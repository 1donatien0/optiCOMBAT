<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:md="http://materialdesigninxaml.net/winfx/xaml/themes">

    <!-- ╔══════════════════════════════════════════════════════════════════╗
         ║  NOTE : CardShadow est défini dans chaque thème (Donaby.*.xaml) ║
         ║  pour s'adapter au mode clair/sombre. Ne pas le redéfinir ici.  ║
         ╚══════════════════════════════════════════════════════════════════╝ -->

    <!-- ── Cartes & en-têtes (glassmorphism — bordure GlassCardRim + fond semi-transparent) ── -->
    <Style x:Key="GlassCard" TargetType="Border">
        <Setter Property="CornerRadius" Value="12"/>
        <Setter Property="Background" Value="{DynamicResource GlassCardBg}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource GlassCardRim}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Effect" Value="{DynamicResource CardShadow}"/>
        <Setter Property="Padding" Value="14,12"/>
        <Setter Property="SnapsToDevicePixels" Value="True"/>
        <Setter Property="UseLayoutRounding" Value="True"/>
    </Style>

    <Style x:Key="MetricCard" TargetType="Border" BasedOn="{StaticResource GlassCard}">
        <Setter Property="CornerRadius" Value="10"/>
        <Setter Property="Background" Value="{DynamicResource CardBg}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource CardBorderAccent}"/>
    </Style>

    <Style x:Key="HeroMetricCard" TargetType="Border">
        <Setter Property="CornerRadius" Value="10"/>
        <Setter Property="Background" Value="{DynamicResource HeroCardGradient}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource HeroCardBorder}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Effect" Value="{DynamicResource GlowShadowAccent}"/>
        <Setter Property="Padding" Value="14,12"/>
    </Style>

    <Style x:Key="PageHeaderBand" TargetType="Border">
        <Setter Property="Margin" Value="24,16,24,0"/>
        <Setter Property="CornerRadius" Value="12"/>
        <Setter Property="BorderBrush" Value="{DynamicResource GlassCardRim}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Background" Value="{DynamicResource PageHeaderMica}"/>
        <Setter Property="Effect" Value="{DynamicResource CardShadow}"/>
        <Setter Property="Padding" Value="18,14"/>
    </Style>

    <Style x:Key="PageHeaderBandDense" TargetType="Border" BasedOn="{StaticResource PageHeaderBand}">
        <Setter Property="Margin" Value="16,16,16,0"/>
    </Style>

    <Style x:Key="PageHeaderIcon" TargetType="Border">
        <Setter Property="Width" Value="48"/>
        <Setter Property="Height" Value="48"/>
        <Setter Property="CornerRadius" Value="24"/>
        <Setter Property="Background" Value="{DynamicResource PageHeaderIconRing}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource PageHeaderIconBorder}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="HorizontalAlignment" Value="Right"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
    </Style>

    <Style x:Key="SectionLabel" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{DynamicResource AppFontFamily}"/>
        <Setter Property="FontSize" Value="{DynamicResource FontSize.Caption}"/>
        <Setter Property="FontWeight" Value="Bold"/>
        <Setter Property="Foreground" Value="{DynamicResource TextAccent}"/>
    </Style>

    <Style x:Key="LogConsolePanel" TargetType="Border" BasedOn="{StaticResource GlassCard}">
        <Setter Property="Padding" Value="14,12"/>
    </Style>

    <Style x:Key="LogConsoleTextBox" TargetType="TextBox">
        <Setter Property="IsReadOnly" Value="True"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Foreground" Value="{DynamicResource TextMedium}"/>
        <Setter Property="FontFamily" Value="Consolas"/>
        <Setter Property="FontSize" Value="{DynamicResource FontSize.Caption}"/>
        <Setter Property="TextWrapping" Value="Wrap"/>
        <Setter Property="AcceptsReturn" Value="True"/>
    </Style>

    <Style x:Key="HubActionCard" TargetType="Border" BasedOn="{StaticResource GlassCard}">
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Padding" Value="0"/>
        <Setter Property="Background" Value="{DynamicResource CardBg}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource CardBorderAccent}"/>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="{DynamicResource CardBgHover}"/>
                <Setter Property="BorderBrush" Value="{DynamicResource PrimaryBlue}"/>
                <Setter Property="Effect" Value="{DynamicResource GlowShadowAccent}"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- Cartes d'action Accueil — Button pour IsPressed + hover (remplace Border + MouseLeftButtonUp) -->
    <Style x:Key="HubActionCardButton" TargetType="Button">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
        <Setter Property="VerticalContentAlignment" Value="Stretch"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="card"
                            Background="{DynamicResource CardBg}"
                            BorderBrush="{DynamicResource CardBorderAccent}"
                            BorderThickness="1"
                            CornerRadius="12"
                            Padding="0"
                            Effect="{DynamicResource CardShadow}">
                        <ContentPresenter HorizontalAlignment="Stretch"
                                          VerticalAlignment="Stretch"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="card" Property="Opacity" Value="0.9"/>
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="card" Property="Background" Value="{DynamicResource CardBgHover}"/>
                            <Setter TargetName="card" Property="BorderBrush" Value="{DynamicResource PrimaryBlue}"/>
                            <Setter TargetName="card" Property="Effect" Value="{DynamicResource GlowShadowAccent}"/>
                        </Trigger>
                        <EventTrigger RoutedEvent="MouseEnter">
                            <BeginStoryboard>
                                <Storyboard>
                                    <DoubleAnimation Storyboard.TargetName="card"
                                                     Storyboard.TargetProperty="Opacity"
                                                     To="0.97" Duration="0:0:0.12"/>
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                        <EventTrigger RoutedEvent="MouseLeave">
                            <BeginStoryboard>
                                <Storyboard>
                                    <DoubleAnimation Storyboard.TargetName="card"
                                                     Storyboard.TargetProperty="Opacity"
                                                     To="1" Duration="0:0:0.12"/>
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="ContentPanelCard" TargetType="Border" BasedOn="{StaticResource GlassCard}">
        <Setter Property="Padding" Value="16,14"/>
        <Setter Property="Background" Value="{DynamicResource CardBg}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource CardBorderAccent}"/>
    </Style>

    <Style x:Key="DangerIconButton" TargetType="Button">
        <Setter Property="Width" Value="28"/>
        <Setter Property="Height" Value="28"/>
        <Setter Property="Padding" Value="0"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="bg" CornerRadius="6" Background="{TemplateBinding Background}">
                        <md:PackIcon Kind="Close" Width="14" Height="14"
                                     Foreground="{DynamicResource DangerRed}"
                                     HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="bg" Property="Opacity" Value="0.85"/>
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="bg" Property="Background" Value="{DynamicResource AlertBg}"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.45"/>
                        </Trigger>
                        <EventTrigger RoutedEvent="MouseEnter">
                            <BeginStoryboard>
                                <Storyboard>
                                    <DoubleAnimation Storyboard.TargetName="bg"
                                                     Storyboard.TargetProperty="Opacity"
                                                     To="0.95" Duration="0:0:0.12"/>
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                        <EventTrigger RoutedEvent="MouseLeave">
                            <BeginStoryboard>
                                <Storyboard>
                                    <DoubleAnimation Storyboard.TargetName="bg"
                                                     Storyboard.TargetProperty="Opacity"
                                                     To="1" Duration="0:0:0.12"/>
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ── Antivirus — panneaux verre ── -->
    <Style x:Key="AvGlassTabShell" TargetType="Border">
        <Setter Property="CornerRadius" Value="12"/>
        <Setter Property="ClipToBounds" Value="True"/>
        <Setter Property="BorderBrush" Value="{DynamicResource GlassCardRim}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Background" Value="{DynamicResource GlassCardBg}"/>
        <Setter Property="Effect" Value="{DynamicResource CardShadow}"/>
    </Style>

    <Style x:Key="AvSideRailCard" TargetType="Border" BasedOn="{StaticResource ContentPanelCard}">
        <Setter Property="Padding" Value="12"/>
        <Setter Property="CornerRadius" Value="10"/>
        <Setter Property="Margin" Value="0"/>
    </Style>

    <Style x:Key="AvSigMetricTile" TargetType="Border">
        <Setter Property="CornerRadius" Value="6"/>
        <Setter Property="Padding" Value="7,5"/>
        <Setter Property="Background" Value="{DynamicResource SurfaceBg}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource GlassCardRim}"/>
        <Setter Property="BorderThickness" Value="1"/>
    </Style>

    <!-- Style DataGridHeader -->
    <Style x:Key="DgHeader" TargetType="DataGridColumnHeader">
        <Setter Property="Background"       Value="{DynamicResource SurfaceBg}"/>
        <Setter Property="Foreground"       Value="{DynamicResource TextMedium}"/>
        <Setter Property="FontFamily"       Value="{DynamicResource AppFontFamily}"/>
        <Setter Property="FontWeight"       Value="SemiBold"/>
        <Setter Property="FontSize"         Value="{DynamicResource FontSize.Small}"/>
        <Setter Property="Padding"          Value="10,8"/>
        <Setter Property="BorderBrush"      Value="{DynamicResource BorderColor}"/>
        <Setter Property="BorderThickness"  Value="0,0,0,1"/>
    </Style>

    <!-- Style DataGridRow -->
    <Style x:Key="DgRow" TargetType="DataGridRow">
        <Setter Property="Background" Value="{DynamicResource CardBg}"/>
        <Setter Property="Foreground" Value="{DynamicResource TextDark}"/>
        <Setter Property="FontFamily" Value="{DynamicResource AppFontFamily}"/>
        <Setter Property="FontSize"   Value="{DynamicResource FontSize.Body}"/>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="{DynamicResource SurfaceBg}"/>
            </Trigger>
            <Trigger Property="AlternationIndex" Value="1">
                <Setter Property="Background" Value="{DynamicResource HeaderBg}"/>
            </Trigger>
            <EventTrigger RoutedEvent="MouseEnter">
                <BeginStoryboard>
                    <Storyboard>
                        <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                         To="0.94" Duration="0:0:0.12"/>
                    </Storyboard>
                </BeginStoryboard>
            </EventTrigger>
            <EventTrigger RoutedEvent="MouseLeave">
                <BeginStoryboard>
                    <Storyboard>
                        <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                         To="1" Duration="0:0:0.12"/>
                    </Storyboard>
                </BeginStoryboard>
            </EventTrigger>
        </Style.Triggers>
    </Style>

    <!-- Cellule DataGrid : texte sur une ligne + infobulle (chemin long, etc.) -->
    <Style x:Key="DgCellTextEllipsis" TargetType="TextBlock">
        <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
        <Setter Property="TextWrapping" Value="NoWrap"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
    </Style>

    <!-- Bouton principal — fond via TemplateBinding (dégradé ou couleur sémantique) -->
    <Style x:Key="GradientPrimaryButton" TargetType="Button">
        <Setter Property="Background"      Value="{DynamicResource AccentGradient}"/>
        <Setter Property="Effect"          Value="{DynamicResource GlowShadowAccent}"/>
        <Setter Property="Foreground"      Value="{DynamicResource TextOnPrimary}"/>
        <Setter Property="FontFamily"      Value="{DynamicResource AppFontFamily}"/>
        <Setter Property="FontWeight"      Value="SemiBold"/>
        <Setter Property="FontSize"        Value="{DynamicResource FontSize.Title}"/>
        <Setter Property="Padding"         Value="14,9"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Cursor"          Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="bg" CornerRadius="8"
                            Background="{TemplateBinding Background}"
                            Padding="{TemplateBinding Padding}"
                            Effect="{TemplateBinding Effect}">
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="bg" Property="Opacity" Value="0.85"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.45"/>
                            <Setter TargetName="bg" Property="Effect" Value="{x:Null}"/>
                        </Trigger>
                        <EventTrigger RoutedEvent="MouseEnter">
                            <BeginStoryboard>
                                <Storyboard>
                                    <DoubleAnimation Storyboard.TargetName="bg"
                                                     Storyboard.TargetProperty="Opacity"
                                                     To="0.92" Duration="0:0:0.14"/>
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                        <EventTrigger RoutedEvent="MouseLeave">
                            <BeginStoryboard>
                                <Storyboard>
                                    <DoubleAnimation Storyboard.TargetName="bg"
                                                     Storyboard.TargetProperty="Opacity"
                                                     To="1" Duration="0:0:0.14"/>
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="PrimaryButton" TargetType="Button" BasedOn="{StaticResource GradientPrimaryButton}">
        <Setter Property="Background" Value="{DynamicResource AccentGradient}"/>
        <Setter Property="Effect" Value="{DynamicResource GlowShadowAccent}"/>
    </Style>

    <Style x:Key="DangerButton" TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
        <Setter Property="Background" Value="{DynamicResource DangerRed}"/>
        <Setter Property="Foreground" Value="{DynamicResource TextOnPrimary}"/>
        <Setter Property="Effect" Value="{x:Null}"/>
    </Style>

    <Style x:Key="WarningButton" TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
        <Setter Property="Background" Value="{DynamicResource WarningOrange}"/>
        <Setter Property="Foreground" Value="{DynamicResource TextOnPrimary}"/>
        <Setter Property="Effect" Value="{x:Null}"/>
    </Style>

    <Style x:Key="SuccessButton" TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
        <Setter Property="Background" Value="{DynamicResource SuccessGreen}"/>
        <Setter Property="Foreground" Value="{DynamicResource TextOnPrimary}"/>
        <Setter Property="Effect" Value="{x:Null}"/>
    </Style>

    <!-- Style SecondaryButton -->
    <Style x:Key="SecondaryButton" TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="{DynamicResource AccentBlue}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="bg" Background="Transparent"
                            BorderBrush="{DynamicResource BorderStrong}" BorderThickness="1"
                            CornerRadius="8" Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="bg" Property="Opacity" Value="0.85"/>
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="bg" Property="Background" Value="{DynamicResource AccentBg}"/>
                            <Setter TargetName="bg" Property="BorderBrush" Value="{DynamicResource AccentBlue}"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.45"/>
                        </Trigger>
                        <EventTrigger RoutedEvent="MouseEnter">
                            <BeginStoryboard>
                                <Storyboard>
                                    <DoubleAnimation Storyboard.TargetName="bg"
                                                     Storyboard.TargetProperty="Opacity"
                                                     To="0.94" Duration="0:0:0.12"/>
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                        <EventTrigger RoutedEvent="MouseLeave">
                            <BeginStoryboard>
                                <Storyboard>
                                    <DoubleAnimation Storyboard.TargetName="bg"
                                                     Storyboard.TargetProperty="Opacity"
                                                     To="1" Duration="0:0:0.12"/>
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Style ExportButton — bouton outlined thématisé (CardBg + BorderColor)
         Utilisé dans HistoryControl pour les boutons d'export HTML/PDF/nav. -->
    <Style x:Key="ExportButton" TargetType="Button">
        <Setter Property="Height"          Value="34"/>
        <Setter Property="Padding"         Value="14,0"/>
        <Setter Property="Cursor"          Value="Hand"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="BorderBrush"     Value="{DynamicResource BorderColor}"/>
        <Setter Property="Background"      Value="{DynamicResource CardBg}"/>
        <Setter Property="Foreground"      Value="{DynamicResource TextDark}"/>
        <Setter Property="FontFamily"      Value="{DynamicResource AppFontFamily}"/>
        <Setter Property="FontSize"        Value="{DynamicResource FontSize.Body}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="bg"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="8">
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center"
                                          Margin="{TemplateBinding Padding}"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="bg" Property="Opacity" Value="0.85"/>
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="bg" Property="Background" Value="{DynamicResource CardBgHover}"/>
                            <Setter TargetName="bg" Property="BorderBrush" Value="{DynamicResource BorderStrong}"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.45"/>
                        </Trigger>
                        <EventTrigger RoutedEvent="MouseEnter">
                            <BeginStoryboard>
                                <Storyboard>
                                    <DoubleAnimation Storyboard.TargetName="bg"
                                                     Storyboard.TargetProperty="Opacity"
                                                     To="0.94" Duration="0:0:0.12"/>
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                        <EventTrigger RoutedEvent="MouseLeave">
                            <BeginStoryboard>
                                <Storyboard>
                                    <DoubleAnimation Storyboard.TargetName="bg"
                                                     Storyboard.TargetProperty="Opacity"
                                                     To="1" Duration="0:0:0.12"/>
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Carte hub Antivirus (bouton avec contenu via ContentPresenter) -->
    <Style x:Key="HubCardButtonStyle" TargetType="Button">
        <Setter Property="OverridesDefaultStyle"  Value="True"/>
        <Setter Property="Cursor"                 Value="Hand"/>
        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
        <Setter Property="VerticalContentAlignment"   Value="Stretch"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="card"
                            Background="{DynamicResource CardBg}"
                            BorderBrush="{DynamicResource CardBorderAccent}"
                            BorderThickness="1"
                            CornerRadius="10"
                            Padding="10,8"
                            Effect="{DynamicResource CardShadow}"
                            MinHeight="88">
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="card" Property="Opacity" Value="0.9"/>
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="card" Property="Background" Value="{DynamicResource CardBgHover}"/>
                            <Setter TargetName="card" Property="BorderBrush" Value="{DynamicResource PrimaryBlue}"/>
                            <Setter TargetName="card" Property="Effect" Value="{DynamicResource GlowShadowAccent}"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="card" Property="Opacity" Value="0.55"/>
                        </Trigger>
                        <EventTrigger RoutedEvent="MouseEnter">
                            <BeginStoryboard>
                                <Storyboard>
                                    <DoubleAnimation Storyboard.TargetName="card"
                                                     Storyboard.TargetProperty="Opacity"
                                                     To="0.96" Duration="0:0:0.12"/>
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                        <EventTrigger RoutedEvent="MouseLeave">
                            <BeginStoryboard>
                                <Storyboard>
                                    <DoubleAnimation Storyboard.TargetName="card"
                                                     Storyboard.TargetProperty="Opacity"
                                                     To="1" Duration="0:0:0.12"/>
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Texte affiché dans ComboBox (ComboBoxItem.Content ou chaîne / heure) -->
    <DataTemplate x:Key="DonabyComboBoxTextTemplate">
        <TextBlock VerticalAlignment="Center"
                   FontFamily="{DynamicResource AppFontFamily}"
                   FontSize="{DynamicResource FontSize.Body}"
                   Foreground="{DynamicResource TextDark}">
            <TextBlock.Text>
                <PriorityBinding FallbackValue="">
                    <Binding Path="Content"/>
                    <Binding/>
                </PriorityBinding>
            </TextBlock.Text>
        </TextBlock>
    </DataTemplate>

    <Style x:Key="DonabyComboBoxItem" TargetType="ComboBoxItem">
        <Setter Property="Foreground" Value="{DynamicResource TextDark}"/>
        <Setter Property="Background" Value="{DynamicResource CardBg}"/>
        <Setter Property="FontFamily" Value="{DynamicResource AppFontFamily}"/>
        <Setter Property="FontSize" Value="{DynamicResource FontSize.Body}"/>
        <Setter Property="Padding" Value="10,8"/>
        <Setter Property="MinHeight" Value="36"/>
        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
        <Setter Property="SnapsToDevicePixels" Value="True"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ComboBoxItem">
                    <Border x:Name="itemBorder"
                            Background="{TemplateBinding Background}"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter TextElement.Foreground="{TemplateBinding Foreground}"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsHighlighted" Value="True">
                            <Setter TargetName="itemBorder" Property="Background" Value="{DynamicResource AccentBg}"/>
                            <Setter Property="Foreground" Value="{DynamicResource TextDark}"/>
                        </Trigger>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter TargetName="itemBorder" Property="Background" Value="{DynamicResource AccentBg}"/>
                            <Setter Property="Foreground" Value="{DynamicResource TextDark}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ComboBox thématisé (évite le fond blanc système en mode sombre) -->
    <Style x:Key="DonabyComboBox" TargetType="ComboBox">
        <Setter Property="Foreground" Value="{DynamicResource TextDark}"/>
        <Setter Property="Background" Value="{DynamicResource SurfaceBg}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource BorderColor}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="FontFamily" Value="{DynamicResource AppFontFamily}"/>
        <Setter Property="FontSize" Value="{DynamicResource FontSize.Body}"/>
        <Setter Property="Padding" Value="10,6,28,6"/>
        <Setter Property="SnapsToDevicePixels" Value="True"/>
        <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Auto"/>
        <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Auto"/>
        <Setter Property="ItemTemplate" Value="{StaticResource DonabyComboBoxTextTemplate}"/>
        <Setter Property="ItemContainerStyle" Value="{StaticResource DonabyComboBoxItem}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ComboBox">
                    <Grid SnapsToDevicePixels="True">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Border x:Name="comboBorder"
                                Grid.ColumnSpan="2"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6"/>
                        <!-- SelectionBoxItemTemplate est en lecture seule : pas de Setter de style (MC3080). -->
                        <ContentPresenter x:Name="selectionPresenter"
                                          Margin="{TemplateBinding Padding}"
                                          HorizontalAlignment="Left"
                                          VerticalAlignment="Center"
                                          Content="{TemplateBinding SelectionBoxItem}"
                                          ContentTemplate="{StaticResource DonabyComboBoxTextTemplate}"
                                          TextElement.Foreground="{DynamicResource TextDark}"
                                          IsHitTestVisible="False"/>
                        <ToggleButton x:Name="dropDownToggle"
                                      Grid.ColumnSpan="2"
                                      Background="Transparent"
                                      BorderThickness="0"
                                      Cursor="Hand"
                                      Focusable="False"
                                      IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                      ClickMode="Release">
                            <ToggleButton.Template>
                                <ControlTemplate TargetType="ToggleButton">
                                    <Border Background="Transparent"
                                            MinHeight="{TemplateBinding MinHeight}"/>
                                </ControlTemplate>
                            </ToggleButton.Template>
                        </ToggleButton>
                        <Path Grid.Column="1"
                              Data="M0,0 L4,4 L8,0 Z"
                              Fill="{DynamicResource TextMuted}"
                              Width="8" Height="5"
                              Margin="0,0,10,0"
                              HorizontalAlignment="Right"
                              VerticalAlignment="Center"
                              IsHitTestVisible="False"/>
                        <Popup x:Name="PART_Popup"
                               Placement="Bottom"
                               PlacementTarget="{Binding ElementName=comboBorder}"
                               IsOpen="{TemplateBinding IsDropDownOpen}"
                               AllowsTransparency="True"
                               Focusable="False"
                               PopupAnimation="Fade">
                            <Border Background="{DynamicResource CardBg}"
                                    BorderBrush="{DynamicResource BorderColor}"
                                    BorderThickness="1"
                                    CornerRadius="6"
                                    Padding="2"
                                    MinWidth="{Binding ActualWidth, RelativeSource={RelativeSource TemplatedParent}}"
                                    MaxHeight="{TemplateBinding MaxDropDownHeight}">
                                <ScrollViewer SnapsToDevicePixels="True">
                                    <ItemsPresenter KeyboardNavigation.DirectionalNavigation="Contained"/>
                                </ScrollViewer>
                            </Border>
                        </Popup>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="comboBorder" Property="Opacity" Value="0.55"/>
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="comboBorder" Property="BorderBrush" Value="{DynamicResource BorderStrong}"/>
                        </Trigger>
                        <Trigger Property="IsKeyboardFocusWithin" Value="True">
                            <Setter TargetName="comboBorder" Property="BorderBrush" Value="{DynamicResource AccentBlue}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Boutons compacts hub Antivirus (dossier / fichier) -->
    <Style x:Key="AntivirusHubActionButtonStyle" TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
        <Setter Property="Padding"                    Value="8,5"/>
        <Setter Property="FontSize"                   Value="{DynamicResource FontSize.Small}"/>
        <Setter Property="HorizontalContentAlignment" Value="Center"/>
    </Style>

    <!-- Onglets principaux (Antivirus, etc.) — contraste sélectionné / non sélectionné -->
    <Style x:Key="DonabyTabItem" TargetType="TabItem">
        <Setter Property="Background" Value="{DynamicResource HeaderBg}"/>
        <Setter Property="Foreground" Value="{DynamicResource TextSecondary}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource BorderColor}"/>
        <Setter Property="BorderThickness" Value="1,1,1,0"/>
        <Setter Property="Padding" Value="14,7"/>
        <Setter Property="Margin" Value="0,0,2,0"/>
        <Setter Property="FontFamily" Value="{DynamicResource AppFontFamily}"/>
        <Setter Property="FontSize" Value="{DynamicResource FontSize.Body}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="TabItem">
                    <Border x:Name="tabBg"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="8,8,0,0">
                        <ContentPresenter x:Name="headerPresenter"
                                          ContentSource="Header"
                                          Margin="{TemplateBinding Padding}"
                                          VerticalAlignment="Center"
                                          HorizontalAlignment="Center"
                                          RecognizesAccessKey="True"
                                          TextElement.Foreground="{TemplateBinding Foreground}"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter TargetName="tabBg" Property="Background" Value="{DynamicResource AccentGradient}"/>
                            <Setter TargetName="tabBg" Property="BorderBrush" Value="{DynamicResource BorderGlass}"/>
                            <Setter TargetName="tabBg" Property="Effect" Value="{DynamicResource GlowShadowAccent}"/>
                            <Setter Property="Foreground" Value="{DynamicResource TextOnPrimary}"/>
                            <Setter TargetName="headerPresenter" Property="TextElement.Foreground"
                                    Value="{DynamicResource TextOnPrimary}"/>
                            <Setter Property="FontWeight" Value="SemiBold"/>
                            <Trigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="tabBg"
                                                         Storyboard.TargetProperty="Opacity"
                                                         From="0.88" To="1" Duration="0:0:0.18">
                                            <DoubleAnimation.EasingFunction>
                                                <QuadraticEase EasingMode="EaseOut"/>
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.EnterActions>
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="tabBg" Property="BorderBrush" Value="{DynamicResource PrimaryBlue}"/>
                        </Trigger>
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="IsSelected" Value="False"/>
                                <Condition Property="IsMouseOver" Value="True"/>
                            </MultiTrigger.Conditions>
                            <Setter Property="Foreground" Value="{DynamicResource TextDark}"/>
                            <Setter TargetName="headerPresenter" Property="TextElement.Foreground"
                                    Value="{DynamicResource TextDark}"/>
                        </MultiTrigger>
                        <EventTrigger RoutedEvent="MouseEnter">
                            <BeginStoryboard>
                                <Storyboard>
                                    <DoubleAnimation Storyboard.TargetName="tabBg"
                                                     Storyboard.TargetProperty="Opacity"
                                                     To="0.94" Duration="0:0:0.12"/>
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                        <EventTrigger RoutedEvent="MouseLeave">
                            <BeginStoryboard>
                                <Storyboard>
                                    <DoubleAnimation Storyboard.TargetName="tabBg"
                                                     Storyboard.TargetProperty="Opacity"
                                                     To="1" Duration="0:0:0.12"/>
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Onglets soulignés (Historique) -->
    <Style x:Key="DonabyTabItemUnderline" TargetType="TabItem">
        <Setter Property="Foreground" Value="{DynamicResource TextMuted}"/>
        <Setter Property="FontFamily" Value="{DynamicResource AppFontFamily}"/>
        <Setter Property="FontSize" Value="{DynamicResource FontSize.Body}"/>
        <Setter Property="Padding" Value="20,12"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="TabItem">
                    <Grid Background="Transparent">
                        <ContentPresenter x:Name="headerPresenter"
                                          ContentSource="Header"
                                          Margin="{TemplateBinding Padding}"
                                          VerticalAlignment="Center"
                                          HorizontalAlignment="Center"
                                          RecognizesAccessKey="True"
                                          TextElement.Foreground="{TemplateBinding Foreground}"/>
                        <Rectangle x:Name="underline" Height="2" VerticalAlignment="Bottom"
                                   Fill="{DynamicResource AccentBlue}" Opacity="0"
                                   RadiusX="1" RadiusY="1"/>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter Property="Foreground" Value="{DynamicResource TextAccent}"/>
                            <Setter TargetName="headerPresenter" Property="TextElement.Foreground"
                                    Value="{DynamicResource TextAccent}"/>
                            <Setter TargetName="underline" Property="Opacity" Value="1"/>
                            <Trigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="underline"
                                                         Storyboard.TargetProperty="Opacity"
                                                         From="0" To="1" Duration="0:0:0.18">
                                            <DoubleAnimation.EasingFunction>
                                                <QuadraticEase EasingMode="EaseOut"/>
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.EnterActions>
                            <Trigger.ExitActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="underline"
                                                         Storyboard.TargetProperty="Opacity"
                                                         To="0" Duration="0:0:0.12"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.ExitActions>
                        </Trigger>
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="IsSelected" Value="False"/>
                                <Condition Property="IsMouseOver" Value="True"/>
                            </MultiTrigger.Conditions>
                            <Setter Property="Foreground" Value="{DynamicResource TextMedium}"/>
                            <Setter TargetName="headerPresenter" Property="TextElement.Foreground"
                                    Value="{DynamicResource TextMedium}"/>
                            <Setter TargetName="underline" Property="Opacity" Value="0.35"/>
                        </MultiTrigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ── État vide réutilisable (DataGrid sans données, etc.) ── -->
    <Style x:Key="EmptyStatePlaceholder" TargetType="StackPanel">
        <Setter Property="HorizontalAlignment" Value="Center"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="IsHitTestVisible" Value="False"/>
        <Setter Property="Opacity" Value="0.55"/>
    </Style>

    <!-- Icônes dans en-têtes d'onglets (héritent Foreground du TabItem) -->
    <Style x:Key="TabHeaderPackIcon" TargetType="md:PackIcon">
        <Setter Property="Foreground" Value="{Binding Foreground, RelativeSource={RelativeSource AncestorType=TabItem}}"/>
    </Style>

    <!-- Chips filtre (Historique, etc.) -->
    <Style x:Key="DonabyChipRadio" TargetType="RadioButton">
        <Setter Property="Background" Value="{DynamicResource SurfaceBg}"/>
        <Setter Property="Foreground" Value="{DynamicResource TextMuted}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource BorderSubtle}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="10,5"/>
        <Setter Property="FontSize" Value="{DynamicResource FontSize.Small}"/>
        <Setter Property="FontFamily" Value="{DynamicResource AppFontFamily}"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="OverridesDefaultStyle" Value="True"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="RadioButton">
                    <Border x:Name="chip"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="14"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center"
                                          RecognizesAccessKey="True"
                                          TextElement.Foreground="{TemplateBinding Foreground}"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="chip" Property="Background" Value="{DynamicResource AccentBlue}"/>
                            <Setter TargetName="chip" Property="BorderBrush" Value="{DynamicResource AccentBlue}"/>
                            <Setter Property="Foreground" Value="{DynamicResource TextOnPrimary}"/>
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="chip" Property="BorderBrush" Value="{DynamicResource AccentBlue}"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.45"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Style NavItem — icône + label centrés, sidebar slim 90px -->
    <Style x:Key="NavItem" TargetType="RadioButton">
        <Setter Property="GroupName"          Value="Navigation"/>
        <Setter Property="Background"         Value="Transparent"/>
        <Setter Property="Foreground"         Value="{DynamicResource SidebarText}"/>
        <Setter Property="Height"             Value="70"/>
        <Setter Property="Cursor"             Value="Hand"/>
        <Setter Property="OverridesDefaultStyle" Value="True"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="RadioButton">
                    <Border x:Name="bg" Background="Transparent"
                            CornerRadius="14" Margin="10,3">
                        <Grid>
                            <!-- Indicateur gauche actif (opacité animée) -->
                            <Rectangle x:Name="bar" Width="3" Height="30" HorizontalAlignment="Left"
                                       VerticalAlignment="Center"
                                       Fill="{DynamicResource SidebarIndicator}"
                                       Opacity="0" RadiusX="2" RadiusY="2"/>
                            <!-- Overlay hover -->
                            <Rectangle x:Name="hoverOverlay" RadiusX="14" RadiusY="14"
                                       Fill="{DynamicResource AccentBlue}" Opacity="0"/>
                            <!-- Contenu : icône + label empilés au centre -->
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Grid>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="bg" Property="Background" Value="{DynamicResource SidebarActiveItem}"/>
                            <Setter TargetName="bg" Property="Effect" Value="{DynamicResource GlowShadowAccent}"/>
                            <Setter TargetName="bar" Property="Opacity" Value="1"/>
                            <Setter Property="Foreground" Value="{DynamicResource SidebarTextActive}"/>
                            <Trigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="bar"
                                                         Storyboard.TargetProperty="Opacity"
                                                         From="0" To="1" Duration="0:0:0.2">
                                            <DoubleAnimation.EasingFunction>
                                                <QuadraticEase EasingMode="EaseOut"/>
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.EnterActions>
                            <Trigger.ExitActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="bar"
                                                         Storyboard.TargetProperty="Opacity"
                                                         To="0" Duration="0:0:0.15"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.ExitActions>
                        </Trigger>
                        <EventTrigger RoutedEvent="MouseEnter">
                            <BeginStoryboard>
                                <Storyboard>
                                    <DoubleAnimation Storyboard.TargetName="hoverOverlay"
                                                     Storyboard.TargetProperty="Opacity"
                                                     To="0.07" Duration="0:0:0.12"/>
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                        <EventTrigger RoutedEvent="MouseLeave">
                            <BeginStoryboard>
                                <Storyboard>
                                    <DoubleAnimation Storyboard.TargetName="hoverOverlay"
                                                     Storyboard.TargetProperty="Opacity"
                                                     To="0" Duration="0:0:0.12"/>
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="bg" Property="Opacity" Value="0.88"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
