<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ═══════════════════════════════════════════════════════════════
         THÈME CONTRASTE RENFORCÉ — conforme Windows HC
         Les couleurs critiques (fond, texte, bordure, sélection) utilisent
         SystemColors.* pour respecter le thème HC choisi par l'utilisateur
         (HC Black, HC White, HC 1, HC 2). Les couleurs sémantiques
         (succès, alerte, danger) conservent des valeurs à fort contraste
         vérifiées WCAG AA (ratio ≥ 4.5:1 sur fond Window).
    ═══════════════════════════════════════════════════════════════ -->

    <!-- ── FONDS — SystemColors : respecte le thème HC système ── -->
    <SolidColorBrush x:Key="AppBg"          Color="{x:Static SystemColors.WindowColor}"/>
    <SolidColorBrush x:Key="SidebarBg"      Color="{x:Static SystemColors.WindowColor}"/>
    <SolidColorBrush x:Key="ContentBg"      Color="{x:Static SystemColors.WindowColor}"/>
    <SolidColorBrush x:Key="HeaderBg"       Color="{x:Static SystemColors.WindowColor}"/>
    <SolidColorBrush x:Key="CardBg"         Color="{x:Static SystemColors.WindowColor}"/>
    <SolidColorBrush x:Key="CardBgHover"    Color="{x:Static SystemColors.HighlightColor}"/>
    <SolidColorBrush x:Key="SurfaceBg"      Color="{x:Static SystemColors.WindowColor}"/>
    <SolidColorBrush x:Key="ContentBgDeep"  Color="{x:Static SystemColors.WindowColor}"/>
    <SolidColorBrush x:Key="GlassCardBg"    Color="{x:Static SystemColors.WindowColor}"/>
    <SolidColorBrush x:Key="BorderGlass"    Color="{x:Static SystemColors.WindowFrameColor}"/>
    <!-- Pas de voile givré en HC : interférerait avec la lisibilité -->
    <SolidColorBrush x:Key="GlassFrostVeil" Color="#00000000"/>

    <!-- ── SIDEBAR ── -->
    <SolidColorBrush x:Key="SidebarActiveItem"  Color="{x:Static SystemColors.HighlightColor}"/>
    <SolidColorBrush x:Key="SidebarActiveGlow"  Color="{x:Static SystemColors.HighlightColor}"/>
    <SolidColorBrush x:Key="SidebarIndicator"   Color="{x:Static SystemColors.HighlightColor}"/>
    <SolidColorBrush x:Key="SidebarText"        Color="{x:Static SystemColors.WindowTextColor}"/>
    <SolidColorBrush x:Key="SidebarTextActive"  Color="{x:Static SystemColors.HighlightTextColor}"/>
    <SolidColorBrush x:Key="SidebarHover"       Color="{x:Static SystemColors.HotTrackColor}"/>

    <!-- ── BORDURES ── -->
    <SolidColorBrush x:Key="BorderColor"        Color="{x:Static SystemColors.WindowFrameColor}"/>
    <SolidColorBrush x:Key="BorderStrong"       Color="{x:Static SystemColors.WindowFrameColor}"/>
    <SolidColorBrush x:Key="BorderSubtle"       Color="{x:Static SystemColors.WindowFrameColor}"/>

    <!-- ── ACCENT PRINCIPAL — couleur de sélection système ── -->
    <SolidColorBrush x:Key="PrimaryBlue"        Color="{x:Static SystemColors.HighlightColor}"/>
    <SolidColorBrush x:Key="AccentBlue"         Color="{x:Static SystemColors.HighlightColor}"/>
    <SolidColorBrush x:Key="AccentBg"           Color="{x:Static SystemColors.HighlightColor}"/>

    <!-- ── SUCCÈS / TEAL — ratio WCAG AA vérifié sur WindowColor ── -->
    <SolidColorBrush x:Key="SuccessGreen"       Color="#007A52"/>
    <SolidColorBrush x:Key="SuccessBg"          Color="{x:Static SystemColors.WindowColor}"/>

    <!-- ── ALERTE / AMBRE ── -->
    <SolidColorBrush x:Key="AlertGold"          Color="#7A4A00"/>
    <SolidColorBrush x:Key="AlertGoldLight"     Color="#7A4A00"/>
    <SolidColorBrush x:Key="AlertBg"            Color="{x:Static SystemColors.WindowColor}"/>
    <SolidColorBrush x:Key="InfoBg"             Color="{x:Static SystemColors.WindowColor}"/>

    <!-- ── AVERTISSEMENT / ORANGE ── -->
    <SolidColorBrush x:Key="WarningOrange"      Color="#7A3300"/>

    <!-- ── DANGER / ROUGE ── -->
    <SolidColorBrush x:Key="DangerRed"          Color="#8B0000"/>

    <!-- ── TEXTES — SystemColors ── -->
    <SolidColorBrush x:Key="TextDark"           Color="{x:Static SystemColors.WindowTextColor}"/>
    <SolidColorBrush x:Key="TextMedium"         Color="{x:Static SystemColors.WindowTextColor}"/>
    <SolidColorBrush x:Key="TextMuted"          Color="{x:Static SystemColors.GrayTextColor}"/>
    <SolidColorBrush x:Key="TextSecondary"      Color="{x:Static SystemColors.WindowTextColor}"/>
    <!-- Texte sur fond sélection système (boutons accent) -->
    <SolidColorBrush x:Key="TextOnPrimary"      Color="{x:Static SystemColors.HighlightTextColor}"/>
    <SolidColorBrush x:Key="TextOnPrimaryMuted" Color="{x:Static SystemColors.HighlightTextColor}"/>
    <SolidColorBrush x:Key="TextAccent"         Color="{x:Static SystemColors.HighlightColor}"/>

    <!-- ── ICÔNE SUR FOND ACCENT ── -->
    <SolidColorBrush x:Key="AccentIconRing"     Color="{x:Static SystemColors.HighlightTextColor}"/>

    <!-- Bordure cards ── -->
    <SolidColorBrush x:Key="CardBorderAccent"  Color="{x:Static SystemColors.WindowFrameColor}"/>

    <!-- En HC les dégradés sont remplacés par des couleurs unies pour éviter la confusion visuelle -->
    <SolidColorBrush x:Key="GlassCardRim"       Color="{x:Static SystemColors.WindowFrameColor}"/>

    <!-- Ligne décorative : couleur de sélection système, opaque -->
    <SolidColorBrush x:Key="AccentLineGradient" Color="{x:Static SystemColors.HighlightColor}"/>

    <!-- Pas de blobs animés en HC (distraction visuelle) -->
    <Color x:Key="MeshBlob1Color">#00000000</Color>
    <Color x:Key="MeshBlob2Color">#00000000</Color>

    <!-- Halos supprimés en HC -->
    <DropShadowEffect x:Key="ShieldGlow"            Color="#00000000" Opacity="0" BlurRadius="0" ShadowDepth="0"/>
    <Color x:Key="HeroHaloOuterColor">#00000000</Color>
    <Color x:Key="HeroHaloInnerColor">#00000000</Color>
    <DropShadowEffect x:Key="HeroShieldPulseGlow"   Color="#00000000" Opacity="0" BlurRadius="0" ShadowDepth="0"/>

    <!-- Ombres supprimées en HC -->
    <DropShadowEffect x:Key="CardShadow"            Color="#00000000" Opacity="0" BlurRadius="0" ShadowDepth="0"/>

    <!-- Boutons — fond sélection système, texte HighlightText -->
    <SolidColorBrush x:Key="AccentGradient"     Color="{x:Static SystemColors.HighlightColor}"/>
    <SolidColorBrush x:Key="HeroCardBorder"     Color="{x:Static SystemColors.WindowFrameColor}"/>
    <SolidColorBrush x:Key="HeroCardGradient"   Color="{x:Static SystemColors.HighlightColor}"/>

    <!-- Mesh désactivé en HC -->
    <SolidColorBrush x:Key="ContentAreaMesh"    Color="#00000000"/>

    <!-- En-tête de page -->
    <SolidColorBrush x:Key="PageHeaderMica"         Color="{x:Static SystemColors.WindowColor}"/>
    <SolidColorBrush x:Key="PageHeaderIconRing"     Color="{x:Static SystemColors.HighlightColor}"/>
    <SolidColorBrush x:Key="PageHeaderIconBorder"   Color="{x:Static SystemColors.WindowFrameColor}"/>

    <!-- Bordure active -->
    <SolidColorBrush x:Key="CardBorderGlow"     Color="{x:Static SystemColors.HighlightColor}"/>

    <!-- Halo accent supprimé -->
    <DropShadowEffect x:Key="GlowShadowAccent"  Color="#00000000" Opacity="0" BlurRadius="0" ShadowDepth="0"/>

    <!-- Toggle thème ── -->
    <SolidColorBrush x:Key="ThemeToggleBg"      Color="{x:Static SystemColors.HighlightColor}"/>
    <SolidColorBrush x:Key="ThemeToggleFg"      Color="{x:Static SystemColors.HighlightTextColor}"/>

    <!-- Badges sévérité — couleurs à fort contraste WCAG AA -->
    <SolidColorBrush x:Key="RiskCritical"       Color="#8B0000"/>
    <SolidColorBrush x:Key="RiskMajor"          Color="#7A3300"/>
    <SolidColorBrush x:Key="RiskMinor"          Color="#7A4A00"/>
    <SolidColorBrush x:Key="RiskInformational"  Color="#007A52"/>

</ResourceDictionary>
