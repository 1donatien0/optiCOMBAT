<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ═══════════════════════════════════════════════════════════════
         THÈME CLAIR — « Combat Aqua »
         Blanc épuré + accent bleu-vert (teal/cyan).
         Dégradé signature vert → bleu.
    ═══════════════════════════════════════════════════════════════ -->

    <!-- ── FONDS (blanc froid épuré) ── -->
    <SolidColorBrush x:Key="AppBg"          Color="#F3F6FA"/>
    <SolidColorBrush x:Key="SidebarBg"      Color="#FFFFFF"/>
    <SolidColorBrush x:Key="ContentBg"      Color="#F3F6FA"/>
    <SolidColorBrush x:Key="HeaderBg"       Color="#FFFFFF"/>
    <SolidColorBrush x:Key="CardBg"         Color="#FFFFFF"/>
    <SolidColorBrush x:Key="CardBgHover"    Color="#E8F6F4"/>
    <SolidColorBrush x:Key="SurfaceBg"      Color="#EEF3F7"/>
    <SolidColorBrush x:Key="ContentBgDeep"  Color="#F3F6FA"/>
    <SolidColorBrush x:Key="GlassCardBg"    Color="#E6FFFFFF"/>
    <SolidColorBrush x:Key="BorderGlass"    Color="#D2DEE8"/>
    <!-- Voile givré sur le mesh (simule diffusion acrylic WPF) -->
    <SolidColorBrush x:Key="GlassFrostVeil" Color="#30FFFFFF"/>

    <!-- ── SIDEBAR ── -->
    <SolidColorBrush x:Key="SidebarActiveItem"  Color="#E2F5F1"/>
    <SolidColorBrush x:Key="SidebarActiveGlow"  Color="#0EA5A4"/>
    <SolidColorBrush x:Key="SidebarIndicator"   Color="#0EA5A4"/>
    <SolidColorBrush x:Key="SidebarText"        Color="#5A6B73"/>
    <SolidColorBrush x:Key="SidebarTextActive"  Color="#0E3A40"/>
    <SolidColorBrush x:Key="SidebarHover"       Color="#EFF7F6"/>

    <!-- ── BORDURES ── -->
    <SolidColorBrush x:Key="BorderColor"        Color="#DCE4EA"/>
    <SolidColorBrush x:Key="BorderStrong"       Color="#B6C2CB"/>
    <SolidColorBrush x:Key="BorderSubtle"       Color="#E6ECF1"/>

    <!-- ── ACCENT PRINCIPAL (bleu-vert / teal) ── -->
    <SolidColorBrush x:Key="PrimaryBlue"        Color="#0EA5A4"/>
    <SolidColorBrush x:Key="AccentBlue"         Color="#0EA5A4"/>
    <SolidColorBrush x:Key="AccentBg"           Color="#DCF4F2"/>

    <!-- ── SUCCÈS / VERT ── -->
    <SolidColorBrush x:Key="SuccessGreen"       Color="#16A66B"/>
    <SolidColorBrush x:Key="SuccessBg"          Color="#E0F5EC"/>

    <!-- ── ALERTE / AMBRE ── -->
    <SolidColorBrush x:Key="AlertGold"          Color="#BA7517"/>
    <SolidColorBrush x:Key="AlertGoldLight"     Color="#EF9F27"/>
    <SolidColorBrush x:Key="AlertBg"            Color="#FAEEDA"/>
    <SolidColorBrush x:Key="InfoBg"             Color="#E2F0FB"/>

    <!-- ── AVERTISSEMENT / ORANGE ── -->
    <SolidColorBrush x:Key="WarningOrange"      Color="#854F0B"/>

    <!-- ── DANGER / ROUGE ── -->
    <SolidColorBrush x:Key="DangerRed"          Color="#C2403F"/>

    <!-- ── TEXTES ── -->
    <SolidColorBrush x:Key="TextDark"           Color="#16242B"/>
    <SolidColorBrush x:Key="TextMedium"         Color="#51626B"/>
    <SolidColorBrush x:Key="TextMuted"          Color="#93A2AB"/>
    <!-- Alias sémantique de TextMedium (libellés secondaires) -->
    <SolidColorBrush x:Key="TextSecondary"      Color="#51626B"/>
    <!-- Texte sur fond accent (boutons teal, bandeaux) -->
    <SolidColorBrush x:Key="TextOnPrimary"      Color="#FFFFFF"/>
    <SolidColorBrush x:Key="TextOnPrimaryMuted" Color="#CDEEEC"/>
    <SolidColorBrush x:Key="TextAccent"         Color="#0E8F8E"/>

    <!-- ── ICÔNE SUR FOND ACCENT — anneau semi-transparent posé sur PrimaryBlue ── -->
    <SolidColorBrush x:Key="AccentIconRing"     Color="#33FFFFFF"/>

    <!-- Bordure subtile cards -->
    <SolidColorBrush x:Key="CardBorderAccent"  Color="#DDE6EC"/>

    <!-- Bordure verre — reflet froid haut-gauche + accent teal bas-droite -->
    <LinearGradientBrush x:Key="GlassCardRim" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#CCFFFFFF" Offset="0"/>
        <GradientStop Color="#99CFDAE2" Offset="0.45"/>
        <GradientStop Color="#440EA5A4" Offset="1"/>
    </LinearGradientBrush>

    <!-- Accent fin pour lignes décoratives (teal → bleu) -->
    <LinearGradientBrush x:Key="AccentLineGradient" StartPoint="0,0" EndPoint="1,0">
        <GradientStop Color="#00000000" Offset="0"/>
        <GradientStop Color="#8810B5A6" Offset="0.4"/>
        <GradientStop Color="#882E97E0" Offset="0.7"/>
        <GradientStop Color="#00000000" Offset="1"/>
    </LinearGradientBrush>

    <!-- ── Fond mesh animé (MainWindow) — vert + bleu ── -->
    <Color x:Key="MeshBlob1Color">#8819C29A</Color>
    <Color x:Key="MeshBlob2Color">#882E97E0</Color>

    <!-- Halos hero (mode clair) — lueur teal-vert -->
    <DropShadowEffect x:Key="ShieldGlow"
                      Color="#16A66B" Opacity="0.32"
                      BlurRadius="32" ShadowDepth="0"/>

    <!-- Hero accueil — halo bleu-vert autour de l'emblème OPTICOMBAT -->
    <Color x:Key="HeroHaloOuterColor">#5510B5A6</Color>
    <Color x:Key="HeroHaloInnerColor">#8819C29A</Color>
    <DropShadowEffect x:Key="HeroShieldPulseGlow"
                      Color="#0EA5A4" Opacity="0.42"
                      BlurRadius="28" ShadowDepth="0"/>

    <!-- ── OMBRES (très légères en mode clair, esprit épuré) ── -->
    <DropShadowEffect x:Key="CardShadow"
                      Color="#1B3A4B" Opacity="0.07"
                      BlurRadius="10" ShadowDepth="1" Direction="270"/>

    <!-- Dégradé accent signature : vert → teal → bleu -->
    <LinearGradientBrush x:Key="AccentGradient" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#19C29A" Offset="0"/>
        <GradientStop Color="#10ADAE" Offset="0.5"/>
        <GradientStop Color="#2E97E0" Offset="1"/>
    </LinearGradientBrush>
    <SolidColorBrush x:Key="HeroCardBorder"     Color="#66FFFFFF"/>

    <LinearGradientBrush x:Key="HeroCardGradient" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#1FC8A2" Offset="0"/>
        <GradientStop Color="#10ADAE" Offset="0.55"/>
        <GradientStop Color="#2E97E0" Offset="1"/>
    </LinearGradientBrush>
    <LinearGradientBrush x:Key="ContentAreaMesh" StartPoint="0,1" EndPoint="1,0">
        <GradientStop Color="#DBF5EF" Offset="0"/>
        <GradientStop Color="#00FFFFFF" Offset="0.4"/>
        <GradientStop Color="#DCEEFB" Offset="0.8"/>
        <GradientStop Color="#00FFFFFF" Offset="1"/>
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="PageHeaderMica" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#F4F8FA" Offset="0"/>
        <GradientStop Color="#E6F4F2" Offset="0.55"/>
        <GradientStop Color="#EEF4F8" Offset="1"/>
    </LinearGradientBrush>
    <SolidColorBrush x:Key="PageHeaderIconRing"   Color="#DCF4F2"/>
    <SolidColorBrush x:Key="PageHeaderIconBorder" Color="#A9E3DE"/>

    <LinearGradientBrush x:Key="CardBorderGlow" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#660EA5A4" Offset="0"/>
        <GradientStop Color="#332E97E0" Offset="1"/>
    </LinearGradientBrush>

    <DropShadowEffect x:Key="GlowShadowAccent"
                      Color="#0EA5A4" Opacity="0.26"
                      BlurRadius="16" ShadowDepth="0"/>

    <!-- ── INDICATEUR TOGGLE (icône soleil pour le bouton thème) ── -->
    <SolidColorBrush x:Key="ThemeToggleBg"      Color="#DCF4F2"/>
    <SolidColorBrush x:Key="ThemeToggleFg"      Color="#0E8F8E"/>

    <!-- Badges sévérité menaces (grille Antivirus — thème clair/sombre) -->
    <SolidColorBrush x:Key="RiskCritical"       Color="#C2403F"/>
    <SolidColorBrush x:Key="RiskMajor"          Color="#854F0B"/>
    <SolidColorBrush x:Key="RiskMinor"          Color="#BA7517"/>
    <SolidColorBrush x:Key="RiskInformational"  Color="#16A66B"/>

</ResourceDictionary>
