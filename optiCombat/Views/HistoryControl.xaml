<UserControl x:Class="optiCombat.Views.HistoryControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:md="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:loc="clr-namespace:optiCombat.Localization"
             xmlns:c="clr-namespace:optiCombat.Converters"
             xmlns:services="clr-namespace:optiCombat.Services;assembly=optiCombat.Application">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <c:InverseBooleanToVisibilityConverter x:Key="InverseBoolToVis"/>
        <c:QuarantinePathVisibilityConverter x:Key="QuarantinePathVis"/>
        <c:ThreatRiskLevelConverter x:Key="ThreatRiskLevel"/>
        <c:ThreatRiskSeverityConverter x:Key="ThreatRiskSeverity"/>
        <c:ThreatRiskIconConverter x:Key="ThreatRiskIcon"/>
    </UserControl.Resources>

    <DockPanel Background="Transparent">
        <Rectangle DockPanel.Dock="Top" Height="2" Margin="48,0,48,0" Opacity="0.55"
                   Fill="{DynamicResource AccentLineGradient}"/>

        <!-- En-tete -->
        <Border DockPanel.Dock="Top" Style="{StaticResource PageHeaderBandDense}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                    <TextBlock Text="{loc:Loc Key=Hist_Title}"
                               FontSize="{DynamicResource FontSize.Hero}" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextDark}"/>
                    <TextBlock Text="{loc:Loc Key=Hist_Sub}"
                               FontSize="{DynamicResource FontSize.Small}" Foreground="{DynamicResource TextMuted}"
                               Margin="0,4,0,0"/>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Content="{loc:Loc Key=Hist_ExportHtml}"
                            Click="BtnExportHtml_Click" Style="{StaticResource ExportButton}"
                            Margin="0,0,8,0" ToolTip="{loc:Loc Key=Hist_TooltipExportHtml}"
                            AutomationProperties.Name="{loc:Loc Key=Hist_ExportHtml}"/>
                    <Button Content="{loc:Loc Key=Hist_ExportPdf}"
                            Click="BtnExportSelectedPdf_Click" Style="{StaticResource ExportButton}"
                            IsEnabled="{Binding CanExportPdf}"
                            Margin="0,0,8,0" ToolTip="{loc:Loc Key=Hist_TooltipExportPdf}"
                            AutomationProperties.Name="{loc:Loc Key=Hist_ExportPdf}"/>
                    <Button Click="BtnOpenAntivirus_Click" Style="{StaticResource ExportButton}"
                            AutomationProperties.Name="{loc:Loc Key=Hist_OpenAv}">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <md:PackIcon Kind="ShieldCheck" Width="15" Height="15"
                                         Foreground="{DynamicResource TextAccent}" VerticalAlignment="Center"/>
                            <TextBlock Text="{loc:Loc Key=Hist_OpenAv}" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextDark}" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Corps -->
        <Border Style="{StaticResource GlassCard}" Margin="24,16,24,24" Padding="0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" MinHeight="100"/>
                    <RowDefinition Height="5"/>
                    <RowDefinition Height="*" MinHeight="100"/>
                </Grid.RowDefinitions>

                <!-- Haut : chips filtre + timeline -->
                <Grid Grid.Row="0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Barre chips + recherche -->
                    <Grid Grid.Row="0" Margin="12,8,12,6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <!-- Chips filtre -->
                        <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                            <RadioButton x:Name="chipAll"
                                         Content="{Binding ChipAllLabel}"
                                         GroupName="HistFilter" IsChecked="True"
                                         Style="{StaticResource DonabyChipRadio}"
                                         Checked="Chip_Checked" Tag="All" Margin="0,0,6,0"/>
                            <RadioButton x:Name="chipThreats"
                                         Content="{Binding ChipThreatsLabel}"
                                         GroupName="HistFilter"
                                         Style="{StaticResource DonabyChipRadio}"
                                         Checked="Chip_Checked" Tag="Threats" Margin="0,0,6,0"/>
                            <RadioButton x:Name="chipClean"
                                         Content="{Binding ChipCleanScansLabel}"
                                         GroupName="HistFilter"
                                         Style="{StaticResource DonabyChipRadio}"
                                         Checked="Chip_Checked" Tag="CleanScans" Margin="0,0,6,0"/>
                            <RadioButton x:Name="chipSweep"
                                         Content="{Binding ChipCleansLabel}"
                                         GroupName="HistFilter"
                                         Style="{StaticResource DonabyChipRadio}"
                                         Checked="Chip_Checked" Tag="Cleans" Margin="0,0,6,0"/>
                            <RadioButton x:Name="chipQuarantine"
                                         Content="{Binding ChipQuarantineLabel}"
                                         GroupName="HistFilter"
                                         Style="{StaticResource DonabyChipRadio}"
                                         Checked="Chip_Checked" Tag="Quarantine"/>
                        </StackPanel>

                        <!-- Recherche -->
                        <TextBox Grid.Column="1" x:Name="txtSearch"
                                 Width="220" Height="32" VerticalAlignment="Center"
                                 md:HintAssist.Hint="{loc:Loc Key=Hist_SearchScan}"
                                 md:HintAssist.Foreground="{DynamicResource TextMuted}"
                                 Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"/>
                    </Grid>

                    <!-- DataGrid timeline unifiee -->
                    <Grid Grid.Row="1">
                        <DataGrid x:Name="dgTimeline"
                                  ItemsSource="{Binding FilteredEntries}"
                                  SelectedItem="{Binding SelectedEntry, Mode=TwoWay}"
                                  AutoGenerateColumns="False" IsReadOnly="True"
                                  CanUserAddRows="False"
                                  GridLinesVisibility="Horizontal"
                                  HorizontalGridLinesBrush="{DynamicResource BorderSubtle}"
                                  Background="Transparent" BorderThickness="0"
                                  ColumnHeaderStyle="{DynamicResource DgHeader}"
                                  RowStyle="{DynamicResource DgRow}"
                                  AlternationCount="2"
                                  VirtualizingPanel.IsVirtualizing="True">
                            <DataGrid.Style>
                                <Style TargetType="DataGrid">
                                    <Setter Property="Visibility" Value="Visible"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsEmpty}" Value="True">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </DataGrid.Style>
                            <DataGrid.Columns>
                                <!-- Icone type -->
                                <DataGridTemplateColumn Width="36" CanUserResize="False" CanUserSort="False">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <md:PackIcon Width="16" Height="16"
                                                         Kind="{Binding IconKind}"
                                                         HorizontalAlignment="Center"
                                                         VerticalAlignment="Center">
                                                <md:PackIcon.Style>
                                                    <Style TargetType="md:PackIcon">
                                                        <Setter Property="Foreground" Value="{DynamicResource SuccessGreen}"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding HasThreats}" Value="True">
                                                                <Setter Property="Foreground" Value="{DynamicResource DangerRed}"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding Kind}" Value="Clean">
                                                                <Setter Property="Foreground" Value="{DynamicResource TextAccent}"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding Kind}" Value="Quarantine">
                                                                <Setter Property="Foreground" Value="{DynamicResource WarningOrange}"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </md:PackIcon.Style>
                                            </md:PackIcon>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>

                                <DataGridTextColumn Header="{loc:Loc Key=Hist_ColDate}"
                                                    Binding="{Binding DateDisplay}" Width="140"/>
                                <DataGridTextColumn Header="{loc:Loc Key=Hist_ColType}"
                                                    Binding="{Binding TypeDisplay}" Width="120"/>
                                <DataGridTextColumn Header="{loc:Loc Key=Hist_ColTarget}"
                                                    Binding="{Binding TargetDisplay}" Width="*">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock" BasedOn="{StaticResource DgCellTextEllipsis}">
                                            <Setter Property="ToolTip" Value="{Binding TargetDisplay}"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                                <DataGridTextColumn Header="{loc:Loc Key=Hist_ColDuration}"
                                                    Binding="{Binding DetailDisplay}" Width="100"/>

                                <!-- Resultat avec couleur -->
                                <DataGridTemplateColumn Header="{loc:Loc Key=Hist_ColResult}" Width="180">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Border CornerRadius="4" Padding="6,2" Margin="2,1"
                                                    HorizontalAlignment="Left">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Background" Value="{DynamicResource SuccessBg}"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding HasThreats}" Value="True">
                                                                <Setter Property="Background" Value="{DynamicResource RiskMinor}"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding Kind}" Value="Clean">
                                                                <Setter Property="Background" Value="{DynamicResource InfoBg}"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding Kind}" Value="Quarantine">
                                                                <Setter Property="Background" Value="{DynamicResource SurfaceBg}"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <TextBlock Text="{Binding ResultSummary}"
                                                           FontSize="{DynamicResource FontSize.Small}"
                                                           FontWeight="SemiBold">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Foreground" Value="{DynamicResource SuccessGreen}"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding HasThreats}" Value="True">
                                                                    <Setter Property="Foreground" Value="{DynamicResource DangerRed}"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding Kind}" Value="Clean">
                                                                    <Setter Property="Foreground" Value="{DynamicResource TextAccent}"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding Kind}" Value="Quarantine">
                                                                    <Setter Property="Foreground" Value="{DynamicResource WarningOrange}"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </Border>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>

                        <!-- Etat vide -->
                        <StackPanel x:Name="emptyState">
                            <StackPanel.Style>
                                <Style TargetType="StackPanel" BasedOn="{StaticResource EmptyStatePlaceholder}">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsEmpty}" Value="True">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </StackPanel.Style>
                            <md:PackIcon Kind="History" Width="48" Height="48"
                                         Foreground="{DynamicResource TextMuted}"
                                         HorizontalAlignment="Center"/>
                            <TextBlock Text="{Binding EmptyTitle}"
                                       FontSize="{DynamicResource FontSize.Title}" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextMedium}"
                                       HorizontalAlignment="Center" Margin="0,10,0,4"/>
                            <TextBlock Text="{Binding EmptySubtitle}"
                                       FontSize="{DynamicResource FontSize.Body}"
                                       Foreground="{DynamicResource TextMuted}"
                                       HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Grid>
                </Grid>

                <!-- Separateur redimensionnable -->
                <GridSplitter Grid.Row="1" Height="5" HorizontalAlignment="Stretch"
                              Background="{DynamicResource BorderSubtle}"
                              Cursor="SizeNS" ResizeDirection="Rows"
                              ShowsPreview="False" Focusable="False"/>

                <!-- Bas : detail de l'entree selectionnee -->
                <Grid Grid.Row="2" Margin="12,4,12,12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Barre info + actions -->
                    <Grid Grid.Row="0" Margin="0,0,0,6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <!-- Info session compacte -->
                        <StackPanel Grid.Column="0" x:Name="sessionInfoBar"
                                    Orientation="Horizontal" VerticalAlignment="Center"
                                    Visibility="Collapsed">
                            <Border Background="{DynamicResource SurfaceBg}"
                                    CornerRadius="4" Padding="7,3" Margin="0,0,6,0">
                                <TextBlock x:Name="txtSessionDate"
                                           FontSize="{DynamicResource FontSize.Small}"
                                           Foreground="{DynamicResource TextMuted}"/>
                            </Border>
                            <Border Background="{DynamicResource SurfaceBg}"
                                    CornerRadius="4" Padding="7,3" Margin="0,0,6,0">
                                <TextBlock x:Name="txtSessionMeta"
                                           FontSize="{DynamicResource FontSize.Small}"
                                           Foreground="{DynamicResource TextMuted}"/>
                            </Border>
                            <Border x:Name="resultChip" Background="{DynamicResource SurfaceBg}"
                                    CornerRadius="4" Padding="7,3">
                                <TextBlock x:Name="txtSessionResult"
                                           FontSize="{DynamicResource FontSize.Small}"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextDark}"/>
                            </Border>
                        </StackPanel>

                        <!-- Indice si aucune selection -->
                        <TextBlock Grid.Column="0" x:Name="txtNoSelHint"
                                   Text="{loc:Loc Key=Hist_SelectScanHint}"
                                   FontSize="{DynamicResource FontSize.Small}"
                                   Foreground="{DynamicResource TextMuted}"
                                   VerticalAlignment="Center"/>

                        <!-- Actions (scan seulement) -->
                        <StackPanel Grid.Column="1" x:Name="scanActionBar"
                                    Orientation="Horizontal"
                                    Visibility="{Binding ShowScanActions, Converter={StaticResource BoolToVis}}">
                            <Button x:Name="btnTreatInAntivirus"
                                    Click="BtnTreatInAntivirus_Click"
                                    Style="{StaticResource PrimaryButton}"
                                    Padding="10,5" Margin="0,0,8,0"
                                    IsEnabled="{Binding ShowScanActions}"
                                    ToolTip="{loc:Loc Key=Hist_TooltipTreatInAv}"
                                    AutomationProperties.Name="{loc:Loc Key=Hist_TreatInAv}">
                                <StackPanel Orientation="Horizontal">
                                    <md:PackIcon Kind="ShieldSearch" Width="14" Height="14"
                                                 VerticalAlignment="Center" Margin="0,0,6,0"/>
                                    <TextBlock Text="{loc:Loc Key=Hist_TreatInAv}" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                            <Button x:Name="btnHistQuarantineAll"
                                    Click="BtnHistQuarantineAll_Click"
                                    Style="{StaticResource WarningButton}"
                                    Padding="10,5"
                                    IsEnabled="{Binding ShowScanActions}"
                                    ToolTip="{loc:Loc Key=Hist_TooltipQuarantineAll}"
                                    AutomationProperties.Name="{loc:Loc Key=Hist_QuarantineAll}">
                                <TextBlock Text="{loc:Loc Key=Hist_QuarantineAll}" VerticalAlignment="Center"/>
                            </Button>
                        </StackPanel>
                    </Grid>

                    <!-- Menaces (scan avec menaces) -->
                    <DataGrid x:Name="dgHistoryThreats" Grid.Row="1"
                              AutoGenerateColumns="False" IsReadOnly="True"
                              CanUserAddRows="False"
                              GridLinesVisibility="Horizontal"
                              HorizontalGridLinesBrush="{DynamicResource BorderSubtle}"
                              Background="Transparent" BorderThickness="0"
                              ColumnHeaderStyle="{DynamicResource DgHeader}"
                              RowStyle="{DynamicResource DgRow}"
                              Visibility="Collapsed">
                        <DataGrid.Columns>
                            <DataGridTemplateColumn Header="{loc:Loc Key=Av_ColRisk}" Width="90">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Border CornerRadius="4" Padding="5,2" Margin="2,0">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Background" Value="{DynamicResource RiskInformational}"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Converter={StaticResource ThreatRiskLevel}}"
                                                                     Value="{x:Static services:RiskLevel.Critical}">
                                                            <Setter Property="Background" Value="{DynamicResource RiskCritical}"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Converter={StaticResource ThreatRiskLevel}}"
                                                                     Value="{x:Static services:RiskLevel.Major}">
                                                            <Setter Property="Background" Value="{DynamicResource RiskMajor}"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Converter={StaticResource ThreatRiskLevel}}"
                                                                     Value="{x:Static services:RiskLevel.Minor}">
                                                            <Setter Property="Background" Value="{DynamicResource RiskMinor}"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                                <md:PackIcon Width="11" Height="11"
                                                             Foreground="{DynamicResource TextOnPrimary}"
                                                             Kind="{Binding Converter={StaticResource ThreatRiskIcon}}"/>
                                                <TextBlock Text="{Binding Converter={StaticResource ThreatRiskSeverity}}"
                                                           FontSize="{DynamicResource FontSize.Micro}"
                                                           Foreground="{DynamicResource TextOnPrimary}"
                                                           VerticalAlignment="Center" Margin="4,0,0,0"/>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTextColumn Header="{loc:Loc Key=Av_ColPath}"
                                                Binding="{Binding FilePath}" Width="*">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock" BasedOn="{StaticResource DgCellTextEllipsis}">
                                        <Setter Property="ToolTip" Value="{Binding FilePath}"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridTextColumn Header="{loc:Loc Key=Av_ColThreat}"
                                                Binding="{Binding VirusName}" Width="200">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock" BasedOn="{StaticResource DgCellTextEllipsis}">
                                        <Setter Property="ToolTip" Value="{Binding VirusName}"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridTemplateColumn Header="{loc:Loc Key=Av_ColClean}" Width="300">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal" Margin="2,1">
                                            <Button Tag="{Binding FilePath}" Click="BtnViewInQuarantine_Click"
                                                    Style="{StaticResource ExportButton}"
                                                    FontSize="{DynamicResource FontSize.Caption}" Padding="7,4" Cursor="Hand"
                                                    Margin="0,0,4,0" ToolTip="{loc:Loc Key=Hist_ViewInQuarantine}"
                                                    Visibility="{Binding CanViewInQuarantine, Converter={StaticResource BoolToVis}}">
                                                <StackPanel Orientation="Horizontal">
                                                    <md:PackIcon Kind="ShieldLock" Width="12" Height="12" Margin="0,0,4,0" VerticalAlignment="Center"/>
                                                    <TextBlock Text="{loc:Loc Key=Hist_ViewInQuarantine}" VerticalAlignment="Center"/>
                                                </StackPanel>
                                            </Button>
                                            <Button Tag="{Binding FilePath}" Click="BtnHistQuarantine_Click"
                                                    Style="{StaticResource PrimaryButton}"
                                                    FontSize="{DynamicResource FontSize.Caption}" Padding="7,4" Cursor="Hand"
                                                    Margin="0,0,4,0"
                                                    Visibility="{Binding CanQuarantine, Converter={StaticResource BoolToVis}}">
                                                <StackPanel Orientation="Horizontal">
                                                    <md:PackIcon Kind="ShieldLock" Width="12" Height="12" Margin="0,0,4,0" VerticalAlignment="Center"/>
                                                    <TextBlock Text="{loc:Loc Key=Av_QuarantineBtn}" VerticalAlignment="Center"/>
                                                </StackPanel>
                                            </Button>
                                            <Button Tag="{Binding FilePath}" Click="BtnHistDismiss_Click"
                                                    Style="{StaticResource ExportButton}"
                                                    FontSize="{DynamicResource FontSize.Caption}" Padding="7,4" Cursor="Hand"
                                                    Margin="0,0,4,0" ToolTip="{loc:Loc Key=Hist_TooltipDismiss}"
                                                    Visibility="{Binding CanDismiss, Converter={StaticResource BoolToVis}}">
                                                <StackPanel Orientation="Horizontal">
                                                    <md:PackIcon Kind="CloseCircleOutline" Width="12" Height="12" Margin="0,0,4,0" VerticalAlignment="Center"/>
                                                    <TextBlock Text="{loc:Loc Key=Hist_DismissThreat}" VerticalAlignment="Center"/>
                                                </StackPanel>
                                            </Button>
                                            <Button Tag="{Binding FilePath}" Click="BtnHistIgnore_Click"
                                                    Style="{StaticResource WarningButton}"
                                                    FontSize="{DynamicResource FontSize.Caption}" Padding="7,4" Cursor="Hand"
                                                    Margin="0,0,4,0" ToolTip="{loc:Loc Key=Av_Tooltip_Exclude}"
                                                    Visibility="{Binding IsFileAccessible, Converter={StaticResource BoolToVis}}">
                                                <StackPanel Orientation="Horizontal">
                                                    <md:PackIcon Kind="EyeOff" Width="12" Height="12" Margin="0,0,4,0" VerticalAlignment="Center"/>
                                                    <TextBlock Text="{loc:Loc Key=Av_IgnoreBtn}" VerticalAlignment="Center"/>
                                                </StackPanel>
                                            </Button>
                                            <Button Tag="{Binding FilePath}" Click="BtnHistDelete_Click"
                                                    Style="{StaticResource DangerButton}"
                                                    FontSize="{DynamicResource FontSize.Caption}" Padding="7,4" Cursor="Hand"
                                                    Visibility="{Binding IsFileAccessible, Converter={StaticResource BoolToVis}}">
                                                <StackPanel Orientation="Horizontal">
                                                    <md:PackIcon Kind="TrashCanOutline" Width="12" Height="12" Margin="0,0,4,0" VerticalAlignment="Center"/>
                                                    <TextBlock Text="{loc:Loc Key=Av_DeleteBtn}" VerticalAlignment="Center"/>
                                                </StackPanel>
                                            </Button>
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>

                    <!-- Journal nettoyage -->
                    <Border x:Name="cleanLogPanel" Grid.Row="1"
                            Style="{StaticResource LogConsolePanel}"
                            Visibility="Collapsed" Padding="0">
                        <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="12,10">
                            <TextBlock x:Name="txtCleanLog"
                                       TextWrapping="Wrap" FontFamily="Consolas"
                                       FontSize="{DynamicResource FontSize.Small}"
                                       Foreground="{DynamicResource TextDark}"/>
                        </ScrollViewer>
                    </Border>

                    <!-- Détail quarantaine -->
                    <Border x:Name="quarantineDetailPanel" Grid.Row="1"
                            Background="{DynamicResource SurfaceBg}"
                            CornerRadius="8" Padding="16,14"
                            Visibility="Collapsed">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                <md:PackIcon Kind="ShieldLock" Width="22" Height="22"
                                             Foreground="{DynamicResource WarningOrange}"
                                             VerticalAlignment="Center" Margin="0,0,10,0"/>
                                <TextBlock x:Name="txtQuarTitle"
                                           FontSize="{DynamicResource FontSize.Title}"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextDark}"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                            <TextBlock x:Name="txtQuarPath"
                                       TextWrapping="Wrap"
                                       FontSize="{DynamicResource FontSize.Body}"
                                       Foreground="{DynamicResource TextMedium}"
                                       Margin="0,0,0,6"/>
                            <TextBlock x:Name="txtQuarMeta"
                                       FontSize="{DynamicResource FontSize.Small}"
                                       Foreground="{DynamicResource TextMuted}"
                                       Margin="0,0,0,8"/>
                            <TextBlock x:Name="txtQuarStatus"
                                       FontSize="{DynamicResource FontSize.Small}"
                                       Foreground="{DynamicResource TextAccent}"
                                       Margin="0,0,0,14"/>
                            <StackPanel Orientation="Horizontal">
                                <Button x:Name="btnViewSourceScan"
                                        Click="BtnViewSourceScan_Click"
                                        Style="{StaticResource ExportButton}"
                                        Padding="10,5" Margin="0,0,8,0"
                                        Visibility="{Binding HasQuarantineSourceScan, Converter={StaticResource BoolToVis}}"
                                        ToolTip="{loc:Loc Key=Hist_TooltipViewSourceScan}"
                                        AutomationProperties.Name="{loc:Loc Key=Hist_ViewSourceScan}">
                                    <StackPanel Orientation="Horizontal">
                                        <md:PackIcon Kind="ShieldSearch" Width="14" Height="14"
                                                     VerticalAlignment="Center" Margin="0,0,6,0"/>
                                        <TextBlock Text="{loc:Loc Key=Hist_ViewSourceScan}" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>
                                <Button x:Name="btnManageInAv"
                                    Click="BtnManageInAv_Click"
                                    Style="{StaticResource PrimaryButton}"
                                    Padding="10,5"
                                    ToolTip="{loc:Loc Key=Hist_TooltipManageInAv}"
                                    AutomationProperties.Name="{loc:Loc Key=Hist_ManageInAv}">
                                <StackPanel Orientation="Horizontal">
                                    <md:PackIcon Kind="ShieldLock" Width="14" Height="14"
                                                 VerticalAlignment="Center" Margin="0,0,6,0"/>
                                    <TextBlock Text="{loc:Loc Key=Hist_ManageInAv}" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- Etat : session propre -->
                    <StackPanel x:Name="noThreatsState" Grid.Row="1"
                                Visibility="Collapsed"
                                VerticalAlignment="Center" HorizontalAlignment="Center">
                        <md:PackIcon Kind="ShieldCheck" Width="36" Height="36"
                                     Foreground="{DynamicResource SuccessGreen}"
                                     HorizontalAlignment="Center"/>
                        <TextBlock Text="{loc:Loc Key=Hist_NoThreatsInSession}"
                                   FontSize="{DynamicResource FontSize.Body}"
                                   Foreground="{DynamicResource TextMuted}"
                                   HorizontalAlignment="Center" Margin="0,8,0,0"/>
                    </StackPanel>

                    <!-- Message session sans détail des chemins -->
                    <TextBlock x:Name="txtHistThreatsLegacy" Grid.Row="2"
                               Visibility="Collapsed"
                               Text="{loc:Loc Key=Hist_ThreatsLegacy}"
                               FontSize="{DynamicResource FontSize.Small}"
                               Foreground="{DynamicResource TextMuted}"
                               TextWrapping="Wrap" Margin="0,6,0,0"/>
                </Grid>
            </Grid>
        </Border>
    </DockPanel>
</UserControl>
