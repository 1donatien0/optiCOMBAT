<UserControl x:Class="optiCombat.Views.OptionsControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:md="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:loc="clr-namespace:optiCombat.Localization">

    <DockPanel Background="Transparent">
        <Rectangle DockPanel.Dock="Top" Height="2" Margin="48,0,48,0" Opacity="0.55"
                   Fill="{DynamicResource AccentLineGradient}"/>
        <Border DockPanel.Dock="Top" Style="{StaticResource PageHeaderBandDense}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                    <TextBlock Text="{loc:Loc Key=Opt_Title}"
                               FontSize="{DynamicResource FontSize.Hero}" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextDark}"/>
                    <TextBlock Text="{loc:Loc Key=Opt_Sub}"
                               FontSize="{DynamicResource FontSize.Small}" Foreground="{DynamicResource TextMuted}"
                               Margin="0,4,0,0"/>
                </StackPanel>

                <Border Grid.Column="1" Style="{StaticResource PageHeaderIcon}">
                    <md:PackIcon Kind="Cog" Width="26" Height="26"
                                 Foreground="{DynamicResource TextAccent}"
                                 HorizontalAlignment="Center"
                                 VerticalAlignment="Center"/>
                </Border>
            </Grid>
        </Border>

        <!-- ══ CONTENU DÉFILABLE ════════════════════════════════════════════ -->
        <ScrollViewer VerticalScrollBarVisibility="Auto" Focusable="False">
            <StackPanel Margin="24,20,24,24">

                <!-- ── GÉNÉRAL ────────────────────────────────────────────────── -->
                <Border Style="{StaticResource GlassCard}"
                        Padding="24,20"
                        Margin="0,0,0,14">
                    <StackPanel>

                        <TextBlock Text="{loc:Loc Key=Opt_General}"
                                   FontSize="{DynamicResource FontSize.Small}" FontWeight="Bold"
                                   Foreground="{DynamicResource AlertGoldLight}"
                                   Margin="0,0,0,16"/>

                        <!-- Démarrage Windows -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                            <CheckBox x:Name="chkAutoStart"
                                      VerticalAlignment="Top"
                                      Margin="0,2,16,0"
                                      Checked="CheckOption_Changed"
                                      Unchecked="CheckOption_Changed"
                                      Tag="AutoStart"/>
                            <StackPanel>
                                <TextBlock Text="{loc:Loc Key=Opt_Startup}"
                                           FontSize="{DynamicResource FontSize.Title}" FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextDark}"/>
                                <TextBlock Text="{loc:Loc Key=Opt_StartupSub}"
                                           FontSize="{DynamicResource FontSize.Small}" Foreground="{DynamicResource TextMuted}"
                                           Margin="0,3,0,0"/>
                            </StackPanel>
                        </StackPanel>

                        <!-- Notifications -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                            <CheckBox x:Name="chkNotifications"
                                      IsChecked="True"
                                      VerticalAlignment="Top"
                                      Margin="0,2,16,0"
                                      Checked="CheckOption_Changed"
                                      Unchecked="CheckOption_Changed"
                                      Tag="Notifications"/>
                            <StackPanel>
                                <TextBlock Text="{loc:Loc Key=Opt_Notifications}"
                                           FontSize="{DynamicResource FontSize.Title}" FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextDark}"/>
                                <TextBlock Text="{loc:Loc Key=Opt_NotifSub}"
                                           FontSize="{DynamicResource FontSize.Small}" Foreground="{DynamicResource TextMuted}"
                                           Margin="0,3,0,0"/>
                            </StackPanel>
                        </StackPanel>

                        <!-- Thème opposé au mode Windows (libellé dynamique : clair si Windows sombre, etc.) -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                            <CheckBox x:Name="chkAlternateTheme"
                                      VerticalAlignment="Top"
                                      Margin="0,2,16,0"
                                      Checked="CheckOption_Changed"
                                      Unchecked="CheckOption_Changed"
                                      Tag="AlternateTheme"/>
                            <StackPanel>
                                <TextBlock x:Name="txtAlternateThemeTitle"
                                           FontSize="{DynamicResource FontSize.Title}" FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextDark}"/>
                                <TextBlock x:Name="txtAlternateThemeSub"
                                           FontSize="{DynamicResource FontSize.Small}" Foreground="{DynamicResource TextMuted}"
                                           Margin="0,3,0,0" TextWrapping="Wrap"/>
                            </StackPanel>
                        </StackPanel>

                        <!-- Langue de l'interface -->
                        <StackPanel Margin="0,0,0,20">
                            <TextBlock Text="{loc:Loc Key=Opt_Language}"
                                       FontSize="{DynamicResource FontSize.Title}" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextDark}"
                                       Margin="0,0,0,6"/>
                            <ComboBox x:Name="cmbUiLanguage"
                                      Style="{StaticResource DonabyComboBox}"
                                      DropDownOpened="ComboBox_DropDownOpened"
                                      DropDownClosed="CmbUiLanguage_DropDownClosed"
                                      PreviewMouseLeftButtonDown="ComboBox_PreviewMouseLeftButtonDown"
                                      Height="36" Width="240" HorizontalAlignment="Left">
                                <ComboBoxItem Tag="fr-FR" Content="{loc:Loc Key=Opt_LangFrench}"/>
                                <ComboBoxItem Tag="en-US" Content="{loc:Loc Key=Opt_LangEnglish}"/>
                            </ComboBox>
                            <TextBlock Text="{loc:Loc Key=Opt_LanguageSub}"
                                       FontSize="{DynamicResource FontSize.Small}" Foreground="{DynamicResource TextMuted}"
                                       Margin="0,4,0,0"/>
                        </StackPanel>

                        <!-- Type de scan favori -->
                        <StackPanel Margin="0,0,0,4">
                            <TextBlock Text="{loc:Loc Key=Opt_FavScan}"
                                       FontSize="{DynamicResource FontSize.Title}" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextDark}"
                                       Margin="0,0,0,6"/>
                            <ComboBox x:Name="cmbFavoriteScan"
                                      Style="{StaticResource DonabyComboBox}"
                                      DisplayMemberPath="Content"
                                      DropDownOpened="ComboBox_DropDownOpened"
                                      DropDownClosed="CmbFavoriteScan_DropDownClosed"
                                      PreviewMouseLeftButtonDown="ComboBox_PreviewMouseLeftButtonDown"
                                      Height="36" Width="240" HorizontalAlignment="Left">
                                <ComboBoxItem Content="{loc:Loc Key=Opt_FavQuick}"/>
                                <ComboBoxItem Content="{loc:Loc Key=Opt_FavFull}"/>
                                <ComboBoxItem Content="{loc:Loc Key=Opt_FavFolder}"/>
                                <ComboBoxItem Content="{loc:Loc Key=Opt_FavFile}"/>
                            </ComboBox>
                            <TextBlock Text="{loc:Loc Key=Opt_FavHint}"
                                       FontSize="{DynamicResource FontSize.Small}" Foreground="{DynamicResource TextMuted}"
                                       Margin="0,4,0,0"/>
                        </StackPanel>

                    </StackPanel>
                </Border>

                <!-- ── ANTIVIRUS ─────────────────────────────────────────────── -->
                <Border Style="{StaticResource GlassCard}"
                        Padding="24,20"
                        Margin="0,0,0,14">
                    <StackPanel>

                        <TextBlock Text="{loc:Loc Key=Opt_Antivirus}"
                                   FontSize="{DynamicResource FontSize.Small}" FontWeight="Bold"
                                   Foreground="{DynamicResource AlertGoldLight}"
                                   Margin="0,0,0,16"/>

                        <!-- Protection temps réel -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                            <CheckBox x:Name="chkRealtimeProtection"
                                      IsChecked="True"
                                      VerticalAlignment="Top"
                                      Margin="0,2,16,0"
                                      Checked="CheckOption_Changed"
                                      Unchecked="CheckOption_Changed"
                                      Tag="RealtimeProtection"/>
                            <StackPanel>
                                <TextBlock Text="{loc:Loc Key=Opt_Rtp}"
                                           FontSize="{DynamicResource FontSize.Title}" FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextDark}"/>
                                <TextBlock Text="{loc:Loc Key=Opt_RtpSub}"
                                           FontSize="{DynamicResource FontSize.Small}" Foreground="{DynamicResource TextMuted}"
                                           Margin="0,3,0,0"/>
                            </StackPanel>
                        </StackPanel>

                        <!-- Surveillance processus -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                            <CheckBox x:Name="chkProcessMonitor"
                                      IsChecked="True"
                                      VerticalAlignment="Top"
                                      Margin="0,2,16,0"
                                      Checked="CheckOption_Changed"
                                      Unchecked="CheckOption_Changed"
                                      Tag="ProcessMonitor"/>
                            <StackPanel>
                                <TextBlock Text="{loc:Loc Key=Opt_ProcessMonitor}"
                                           FontSize="{DynamicResource FontSize.Title}" FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextDark}"/>
                                <TextBlock Text="{loc:Loc Key=Opt_ProcessMonitorSub}"
                                           FontSize="{DynamicResource FontSize.Small}" Foreground="{DynamicResource TextMuted}"
                                           Margin="0,3,0,0" TextWrapping="Wrap"/>
                            </StackPanel>
                        </StackPanel>

                        <!-- Anti-manipulation -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                            <CheckBox x:Name="chkTamperProtection"
                                      IsChecked="True"
                                      VerticalAlignment="Top"
                                      Margin="0,2,16,0"
                                      Checked="CheckOption_Changed"
                                      Unchecked="CheckOption_Changed"
                                      Tag="TamperProtection"/>
                            <StackPanel>
                                <TextBlock Text="{loc:Loc Key=Opt_TamperProtection}"
                                           FontSize="{DynamicResource FontSize.Title}" FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextDark}"/>
                                <TextBlock Text="{loc:Loc Key=Opt_TamperProtectionSub}"
                                           FontSize="{DynamicResource FontSize.Small}" Foreground="{DynamicResource TextMuted}"
                                           Margin="0,3,0,0" TextWrapping="Wrap"/>
                            </StackPanel>
                        </StackPanel>

                        <!-- Service Windows / protection système avancée (dormant — prévu 3-5 ans) -->
                        <StackPanel x:Name="pnlPlatformProtection" Orientation="Vertical" Margin="0,0,0,20" Opacity="0.55">
                            <StackPanel Orientation="Horizontal">
                            <CheckBox x:Name="chkPlatformProtection"
                                      IsChecked="False"
                                      IsEnabled="False"
                                      VerticalAlignment="Top"
                                      Margin="0,2,16,0"
                                      Checked="CheckOption_Changed"
                                      Unchecked="CheckOption_Changed"
                                      Tag="PlatformProtection"/>
                            <StackPanel>
                                <TextBlock Text="{loc:Loc Key=Opt_PlatformProtection}"
                                           FontSize="{DynamicResource FontSize.Title}" FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextDark}"/>
                                <TextBlock Text="{loc:Loc Key=Opt_PlatformProtectionSub}"
                                           FontSize="{DynamicResource FontSize.Small}" Foreground="{DynamicResource TextMuted}"
                                           Margin="0,3,0,0" TextWrapping="Wrap"/>
                            </StackPanel>
                            </StackPanel>
                            <TextBlock x:Name="txtPlatformProtectionPlanned"
                                       Text="{loc:Loc Key=Opt_PlatformProtectionPlanned}"
                                       FontSize="{DynamicResource FontSize.Small}"
                                       FontStyle="Italic"
                                       Foreground="{DynamicResource TextMuted}"
                                       Margin="32,6,0,0"
                                       TextWrapping="Wrap"/>
                        </StackPanel>

                        <!-- Scan lecteurs amovibles -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                            <CheckBox x:Name="chkRemovableDriveScan"
                                      IsChecked="True"
                                      VerticalAlignment="Top"
                                      Margin="0,2,16,0"
                                      Checked="CheckOption_Changed"
                                      Unchecked="CheckOption_Changed"
                                      Tag="RemovableDriveScan"/>
                            <StackPanel>
                                <TextBlock Text="{loc:Loc Key=Opt_RemovableScan}"
                                           FontSize="{DynamicResource FontSize.Title}" FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextDark}"/>
                                <TextBlock Text="{loc:Loc Key=Opt_RemovableScanSub}"
                                           FontSize="{DynamicResource FontSize.Small}" Foreground="{DynamicResource TextMuted}"
                                           Margin="0,3,0,0" TextWrapping="Wrap"/>
                            </StackPanel>
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" Margin="32,0,0,12">
                            <CheckBox x:Name="chkRemovableDriveDetailed"
                                      VerticalAlignment="Top"
                                      Margin="0,2,16,0"
                                      Checked="CheckOption_Changed"
                                      Unchecked="CheckOption_Changed"
                                      Tag="RemovableDriveDetailed"/>
                            <StackPanel>
                                <TextBlock Text="{loc:Loc Key=Opt_RemovableDetailed}"
                                           FontSize="{DynamicResource FontSize.Title}" FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextDark}"/>
                                <TextBlock Text="{loc:Loc Key=Opt_RemovableDetailedSub}"
                                           FontSize="{DynamicResource FontSize.Small}" Foreground="{DynamicResource TextMuted}"
                                           Margin="0,3,0,0" TextWrapping="Wrap"/>
                            </StackPanel>
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" Margin="32,0,0,20">
                            <CheckBox x:Name="chkIncludeRemovableFullScan"
                                      VerticalAlignment="Top"
                                      Margin="0,2,16,0"
                                      Checked="CheckOption_Changed"
                                      Unchecked="CheckOption_Changed"
                                      Tag="IncludeRemovableFullScan"/>
                            <StackPanel>
                                <TextBlock Text="{loc:Loc Key=Opt_IncludeRemovableFull}"
                                           FontSize="{DynamicResource FontSize.Title}" FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextDark}"/>
                                <TextBlock Text="{loc:Loc Key=Opt_IncludeRemovableFullSub}"
                                           FontSize="{DynamicResource FontSize.Small}" Foreground="{DynamicResource TextMuted}"
                                           Margin="0,3,0,0" TextWrapping="Wrap"/>
                            </StackPanel>
                        </StackPanel>

                        <!-- Quarantaine automatique -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                            <CheckBox x:Name="chkAutoQuarantine"
                                      IsChecked="False"
                                      VerticalAlignment="Top"
                                      Margin="0,2,16,0"
                                      Checked="CheckOption_Changed"
                                      Unchecked="CheckOption_Changed"
                                      Tag="AutoQuarantine"/>
                            <StackPanel>
                                <TextBlock Text="{loc:Loc Key=Opt_AutoQuarantine}"
                                           FontSize="{DynamicResource FontSize.Title}" FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextDark}"/>
                                <TextBlock Text="{loc:Loc Key=Opt_AutoQuarSub}"
                                           FontSize="{DynamicResource FontSize.Small}" Foreground="{DynamicResource TextMuted}"
                                           Margin="0,3,0,0" TextWrapping="Wrap"/>
                            </StackPanel>
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" Margin="32,0,0,20">
                            <CheckBox x:Name="chkBackupBeforeQuarantine"
                                      VerticalAlignment="Top"
                                      Margin="0,2,16,0"
                                      Checked="CheckOption_Changed"
                                      Unchecked="CheckOption_Changed"
                                      Tag="BackupBeforeQuarantine"/>
                            <StackPanel>
                                <TextBlock Text="{loc:Loc Key=Opt_BackupBeforeQuarantine}"
                                           FontSize="{DynamicResource FontSize.Title}" FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextDark}"/>
                                <TextBlock Text="{loc:Loc Key=Opt_BackupBeforeQuarantineSub}"
                                           FontSize="{DynamicResource FontSize.Small}" Foreground="{DynamicResource TextMuted}"
                                           Margin="0,3,0,0" TextWrapping="Wrap"/>
                            </StackPanel>
                        </StackPanel>

                        <!-- Moteur clamd -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                            <CheckBox x:Name="chkUseClamd"
                                      IsChecked="True"
                                      VerticalAlignment="Top"
                                      Margin="0,2,16,0"
                                      Checked="CheckOption_Changed"
                                      Unchecked="CheckOption_Changed"
                                      Tag="UseClamd"/>
                            <StackPanel>
                                <TextBlock Text="{loc:Loc Key=Opt_UseClamd}"
                                           FontSize="{DynamicResource FontSize.Title}" FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextDark}"/>
                                <TextBlock Text="{loc:Loc Key=Opt_UseClamdSub}"
                                           FontSize="{DynamicResource FontSize.Small}" Foreground="{DynamicResource TextMuted}"
                                           Margin="0,3,0,0" TextWrapping="Wrap"/>
                            </StackPanel>
                        </StackPanel>

                        <!-- Mode jeu -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                            <CheckBox x:Name="chkGameMode"
                                      IsChecked="True"
                                      VerticalAlignment="Top"
                                      Margin="0,2,16,0"
                                      Checked="CheckOption_Changed"
                                      Unchecked="CheckOption_Changed"
                                      Tag="GameMode"/>
                            <StackPanel>
                                <TextBlock Text="{loc:Loc Key=Opt_GameMode}"
                                           FontSize="{DynamicResource FontSize.Title}" FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextDark}"/>
                                <TextBlock Text="{loc:Loc Key=Opt_GameModeSub}"
                                           FontSize="{DynamicResource FontSize.Small}" Foreground="{DynamicResource TextMuted}"
                                           Margin="0,3,0,0" TextWrapping="Wrap"/>
                            </StackPanel>
                        </StackPanel>

                        <!-- VirusTotal -->
                        <StackPanel Margin="0,0,0,20">
                            <TextBlock Text="{loc:Loc Key=Opt_VirusTotal}"
                                       FontSize="{DynamicResource FontSize.Title}" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextDark}"/>
                            <PasswordBox x:Name="pwdVirusTotalApiKey"
                                         Margin="0,6,0,0" Height="32" MaxWidth="360" HorizontalAlignment="Left"
                                         PasswordChanged="PwdVirusTotalApiKey_Changed"/>
                            <TextBlock Text="{loc:Loc Key=Opt_VirusTotalSub}"
                                       FontSize="{DynamicResource FontSize.Small}" Foreground="{DynamicResource TextMuted}"
                                       Margin="0,4,0,0" TextWrapping="Wrap"/>
                        </StackPanel>

                        <!-- Mise à jour auto -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                            <CheckBox x:Name="chkAutoUpdate"
                                      IsChecked="True"
                                      VerticalAlignment="Top"
                                      Margin="0,2,16,0"
                                      Checked="CheckOption_Changed"
                                      Unchecked="CheckOption_Changed"
                                      Tag="AutoUpdate"/>
                            <StackPanel>
                                <TextBlock Text="{loc:Loc Key=Opt_AutoSig}"
                                           FontSize="{DynamicResource FontSize.Title}" FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextDark}"/>
                                <TextBlock Text="{loc:Loc Key=Opt_AutoSigSub}"
                                           FontSize="{DynamicResource FontSize.Small}" Foreground="{DynamicResource TextMuted}"
                                           Margin="0,3,0,0"/>
                            </StackPanel>
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" Margin="32,0,0,0">
                            <CheckBox x:Name="chkAggressiveSignatures"
                                      VerticalAlignment="Top"
                                      Margin="0,2,16,0"
                                      Checked="CheckOption_Changed"
                                      Unchecked="CheckOption_Changed"
                                      Tag="AggressiveSignatures"/>
                            <StackPanel>
                                <TextBlock Text="{loc:Loc Key=Opt_AggressiveSignatures}"
                                           FontSize="{DynamicResource FontSize.Title}" FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextDark}"/>
                                <TextBlock Text="{loc:Loc Key=Opt_AggressiveSignaturesSub}"
                                           FontSize="{DynamicResource FontSize.Small}" Foreground="{DynamicResource TextMuted}"
                                           Margin="0,3,0,0" TextWrapping="Wrap"/>
                            </StackPanel>
                        </StackPanel>

                        <!-- Seuils de recommandations -->
                        <StackPanel Margin="0,16,0,0">
                            <TextBlock Text="{loc:Loc Key=Opt_RecThresholds}"
                                       FontSize="{DynamicResource FontSize.Title}" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextDark}"/>
                            <TextBlock Text="{loc:Loc Key=Opt_RecThresholdsSub}"
                                       FontSize="{DynamicResource FontSize.Small}" Foreground="{DynamicResource TextMuted}"
                                       Margin="0,3,0,8"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <!-- Seuil nettoyage -->
                                <StackPanel Grid.Column="0" Margin="0,0,8,0">
                                    <TextBlock Text="{loc:Loc Key=Opt_CleanThreshold}"
                                               FontSize="{DynamicResource FontSize.Body}"
                                               Foreground="{DynamicResource TextDark}" Margin="0,0,0,4"/>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBox x:Name="txtCleanThreshold"
                                                 Width="60" TextAlignment="Center"
                                                 Text="14"
                                                 PreviewTextInput="NumericOnly_PreviewTextInput"
                                                 LostFocus="ThresholdBox_LostFocus"
                                                 Tag="CleanThreshold"/>
                                        <TextBlock Text="{loc:Loc Key=Opt_Days}"
                                                   FontSize="{DynamicResource FontSize.Small}"
                                                   Foreground="{DynamicResource TextMuted}"
                                                   VerticalAlignment="Center" Margin="6,0,0,0"/>
                                    </StackPanel>
                                </StackPanel>
                                <!-- Seuil signatures -->
                                <StackPanel Grid.Column="1">
                                    <TextBlock Text="{loc:Loc Key=Opt_SigThreshold}"
                                               FontSize="{DynamicResource FontSize.Body}"
                                               Foreground="{DynamicResource TextDark}" Margin="0,0,0,4"/>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBox x:Name="txtSigThreshold"
                                                 Width="60" TextAlignment="Center"
                                                 Text="7"
                                                 PreviewTextInput="NumericOnly_PreviewTextInput"
                                                 LostFocus="ThresholdBox_LostFocus"
                                                 Tag="SigThreshold"/>
                                        <TextBlock Text="{loc:Loc Key=Opt_Days}"
                                                   FontSize="{DynamicResource FontSize.Small}"
                                                   Foreground="{DynamicResource TextMuted}"
                                                   VerticalAlignment="Center" Margin="6,0,0,0"/>
                                    </StackPanel>
                                </StackPanel>
                            </Grid>
                        </StackPanel>

                        <!-- Scan planifié (schtasks) -->
                        <StackPanel Margin="0,16,0,0">
                            <StackPanel Orientation="Horizontal">
                                <CheckBox x:Name="chkScheduledScan"
                                          VerticalAlignment="Top"
                                          Margin="0,2,16,0"
                                          Checked="CheckOption_Changed"
                                          Unchecked="CheckOption_Changed"
                                          Tag="ScheduledScan"/>
                                <StackPanel>
                                    <TextBlock Text="{loc:Loc Key=Opt_Scheduled}"
                                               FontSize="{DynamicResource FontSize.Title}" FontWeight="SemiBold"
                                               Foreground="{DynamicResource TextDark}"/>
                                    <TextBlock Text="{loc:Loc Key=Opt_ScheduledSub}"
                                               FontSize="{DynamicResource FontSize.Small}" Foreground="{DynamicResource TextMuted}"
                                               Margin="0,3,0,0" TextWrapping="Wrap"/>
                                    <TextBlock Text="{loc:Loc Key=Opt_SchedUacHint}"
                                               FontSize="{DynamicResource FontSize.Small}" Foreground="{DynamicResource WarningOrange}"
                                               Margin="0,6,0,0" TextWrapping="Wrap"/>
                                </StackPanel>
                            </StackPanel>
                            <StackPanel x:Name="pnlScheduleTime" Orientation="Horizontal" Margin="32,10,0,6">
                                <TextBlock Text="{loc:Loc Key=Opt_ScheduleTime}" VerticalAlignment="Center" Margin="0,0,8,0"
                                           Foreground="{DynamicResource TextSecondary}" FontSize="{DynamicResource FontSize.Body}"/>
                                <ComboBox x:Name="cmbScheduleHour"
                                          Style="{StaticResource DonabyComboBox}"
                                          PreviewMouseLeftButtonDown="ComboBox_PreviewMouseLeftButtonDown"
                                          Width="56" Height="32" Margin="0,0,6,0"/>
                                <TextBlock Text=":" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                <ComboBox x:Name="cmbScheduleMinute"
                                          Style="{StaticResource DonabyComboBox}"
                                          PreviewMouseLeftButtonDown="ComboBox_PreviewMouseLeftButtonDown"
                                          Width="56" Height="32"/>
                            </StackPanel>
                            <TextBlock x:Name="txtScheduledNextRun"
                                       FontSize="{DynamicResource FontSize.Small}" Foreground="{DynamicResource TextMuted}"
                                       Margin="32,4,0,8" TextWrapping="Wrap"/>
                            <Button x:Name="btnScheduledRunNow"
                                    Content="{loc:Loc Key=Opt_RunNow}"
                                    Click="BtnScheduledRunNow_Click"
                                    Style="{StaticResource SecondaryButton}"
                                    Height="32" Padding="12,4" Margin="32,0,0,0" HorizontalAlignment="Left"/>
                        </StackPanel>

                    </StackPanel>
                </Border>

                <!-- ── APPLICATION (mises à jour binaire) ───────────────────── -->
                <Border Style="{StaticResource GlassCard}"
                        Padding="24,20"
                        Margin="0,0,0,14">
                    <StackPanel>
                        <TextBlock Text="{loc:Loc Key=Opt_App}"
                                   FontSize="{DynamicResource FontSize.Small}" FontWeight="Bold"
                                   Foreground="{DynamicResource AlertGoldLight}"
                                   Margin="0,0,0,12"/>
                        <TextBlock TextWrapping="Wrap" FontSize="{DynamicResource FontSize.Body}" Foreground="{DynamicResource TextMuted}"
                                   Margin="0,0,0,12"
                                   Text="{loc:Loc Key=Opt_UpdateHint}"/>
                        <StackPanel Orientation="Horizontal">
                            <Button Content="{loc:Loc Key=Opt_AboutUpdates}"
                                    Click="BtnCheckAppUpdate_Click"
                                    Style="{StaticResource SecondaryButton}"
                                    Height="34" Padding="14,6" Margin="0,0,10,0"/>
                            <Button Content="{loc:Loc Key=Opt_SourceForge}"
                                    Click="BtnOpenSourceForge_Click"
                                    Style="{StaticResource SecondaryButton}"
                                    Height="34" Padding="14,6"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- ── EXCLUSIONS ────────────────────────────────────────────── -->
                <Border Style="{StaticResource GlassCard}"
                        Padding="24,20">
                    <StackPanel>

                        <TextBlock Text="{loc:Loc Key=Opt_Exclusions}"
                                   FontSize="{DynamicResource FontSize.Small}" FontWeight="Bold"
                                   Foreground="{DynamicResource AlertGoldLight}"
                                   Margin="0,0,0,16"/>

                        <TextBlock Text="{loc:Loc Key=Opt_ExclHint}"
                                   FontSize="{DynamicResource FontSize.Title}" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextDark}"
                                   Margin="0,0,0,10"/>

                        <!-- Zone d'ajout -->
                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="10"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0"
                                    BorderBrush="{DynamicResource BorderColor}"
                                    BorderThickness="1" CornerRadius="6">
                                <TextBox x:Name="txtNewExclusion"
                                         Background="Transparent"
                                         BorderThickness="0"
                                         Foreground="{DynamicResource TextMedium}"
                                         FontSize="{DynamicResource FontSize.Body}" Padding="10,8"
                                         md:HintAssist.Hint="C:\Chemin\vers\dossier..."
                                         md:HintAssist.Foreground="{DynamicResource TextMuted}"
                                         VerticalAlignment="Center"/>
                            </Border>
                            <Border Grid.Column="2">
                                <StackPanel Orientation="Horizontal">
                                    <Button Content="{loc:Loc Key=Opt_Add}"
                                            Click="BtnAddTypedExclusion_Click"
                                            Style="{StaticResource SecondaryButton}"
                                            Height="34" Padding="12,6" Margin="0,0,8,0"/>
                                    <Button Content="{loc:Loc Key=Opt_Browse}"
                                            Click="BtnAddExclusion_Click"
                                            Style="{StaticResource SecondaryButton}"
                                            Height="34" Padding="14,6"/>
                                </StackPanel>
                            </Border>
                        </Grid>

                        <!-- Liste des exclusions -->
                        <ItemsControl x:Name="lstExclusions" Margin="0,4,0,0">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="{DynamicResource SurfaceBg}"
                                            CornerRadius="6" Margin="0,3"
                                            Padding="12,8">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <md:PackIcon Grid.Column="0"
                                                         Kind="FolderOutline" Width="16" Height="16"
                                                         Foreground="{DynamicResource TextMuted}"
                                                         VerticalAlignment="Center" Margin="0,0,8,0"/>
                                            <TextBlock Grid.Column="1"
                                                       Text="{Binding}"
                                                       FontSize="{DynamicResource FontSize.Body}"
                                                       Foreground="{DynamicResource TextMedium}"
                                                       VerticalAlignment="Center"
                                                       TextTrimming="CharacterEllipsis"/>
                                            <Button Grid.Column="2"
                                                    Tag="{Binding}"
                                                    Click="BtnRemoveExclusion_Click"
                                                    Style="{StaticResource DangerIconButton}"
                                                    ToolTip="{loc:Loc Key=Opt_RemoveExclusion}"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <TextBlock Text="{loc:Loc Key=Opt_ExclNote}"
                                   FontSize="{DynamicResource FontSize.Small}" Foreground="{DynamicResource TextMuted}"
                                   Margin="0,10,0,0" FontStyle="Italic"/>

                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>

    </DockPanel>
</UserControl>
