<UserControl x:Class="optiCombat.Views.AntivirusView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:md="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:c="clr-namespace:optiCombat.Converters"
             xmlns:loc="clr-namespace:optiCombat.Localization"
             xmlns:services="clr-namespace:optiCombat.Services"
             mc:Ignorable="d"
             d:DesignHeight="650" d:DesignWidth="960">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <c:InverseBooleanToVisibilityConverter x:Key="InverseBoolToVis"/>
        <c:PositiveIntToVisibilityConverter x:Key="PosIntVis"/>
        <c:ThreatRiskSeverityConverter x:Key="ThreatRiskSeverity"/>
        <c:ThreatRiskLevelConverter x:Key="ThreatRiskLevel"/>
        <c:ThreatRiskColorConverter x:Key="ThreatRiskColor"/>
        <c:ThreatRiskIconConverter x:Key="ThreatRiskIcon"/>
    </UserControl.Resources>

    <DockPanel>
        <!-- Ligne accent sous le header -->
        <Rectangle DockPanel.Dock="Top" Height="2" Margin="32,0,32,0" Opacity="0.55"
                   Fill="{DynamicResource AccentLineGradient}"/>
        <!-- ══ En-tête (thème clair / sombre) ═══════════════════════════════ -->
        <Border DockPanel.Dock="Top" Style="{StaticResource PageHeaderBandDense}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal">
                        <md:PackIcon Kind="ShieldCheck" Width="20" Height="20"
                                     Foreground="{DynamicResource AlertGoldLight}"
                                     VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <TextBlock Text="{loc:Loc Key=Av_Title}" FontSize="{DynamicResource FontSize.Hero}" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextDark}"/>
                    </StackPanel>
                    <TextBlock x:Name="antivirusHeroLastScan"
                               Margin="28,3,0,0"
                               Text="{loc:Loc Key=Av_NoScanYet}"
                               FontSize="{DynamicResource FontSize.Small}" Foreground="{DynamicResource TextMuted}"/>
                </StackPanel>

                <!-- Badge : ClamAV + YARA + protection temps réel (ProtectionBadgeLevel) -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Width="7" Height="7" CornerRadius="4"
                            Margin="0,0,6,0" VerticalAlignment="Center">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Background" Value="{DynamicResource DangerRed}"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding ProtectionBadgeLevel}"
                                                 Value="{x:Static services:ProtectionBadgeLevel.Degraded}">
                                        <Setter Property="Background" Value="{DynamicResource AlertGold}"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding ProtectionBadgeLevel}"
                                                 Value="{x:Static services:ProtectionBadgeLevel.Active}">
                                        <Setter Property="Background" Value="{DynamicResource SuccessGreen}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                    </Border>
                    <TextBlock Text="{Binding ProtectionBadgeText}"
                               Foreground="{DynamicResource TextMedium}"
                               FontSize="{DynamicResource FontSize.Small}" VerticalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ══ CONTENU PRINCIPAL ═══════════════════════════════════════════ -->
        <Grid Background="Transparent">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- ── Overlay d'initialisation ─────────────────────────────────
                 Visible tant que IsInitializing = true. Évite d'afficher des
                 champs "Vérification…" vides si un service met du temps à
                 démarrer ou échoue. Disparaît automatiquement dès que
                 InitializeAsync() termine (succès ou erreur partielle). -->
            <Grid Grid.RowSpan="2"
                  Background="Transparent"
                  Visibility="{Binding IsInitializing, Converter={StaticResource BoolToVis}}"
                  Panel.ZIndex="10">
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                    <ProgressBar IsIndeterminate="True" Width="180" Height="3"
                                 Margin="0,0,0,14"/>
                    <TextBlock Text="{loc:Loc Key=Av_Init}"
                               FontSize="{DynamicResource FontSize.Title}" Foreground="{DynamicResource TextMuted}"
                               HorizontalAlignment="Center"/>
                    <!-- Message d'erreur : visible dès que InitializationError est non vide -->
                    <TextBlock Text="{Binding InitializationError}"
                               FontSize="{DynamicResource FontSize.Body}" Foreground="{DynamicResource DangerRed}"
                               HorizontalAlignment="Center" TextWrapping="Wrap"
                               MaxWidth="420" Margin="0,8,0,0">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Visible"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding InitializationError}" Value="">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </StackPanel>
            </Grid>

            <!-- Hub d'actions (masqué pendant un scan) -->
            <Border Grid.Row="0" Margin="12,8,12,4"
                    Visibility="{Binding IsScanning, Converter={StaticResource InverseBoolToVis}}"
                    Style="{StaticResource ContentPanelCard}"
                    Padding="10">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Button x:Name="btnQuickScan" Grid.Column="0"
                            Style="{StaticResource HubCardButtonStyle}"
                            Command="{Binding QuickScanCommand}" Margin="0,0,6,0"
                            ToolTip="{loc:Loc Key=Av_Tooltip_QuickScan}"
                            AutomationProperties.Name="{loc:Loc Key=Av_Tooltip_QuickScan}">
                        <StackPanel HorizontalAlignment="Center">
                            <Border Width="40" Height="40" CornerRadius="20" Background="{DynamicResource AccentBg}">
                                <md:PackIcon Kind="Flash" Width="22" Height="22"
                                             Foreground="{DynamicResource AccentBlue}"
                                             HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock Text="{loc:Loc Key=Av_Quick}" Margin="0,6,0,0" FontWeight="SemiBold" FontSize="{DynamicResource FontSize.Body}"
                                       Foreground="{DynamicResource TextDark}" HorizontalAlignment="Center"/>
                            <TextBlock Text="F5" FontSize="{DynamicResource FontSize.Micro}" Foreground="{DynamicResource TextMuted}"
                                       HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button x:Name="btnFullScan" Grid.Column="1"
                            Style="{StaticResource HubCardButtonStyle}"
                            Command="{Binding FullScanCommand}" Margin="3,0,3,0"
                            AutomationProperties.Name="{loc:Loc Key=Av_Full}">
                        <StackPanel HorizontalAlignment="Center">
                            <Border Width="40" Height="40" CornerRadius="20" Background="{DynamicResource SuccessBg}">
                                <md:PackIcon Kind="Magnify" Width="22" Height="22"
                                             Foreground="{DynamicResource SuccessGreen}"
                                             HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock Text="{loc:Loc Key=Av_Full}" Margin="0,6,0,0" FontWeight="SemiBold" FontSize="{DynamicResource FontSize.Body}"
                                       Foreground="{DynamicResource TextDark}" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Border Grid.Column="2" Margin="6,0,0,0"
                            Style="{StaticResource MetricCard}"
                            Padding="10,8" MinHeight="88">
                        <Grid VerticalAlignment="Center">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" Width="40" Height="40" CornerRadius="20"
                                    Background="{DynamicResource AlertBg}" Margin="0,0,10,0">
                                <md:PackIcon Kind="FolderSearch" Width="22" Height="22"
                                             Foreground="{DynamicResource AlertGold}"
                                             HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <TextBlock Text="{loc:Loc Key=Av_Targeted}" FontWeight="SemiBold" FontSize="{DynamicResource FontSize.Body}"
                                           Foreground="{DynamicResource TextDark}" Margin="0,0,0,6"/>
                                <UniformGrid Columns="2">
                                    <Button x:Name="btnBrowseFolder"
                                            Style="{StaticResource AntivirusHubActionButtonStyle}"
                                            Click="BrowseFolder_Click" Margin="0,0,3,0"
                                            Padding="6,4" FontSize="{DynamicResource FontSize.Caption}">
                                        <TextBlock Text="{loc:Loc Key=Av_Folder}" HorizontalAlignment="Center"/>
                                    </Button>
                                    <Button x:Name="btnBrowseFile"
                                            Style="{StaticResource AntivirusHubActionButtonStyle}"
                                            Click="BrowseFile_Click" Margin="3,0,0,0"
                                            Padding="6,4" FontSize="{DynamicResource FontSize.Caption}">
                                        <TextBlock Text="{loc:Loc Key=Av_File}" HorizontalAlignment="Center"/>
                                    </Button>
                                </UniformGrid>
                            </StackPanel>
                        </Grid>
                    </Border>
                </Grid>
            </Border>

            <Grid Grid.Row="1" Margin="12,0,12,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="200"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

            <ScrollViewer Grid.Column="0"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled"
                          Margin="0,0,8,0">
                <Border Style="{StaticResource AvSideRailCard}">
                    <StackPanel>
                        <TextBlock Text="{loc:Loc Key=Av_Tools}" Style="{StaticResource SectionLabel}" Margin="0,0,0,8"/>

                        <TextBlock Text="{loc:Loc Key=Av_Recent}" Foreground="{DynamicResource TextMuted}"
                                   FontSize="{DynamicResource FontSize.Micro}" FontWeight="SemiBold" Margin="0,0,0,4"/>
                        <ListBox ItemsSource="{Binding RecentTargets}"
                                 MaxHeight="72" Margin="0,0,0,8"
                                 BorderBrush="{DynamicResource GlassCardRim}"
                                 BorderThickness="1"
                                 Background="{DynamicResource SurfaceBg}">
                            <ListBox.ItemContainerStyle>
                                <Style TargetType="ListBoxItem">
                                    <Setter Property="Padding" Value="0"/>
                                    <Setter Property="Margin" Value="0"/>
                                </Style>
                            </ListBox.ItemContainerStyle>
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Button Command="{Binding DataContext.ScanRecentCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}"
                                            HorizontalContentAlignment="Left"
                                            Padding="8,5" Margin="0"
                                            Background="Transparent" BorderThickness="0"
                                            Cursor="Hand" ToolTip="{Binding Path}">
                                        <StackPanel Orientation="Horizontal">
                                            <md:PackIcon Kind="History" Width="12" Height="12"
                                                         Foreground="{DynamicResource TextMuted}"
                                                         Margin="0,0,8,0" VerticalAlignment="Center"/>
                                            <TextBlock Text="{Binding ListLabel}" FontSize="{DynamicResource FontSize.Small}"
                                                       Foreground="{DynamicResource TextDark}"
                                                       TextTrimming="CharacterEllipsis"/>
                                        </StackPanel>
                                    </Button>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>

                        <Button x:Name="btnStopScan" Style="{StaticResource DangerButton}"
                                Command="{Binding StopScanCommand}" IsEnabled="{Binding CanStop}"
                                HorizontalAlignment="Stretch" Margin="0,0,0,14"
                                AutomationProperties.Name="{loc:Loc Key=Av_Stop}">
                            <StackPanel Orientation="Horizontal">
                                <md:PackIcon Kind="StopCircleOutline" Width="14" Height="14"
                                             Margin="0,0,6,0" VerticalAlignment="Center"/>
                                <TextBlock Text="{loc:Loc Key=Av_Stop}" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <Separator Margin="0,0,0,12" Background="{DynamicResource BorderSubtle}"/>

                        <TextBlock Text="{loc:Loc Key=Av_Stats}" Style="{StaticResource SectionLabel}" Margin="0,0,0,8"/>

                        <Border Background="{DynamicResource SurfaceBg}" CornerRadius="6"
                                Padding="8,5" Margin="0,0,0,4">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <md:PackIcon Kind="FileDocument" Width="14" Height="14"
                                                 Foreground="{DynamicResource PrimaryBlue}" Margin="0,0,8,0"/>
                                    <TextBlock Text="{loc:Loc Key=Av_Analyzed}" Foreground="{DynamicResource TextSecondary}" FontSize="{DynamicResource FontSize.Small}"/>
                                </StackPanel>
                                <TextBlock x:Name="antivirusFilesScanned" Grid.Column="1"
                                           Text="{Binding FilesScanned}"
                                           Foreground="{DynamicResource PrimaryBlue}"
                                           FontWeight="Bold" FontSize="{DynamicResource FontSize.Large}" VerticalAlignment="Center"/>
                            </Grid>
                        </Border>

                        <Border Background="{DynamicResource SurfaceBg}" CornerRadius="6"
                                Padding="8,5" Margin="0,0,0,4">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <md:PackIcon Kind="AlertCircle" Width="14" Height="14"
                                                 Foreground="{DynamicResource DangerRed}" Margin="0,0,8,0"/>
                                    <TextBlock Text="{loc:Loc Key=Av_Threats}" Foreground="{DynamicResource TextSecondary}" FontSize="{DynamicResource FontSize.Small}"/>
                                </StackPanel>
                                <TextBlock x:Name="antivirusThreatsFound" Grid.Column="1"
                                           Text="{Binding ThreatsFound}"
                                           Foreground="{DynamicResource DangerRed}"
                                           FontWeight="Bold" FontSize="{DynamicResource FontSize.Large}" VerticalAlignment="Center"/>
                            </Grid>
                        </Border>

                        <Border Background="{DynamicResource SurfaceBg}" CornerRadius="6"
                                Padding="8,5">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <md:PackIcon Kind="Lock" Width="14" Height="14"
                                                 Foreground="{DynamicResource WarningOrange}" Margin="0,0,8,0"/>
                                    <TextBlock Text="{loc:Loc Key=Av_Quarantine}" Foreground="{DynamicResource TextSecondary}" FontSize="{DynamicResource FontSize.Small}"/>
                                </StackPanel>
                                <TextBlock x:Name="antivirusQuarantineCount" Grid.Column="1"
                                           Text="{Binding QuarantineTotalCount, StringFormat=N0}"
                                           Foreground="{DynamicResource WarningOrange}"
                                           FontWeight="Bold" FontSize="{DynamicResource FontSize.Large}" VerticalAlignment="Center"/>
                            </Grid>
                        </Border>
                    </StackPanel>
                </Border>
            </ScrollViewer>

            <Border Grid.Column="1" Style="{StaticResource AvGlassTabShell}">
            <TabControl x:Name="antivirusMainTabs" Margin="0"
                        BorderThickness="0"
                        Background="Transparent">
                <TabControl.ItemContainerStyle>
                    <Style TargetType="TabItem" BasedOn="{StaticResource DonabyTabItem}"/>
                </TabControl.ItemContainerStyle>
                <TabItem>
                    <TabItem.Header>
                        <StackPanel Orientation="Horizontal">
                            <md:PackIcon Kind="Radar" Width="14" Height="14"
                                         Style="{StaticResource TabHeaderPackIcon}"
                                         Margin="0,0,6,0" VerticalAlignment="Center"/>
                            <TextBlock Text="{loc:Loc Key=Av_TabScan}" VerticalAlignment="Center"/>
                        </StackPanel>
                    </TabItem.Header>
                    <Border Padding="12,10" Background="{DynamicResource CardBg}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <!-- Bandeau « analyse en cours » -->
                            <Border Grid.Row="0" CornerRadius="10" Padding="14,12" Margin="0,0,0,10"
                                    BorderBrush="{DynamicResource AccentBlue}" BorderThickness="2"
                                    Background="{DynamicResource AccentBg}"
                                    Visibility="{Binding IsScanning, Converter={StaticResource BoolToVis}}">
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                        <md:PackIcon Kind="ShieldSearch" Width="22" Height="22"
                                                     Foreground="{DynamicResource AccentBlue}" Margin="0,0,10,0"
                                                     VerticalAlignment="Center"/>
                                        <StackPanel VerticalAlignment="Center">
                                            <TextBlock Text="{loc:Loc Key=Av_ScanInProgress}"
                                                       FontSize="{DynamicResource FontSize.Hero}" FontWeight="SemiBold"
                                                       Foreground="{DynamicResource TextDark}"/>
                                            <TextBlock Text="{loc:Loc Key=Av_ScanHint}"
                                                       FontSize="{DynamicResource FontSize.Small}" Foreground="{DynamicResource TextMuted}"
                                                       TextWrapping="Wrap" Margin="0,4,0,0"/>
                                        </StackPanel>
                                    </StackPanel>

                                    <ProgressBar Height="10" Margin="0,0,0,8"
                                                 Value="{Binding ProgressValue}"
                                                 Minimum="0" Maximum="100"
                                                 IsIndeterminate="{Binding IsIndeterminate}"
                                                 Foreground="{DynamicResource AccentBlue}"
                                                 Background="{DynamicResource BorderColor}"/>

                                    <TextBlock Text="{Binding ScanProgressDetail}"
                                               FontSize="{DynamicResource FontSize.Title}" FontWeight="SemiBold"
                                               Foreground="{DynamicResource TextDark}" Margin="0,0,0,6"/>

                                    <TextBlock Text="{loc:Loc Key=Av_Location}"
                                               FontSize="{DynamicResource FontSize.Caption}" FontWeight="SemiBold"
                                               Foreground="{DynamicResource TextMuted}" Margin="0,0,0,2"/>
                                    <TextBlock Text="{Binding CurrentScanItem}"
                                               FontSize="{DynamicResource FontSize.Body}"
                                               Foreground="{DynamicResource TextDark}"
                                               TextTrimming="CharacterEllipsis"
                                               ToolTip="{Binding CurrentScanItem}"/>

                                    <Separator Margin="0,10,0,8" Background="{DynamicResource BorderColor}"/>

                                    <TextBlock Text="{Binding StatusMessage}"
                                               FontSize="{DynamicResource FontSize.Small}" Foreground="{DynamicResource TextSecondary}"
                                               TextWrapping="Wrap"/>
                                </StackPanel>
                            </Border>

                            <!-- État hors analyse -->
                            <Grid Grid.Row="0" Margin="0,0,0,8">
                                <Grid.Style>
                                    <Style TargetType="Grid">
                                        <Setter Property="Visibility" Value="Visible"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsScanning}" Value="True">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Grid.Style>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock x:Name="antivirusStatusMessage" Text="{Binding StatusMessage}"
                                           Foreground="{DynamicResource TextDark}" FontFamily="{DynamicResource AppFontFamily}"
                                           FontSize="{DynamicResource FontSize.Body}" TextWrapping="Wrap"
                                           VerticalAlignment="Center"/>
                                <TextBlock x:Name="antivirusSummary" Grid.Column="1"
                                           Foreground="{DynamicResource TextSecondary}" FontFamily="{DynamicResource AppFontFamily}"
                                           FontSize="{DynamicResource FontSize.Small}" VerticalAlignment="Center"
                                           Margin="8,0,0,0"/>
                            </Grid>

                            <Grid Grid.Row="1">
                            <DataGrid x:Name="antivirusThreatsGrid" ItemsSource="{Binding Threats}"
                                      VirtualizingPanel.IsVirtualizing="True" VirtualizingPanel.VirtualizationMode="Recycling" ScrollViewer.CanContentScroll="True"
                                      AutoGenerateColumns="False" CanUserAddRows="False"
                                      IsReadOnly="True" Background="{DynamicResource AppBg}" RowBackground="{DynamicResource AppBg}"
                                      AlternatingRowBackground="{DynamicResource HeaderBg}" Foreground="{DynamicResource TextDark}"
                                      GridLinesVisibility="Horizontal"
                                      HorizontalGridLinesBrush="{DynamicResource BorderSubtle}" HeadersVisibility="Column"
                                      BorderBrush="{DynamicResource BorderColor}" BorderThickness="1" SelectionMode="Single"
                                      ColumnHeaderStyle="{StaticResource DgHeader}"
                                      RowStyle="{StaticResource DgRow}">
                                <DataGrid.Columns>
                                    <DataGridTemplateColumn Header="{loc:Loc Key=Av_ColRisk}" Width="95">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <Border CornerRadius="4" Padding="6,2" Margin="2,0">
                                                    <Border.Style>
                                                        <Style TargetType="Border">
                                                            <Setter Property="Background" Value="{DynamicResource RiskInformational}"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding Converter={StaticResource ThreatRiskLevel}}"
                                                                             Value="{x:Static services:RiskLevel.Critical}">
                                                                    <Setter Property="Background" Value="{DynamicResource RiskCritical}"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding Converter={StaticResource ThreatRiskLevel}}"
                                                                             Value="{x:Static services:RiskLevel.Major}">
                                                                    <Setter Property="Background" Value="{DynamicResource RiskMajor}"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding Converter={StaticResource ThreatRiskLevel}}"
                                                                             Value="{x:Static services:RiskLevel.Minor}">
                                                                    <Setter Property="Background" Value="{DynamicResource RiskMinor}"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Border.Style>
                                                    <StackPanel Orientation="Horizontal"
                                                                HorizontalAlignment="Center"
                                                                VerticalAlignment="Center">
                                                        <md:PackIcon Width="12" Height="12" Foreground="{DynamicResource TextOnPrimary}"
                                                                     VerticalAlignment="Center" Margin="0,0,4,0"
                                                                     Kind="{Binding Converter={StaticResource ThreatRiskIcon}}"/>
                                                        <TextBlock Text="{Binding Converter={StaticResource ThreatRiskSeverity}}"
                                                                   FontSize="{DynamicResource FontSize.Caption}" FontWeight="Bold"
                                                                   Foreground="{DynamicResource TextOnPrimary}" VerticalAlignment="Center"/>
                                                    </StackPanel>
                                                </Border>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTextColumn Header="{loc:Loc Key=Av_ColPath}" Binding="{Binding FilePath}" Width="*">
                                        <DataGridTextColumn.ElementStyle>
                                            <Style TargetType="TextBlock" BasedOn="{StaticResource DgCellTextEllipsis}">
                                                <Setter Property="ToolTip" Value="{Binding FilePath}"/>
                                            </Style>
                                        </DataGridTextColumn.ElementStyle>
                                    </DataGridTextColumn>
                                    <DataGridTextColumn Header="{loc:Loc Key=Av_ColThreat}" Binding="{Binding VirusName}" Width="*">
                                        <DataGridTextColumn.ElementStyle>
                                            <Style TargetType="TextBlock" BasedOn="{StaticResource DgCellTextEllipsis}">
                                                <Setter Property="ToolTip" Value="{Binding VirusName}"/>
                                            </Style>
                                        </DataGridTextColumn.ElementStyle>
                                    </DataGridTextColumn>
                                    <DataGridTextColumn Header="{loc:Loc Key=Av_ColTime}" Binding="{Binding DetectedAt, StringFormat='HH:mm:ss'}" Width="60"/>
                                    <DataGridTextColumn Header="{loc:Loc Key=Av_ColStatus}" Binding="{Binding Status}" Width="70"/>
                                    <DataGridTemplateColumn Header="{loc:Loc Key=Av_ColClean}" Width="330">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <StackPanel Orientation="Horizontal" Margin="2,1">
                                                    <Button Margin="0,0,4,0" Tag="{Binding FilePath}"
                                                            Style="{StaticResource SecondaryButton}"
                                                            Click="BtnCheckReputation_Click"
                                                            FontSize="{DynamicResource FontSize.Caption}" Padding="6,4" Cursor="Hand"
                                                            ToolTip="{loc:Loc Key=Av_Tooltip_Reputation}">
                                                        <md:PackIcon Kind="CloudSearch" Width="12" Height="12"/>
                                                    </Button>
                                                    <Button Margin="0,0,4,0" Tag="{Binding FilePath}"
                                                            Style="{StaticResource PrimaryButton}"
                                                            Click="BtnQuarantineThreat_Click"
                                                            FontSize="{DynamicResource FontSize.Caption}" Padding="7,4" Cursor="Hand">
                                                        <StackPanel Orientation="Horizontal">
                                                            <md:PackIcon Kind="ShieldLock" Width="12" Height="12" Margin="0,0,4,0" VerticalAlignment="Center"/>
                                                            <TextBlock Text="{loc:Loc Key=Av_QuarantineBtn}" VerticalAlignment="Center"/>
                                                        </StackPanel>
                                                    </Button>
                                                    <Button Margin="0,0,4,0" Tag="{Binding FilePath}"
                                                            Style="{StaticResource WarningButton}"
                                                            Click="BtnIgnoreThreat_Click"
                                                            FontSize="{DynamicResource FontSize.Caption}" Padding="7,4" Cursor="Hand"
                                                            ToolTip="{loc:Loc Key=Av_Tooltip_Exclude}">
                                                        <StackPanel Orientation="Horizontal">
                                                            <md:PackIcon Kind="EyeOff" Width="12" Height="12" Margin="0,0,4,0" VerticalAlignment="Center"/>
                                                            <TextBlock Text="{loc:Loc Key=Av_IgnoreBtn}" VerticalAlignment="Center"/>
                                                        </StackPanel>
                                                    </Button>
                                                    <Button Tag="{Binding FilePath}"
                                                            Style="{StaticResource DangerButton}"
                                                            Click="BtnDeleteThreat_Click"
                                                            FontSize="{DynamicResource FontSize.Caption}" Padding="7,4" Cursor="Hand">
                                                        <StackPanel Orientation="Horizontal">
                                                            <md:PackIcon Kind="TrashCanOutline" Width="12" Height="12" Margin="0,0,4,0" VerticalAlignment="Center"/>
                                                            <TextBlock Text="{loc:Loc Key=Av_DeleteBtn}" VerticalAlignment="Center"/>
                                                        </StackPanel>
                                                    </Button>
                                                </StackPanel>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                </DataGrid.Columns>
                            </DataGrid>

                            <!-- État vide : visible quand aucune menace et pas de scan en cours -->
                            <StackPanel>
                                <StackPanel.Style>
                                    <Style TargetType="StackPanel" BasedOn="{StaticResource EmptyStatePlaceholder}">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <MultiDataTrigger>
                                                <MultiDataTrigger.Conditions>
                                                    <Condition Binding="{Binding ThreatsFound}" Value="0"/>
                                                    <Condition Binding="{Binding IsScanning}" Value="False"/>
                                                </MultiDataTrigger.Conditions>
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </MultiDataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </StackPanel.Style>
                                <md:PackIcon Kind="ShieldCheck" Width="52" Height="52"
                                             Foreground="{DynamicResource SuccessGreen}"
                                             HorizontalAlignment="Center"/>
                                <TextBlock Text="{loc:Loc Key=Av_NoThreats}"
                                           FontSize="{DynamicResource FontSize.Title}" FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextMedium}"
                                           HorizontalAlignment="Center" Margin="0,10,0,4"/>
                                <TextBlock Text="{loc:Loc Key=Av_SystemClean}"
                                           FontSize="{DynamicResource FontSize.Body}"
                                           Foreground="{DynamicResource TextMuted}"
                                           HorizontalAlignment="Center"/>
                            </StackPanel>
                            </Grid>

                            <StackPanel Grid.Row="2" Orientation="Horizontal"
                                        HorizontalAlignment="Right" Margin="0,8,0,0">
                                <Button x:Name="btnQuarantineAll" Style="{StaticResource WarningButton}"
                                        Command="{Binding QuarantineAllCommand}" Padding="12,6"
                                        AutomationProperties.Name="{loc:Loc Key=Av_QuarantineAll}">
                                    <StackPanel Orientation="Horizontal">
                                        <md:PackIcon Kind="ShieldLock" Width="13" Height="13"
                                                     Foreground="{DynamicResource TextOnPrimary}"
                                                     Margin="0,0,6,0" VerticalAlignment="Center"/>
                                        <TextBlock Text="{loc:Loc Key=Av_QuarantineAll}"
                                                   Foreground="{DynamicResource TextOnPrimary}"
                                                   FontSize="{DynamicResource FontSize.Body}" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>
                            </StackPanel>
                        </Grid>
                    </Border>
                </TabItem>

                <TabItem>
                    <TabItem.Header>
                        <StackPanel Orientation="Horizontal">
                            <md:PackIcon Kind="LockOutline" Width="14" Height="14"
                                         Style="{StaticResource TabHeaderPackIcon}"
                                         Margin="0,0,6,0" VerticalAlignment="Center"/>
                            <TextBlock Text="{loc:Loc Key=Av_TabQuarantine}" VerticalAlignment="Center"/>
                        </StackPanel>
                    </TabItem.Header>
                    <Border Padding="12" Background="{DynamicResource CardBg}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <DataGrid x:Name="quarantineGrid"
                                      VirtualizingPanel.IsVirtualizing="True" VirtualizingPanel.VirtualizationMode="Recycling" ScrollViewer.CanContentScroll="True" Grid.Row="0"
                                      ItemsSource="{Binding QuarantineEntries}"
                                      AutoGenerateColumns="False" CanUserAddRows="False"
                                      IsReadOnly="True" Background="{DynamicResource AppBg}" RowBackground="{DynamicResource AppBg}"
                                      AlternatingRowBackground="{DynamicResource HeaderBg}" Foreground="{DynamicResource TextDark}"
                                      GridLinesVisibility="Horizontal"
                                      HorizontalGridLinesBrush="{DynamicResource BorderSubtle}" BorderBrush="{DynamicResource BorderColor}"
                                      BorderThickness="0" ColumnHeaderStyle="{StaticResource DgHeader}"
                                      RowStyle="{StaticResource DgRow}">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="{loc:Loc Key=Av_ColOrigPath}" Binding="{Binding OriginalPath}" Width="*">
                                        <DataGridTextColumn.ElementStyle>
                                            <Style TargetType="TextBlock" BasedOn="{StaticResource DgCellTextEllipsis}">
                                                <Setter Property="ToolTip" Value="{Binding OriginalPath}"/>
                                            </Style>
                                        </DataGridTextColumn.ElementStyle>
                                    </DataGridTextColumn>
                                    <DataGridTextColumn Header="{loc:Loc Key=Av_ColVirus}" Binding="{Binding VirusName}" Width="140"/>
                                    <DataGridTextColumn Header="{loc:Loc Key=Av_ColSize}" Binding="{Binding SizeDisplay}" Width="75"/>
                                    <DataGridTextColumn Header="{loc:Loc Key=Av_ColQuarDate}" Binding="{Binding QuarantinedAt, StringFormat='dd/MM HH:mm'}" Width="110"/>
                                    <DataGridTemplateColumn Header="{loc:Loc Key=Av_ColActions}" Width="175">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <StackPanel Orientation="Horizontal" Margin="2,1">
                                                    <Button Margin="0,0,4,0" Tag="{Binding Id}"
                                                            Style="{StaticResource PrimaryButton}"
                                                            Click="BtnRestoreFromQuarantine_Click"
                                                            FontSize="{DynamicResource FontSize.Caption}" Padding="7,4" Cursor="Hand">
                                                        <StackPanel Orientation="Horizontal">
                                                            <md:PackIcon Kind="UndoVariant" Width="12" Height="12" Margin="0,0,4,0"/>
                                                            <TextBlock Text="{loc:Loc Key=Av_Restore}"/>
                                                        </StackPanel>
                                                    </Button>
                                                    <Button Tag="{Binding Id}"
                                                            Style="{StaticResource DangerButton}"
                                                            Click="BtnDeleteFromQuarantine_Click"
                                                            FontSize="{DynamicResource FontSize.Caption}" Padding="7,4" Cursor="Hand">
                                                        <StackPanel Orientation="Horizontal">
                                                            <md:PackIcon Kind="TrashCanOutline" Width="12" Height="12" Margin="0,0,4,0"/>
                                                            <TextBlock Text="{loc:Loc Key=Av_Delete}"/>
                                                        </StackPanel>
                                                    </Button>
                                                </StackPanel>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                </DataGrid.Columns>
                            </DataGrid>
                            <Grid Grid.Row="1" Margin="0,8,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                                    <Button Padding="12,6"
                                            Command="{Binding LoadMoreQuarantineCommand}"
                                            Style="{StaticResource PrimaryButton}" Margin="0,0,10,0">
                                        <StackPanel Orientation="Horizontal">
                                            <md:PackIcon Kind="ChevronDown" Width="14" Height="14"
                                                         Margin="0,0,8,0" VerticalAlignment="Center"/>
                                            <TextBlock Text="{loc:Loc Key=Av_LoadMore}" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Button>
                                    <TextBlock Text="{Binding QuarantinePagingStatus}"
                                               Foreground="{DynamicResource TextMuted}"
                                               FontSize="{DynamicResource FontSize.Small}"
                                               VerticalAlignment="Center"/>
                                </StackPanel>
                                <Button Grid.Column="1" x:Name="btnPurgeQuarantine" Style="{StaticResource DangerButton}"
                                        Command="{Binding PurgeQuarantineCommand}" Padding="12,6">
                                    <StackPanel Orientation="Horizontal">
                                        <md:PackIcon Kind="TrashCanOutline" Width="14" Height="14"
                                                     Margin="0,0,7,0" VerticalAlignment="Center"/>
                                        <TextBlock Text="{loc:Loc Key=Av_EmptyQuarantine}" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>
                            </Grid>
                        </Grid>
                    </Border>
                </TabItem>

                <TabItem>
                    <TabItem.Header>
                        <StackPanel Orientation="Horizontal">
                            <md:PackIcon Kind="DatabaseRefresh" Width="14" Height="14"
                                         Style="{StaticResource TabHeaderPackIcon}"
                                         Margin="0,0,6,0" VerticalAlignment="Center"/>
                            <TextBlock Text="{loc:Loc Key=Av_TabSignatures}" VerticalAlignment="Center"/>
                        </StackPanel>
                    </TabItem.Header>
                    <Border Padding="10,8" Background="{DynamicResource CardBg}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <StackPanel Grid.Row="0">
                                    <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="0.9*"/>
                                            <ColumnDefinition Width="0.9*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <Border Grid.Column="0" Style="{StaticResource AvSigMetricTile}" Margin="0,0,4,0">
                                        <StackPanel>
                                            <TextBlock Text="YARA" Foreground="{DynamicResource TextMuted}"
                                                       FontSize="{DynamicResource FontSize.Micro}" FontWeight="Bold"/>
                                            <TextBlock x:Name="sigYaraVersion" Foreground="{DynamicResource PrimaryBlue}"
                                                       FontSize="{DynamicResource FontSize.Large}" FontWeight="Bold" Margin="0,2,0,0"/>
                                            <TextBlock x:Name="sigYaraLastMaj" Foreground="{DynamicResource TextMuted}"
                                                       FontSize="{DynamicResource FontSize.Micro}" Margin="0,2,0,0" TextTrimming="CharacterEllipsis"/>
                                        </StackPanel>
                                    </Border>

                                    <Border Grid.Column="1" Style="{StaticResource AvSigMetricTile}" Margin="4,0,4,0">
                                        <StackPanel>
                                            <TextBlock Text="CLAMAV" Foreground="{DynamicResource TextMuted}"
                                                       FontSize="{DynamicResource FontSize.Micro}" FontWeight="Bold"/>
                                            <TextBlock x:Name="sigClamVersion" Foreground="{DynamicResource AlertGold}"
                                                       FontSize="{DynamicResource FontSize.Large}" FontWeight="Bold" Margin="0,2,0,0"/>
                                            <TextBlock x:Name="sigClamLastMaj" Foreground="{DynamicResource TextMuted}"
                                                       FontSize="{DynamicResource FontSize.Micro}" Margin="0,2,0,0" TextTrimming="CharacterEllipsis"/>
                                        </StackPanel>
                                    </Border>

                                    <StackPanel Grid.Column="2" VerticalAlignment="Center">
                                        <Button x:Name="btnManualUpdateSignatures"
                                                Style="{StaticResource SuccessButton}"
                                                Click="BtnManualUpdateSignatures_Click"
                                                Padding="9,6" FontSize="{DynamicResource FontSize.Small}"
                                                ToolTip="{loc:Loc Key=Av_Tooltip_UpdateSignatures}"
                                                AutomationProperties.Name="{loc:Loc Key=Av_Tooltip_UpdateSignatures}">
                                            <StackPanel Orientation="Horizontal">
                                                <md:PackIcon Kind="Refresh" Width="14" Height="14"
                                                             Foreground="{DynamicResource TextOnPrimary}"
                                                             Margin="0,0,6,0" VerticalAlignment="Center"/>
                                                <TextBlock Text="{loc:Loc Key=Av_Update}"
                                                           Foreground="{DynamicResource TextOnPrimary}"
                                                           VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </Button>
                                        <Button x:Name="btnStopUpdateSignatures"
                                                Style="{StaticResource DangerButton}"
                                                Click="BtnStopUpdateSignatures_Click"
                                                Visibility="Collapsed" Margin="0,4,0,0"
                                                Padding="8,4" FontSize="{DynamicResource FontSize.Caption}">
                                            <TextBlock Text="{loc:Loc Key=Av_StopUpdate}" VerticalAlignment="Center"/>
                                        </Button>
                                    </StackPanel>
                                </Grid>

                                <Grid Margin="0,0,0,6">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <ProgressBar x:Name="sigUpdateProgressBar" Grid.Row="0"
                                                 Height="4" IsIndeterminate="True"
                                                 Foreground="{DynamicResource SuccessGreen}"
                                                 Background="{DynamicResource SurfaceBg}"
                                                 BorderBrush="Transparent"
                                                 Visibility="Collapsed">
                                        <ProgressBar.Template>
                                            <ControlTemplate TargetType="ProgressBar">
                                                <Grid>
                                                    <Border x:Name="PART_Track" CornerRadius="2"
                                                            Background="{TemplateBinding Background}"/>
                                                    <Border x:Name="PART_Indicator" CornerRadius="2"
                                                            Background="{TemplateBinding Foreground}"
                                                            HorizontalAlignment="Left"/>
                                                </Grid>
                                            </ControlTemplate>
                                        </ProgressBar.Template>
                                    </ProgressBar>
                                </Grid>
                            </StackPanel>

                            <Border Grid.Row="1" CornerRadius="8" BorderBrush="{DynamicResource BorderColor}" BorderThickness="1"
                                    Background="{DynamicResource AppBg}">
                                <TextBox x:Name="signatureLog" Margin="2" IsReadOnly="True" Background="Transparent"
                                         Foreground="{DynamicResource SuccessGreen}" FontFamily="{DynamicResource AppFontFamily}" FontSize="{DynamicResource FontSize.Caption}"
                                         TextWrapping="Wrap" BorderThickness="0" Padding="8,6"
                                         VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled"/>
                            </Border>
                        </Grid>
                    </Border>
                </TabItem>
            </TabControl>
            </Border>
            </Grid>
        </Grid>

    </DockPanel>
</UserControl>
                                       