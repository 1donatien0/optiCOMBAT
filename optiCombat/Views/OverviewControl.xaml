<UserControl x:Class="optiCombat.Views.OverviewControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:md="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:strings="clr-namespace:optiCombat.Strings"
             xmlns:loc="clr-namespace:optiCombat.Localization"
             UseLayoutRounding="True"
             SnapsToDevicePixels="True"
             TextOptions.TextFormattingMode="Display"
             TextOptions.TextRenderingMode="ClearType">

    <Grid Background="Transparent">
        <Grid.RowDefinitions>
            <!-- Hero shield zone -->
            <RowDefinition Height="240"/>
            <!-- Actions bar -->
            <RowDefinition Height="Auto"/>
            <!-- Bandeau UAC (masqué si admin) -->
            <RowDefinition Height="Auto"/>
            <!-- Bottom cards -->
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ══════════════════════════════════════════════════════
             HERO — statut (gauche) · logo OPTICOMBAT (droite)
        ══════════════════════════════════════════════════════ -->
        <Border Grid.Row="0" Margin="24,20,24,0"
                Background="{DynamicResource CardBg}"
                BorderBrush="{DynamicResource CardBorderAccent}"
                BorderThickness="1"
                CornerRadius="16"
                Padding="28,16"
                Effect="{DynamicResource CardShadow}">
            <Grid UseLayoutRounding="True" SnapsToDevicePixels="True">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*" MinWidth="200"/>
                </Grid.ColumnDefinitions>

                <!-- Statut protection + analyse -->
                <StackPanel Grid.Column="0" VerticalAlignment="Center" Margin="0,0,20,0">
                    <TextBlock x:Name="txtProtectionHeadline"
                               Text="{loc:Loc Key=Overview_Protected}"
                               FontSize="26" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextDark}"
                               TextWrapping="NoWrap"
                               TextOptions.TextFormattingMode="Display"/>
                    <TextBlock x:Name="txtProtectionSub"
                               Text="{loc:Loc Key=Overview_ProtectedSub}"
                               FontSize="{DynamicResource FontSize.Body}"
                               Foreground="{DynamicResource TextMuted}"
                               TextWrapping="Wrap"
                               MaxWidth="400"
                               Margin="0,5,0,0"/>
                    <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                        <md:PackIcon Kind="ClockOutline" Width="13" Height="13"
                                     Foreground="{DynamicResource SuccessGreen}"
                                     VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <TextBlock Text="{loc:Loc Key=Overview_LastScan}"
                                   FontSize="{DynamicResource FontSize.Small}"
                                   Foreground="{DynamicResource SuccessGreen}"
                                   VerticalAlignment="Center" Margin="0,0,5,0"/>
                        <TextBlock x:Name="txtLastScan"
                                   Text="{loc:Loc Key=Common_Never}"
                                   FontSize="{DynamicResource FontSize.Small}" FontWeight="SemiBold"
                                   Foreground="{DynamicResource SuccessGreen}"
                                   VerticalAlignment="Center"/>
                    </StackPanel>

                    <Button Style="{StaticResource PrimaryButton}"
                            HorizontalAlignment="Left"
                            Margin="0,16,0,0" Padding="26,10"
                            Tag="{x:Static strings:OpticombatStrings+PanelIds.Antivirus}"
                            Click="ActionCard_Click">
                        <StackPanel Orientation="Horizontal">
                            <md:PackIcon Kind="ShieldSearch" Width="18" Height="18"
                                         VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <TextBlock Text="{loc:Loc Key=Overview_ScanTitle}"
                                       FontWeight="SemiBold" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </StackPanel>

                <!-- Logo OPTICOMBAT — emblème net + wordmark vectoriel (adaptatif thème) -->
                <StackPanel Grid.Column="1" Orientation="Horizontal"
                            VerticalAlignment="Center" HorizontalAlignment="Right"
                            Margin="8,0,0,0">
                    <!-- Emblème teal (fond transparent, anneau + coche intégrés) -->
                    <Image Source="/optiCombat;component/optiCombat_hero.png"
                           Stretch="Uniform" Height="128"
                           VerticalAlignment="Center"
                           RenderOptions.BitmapScalingMode="HighQuality"
                           SnapsToDevicePixels="True"/>
                    <!-- Wordmark texte : OPTI (neutre) + COMBAT (dégradé accent) + slogan -->
                    <StackPanel VerticalAlignment="Center" Margin="16,0,4,0">
                        <TextBlock FontFamily="Segoe UI" FontSize="44" FontWeight="Bold"
                                   TextOptions.TextFormattingMode="Ideal">
                            <Run Text="opti" Foreground="{DynamicResource TextDark}"/><Run Text="COMBAT" Foreground="{DynamicResource AccentBlue}"/>
                        </TextBlock>
                        <TextBlock Text="PROTECT  •  DETECT  •  DEFEND"
                                   FontFamily="Segoe UI" FontSize="14" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextMuted}"
                                   Margin="3,3,0,0"/>
                    </StackPanel>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ══════════════════════════════════════════════════════
             BARRE D'ACTIONS (4 boutons compacts en ligne)
        ══════════════════════════════════════════════════════ -->
        <Border Grid.Row="1" Margin="24,12,24,0"
                Background="{DynamicResource GlassCardBg}"
                BorderBrush="{DynamicResource GlassCardRim}"
                BorderThickness="1"
                CornerRadius="14"
                Padding="12,10"
                Effect="{DynamicResource CardShadow}">
            <UniformGrid Columns="4">

                <Button Margin="0,0,4,0" Style="{StaticResource HubActionCardButton}"
                        Tag="{x:Static strings:OpticombatStrings+PanelIds.Clean}"
                        Click="ActionCard_Click">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center"
                                VerticalAlignment="Center" Margin="12,10">
                        <Border Width="38" Height="38" CornerRadius="10" Margin="0,0,10,0"
                                Background="{DynamicResource AlertBg}">
                            <md:PackIcon Kind="Broom" Width="20" Height="20"
                                         Foreground="{DynamicResource AlertGoldLight}"
                                         HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="{loc:Loc Key=Overview_CleanTitle}"
                                       FontSize="{DynamicResource FontSize.Body}" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextDark}"/>
                            <TextBlock Text="{loc:Loc Key=Overview_CleanSub}"
                                       FontSize="{DynamicResource FontSize.Caption}"
                                       Foreground="{DynamicResource TextMuted}"/>
                        </StackPanel>
                    </StackPanel>
                </Button>

                <Button Margin="2,0" Style="{StaticResource HubActionCardButton}"
                        Tag="{x:Static strings:OpticombatStrings+PanelIds.Antivirus}"
                        Click="ActionCard_Click">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center"
                                VerticalAlignment="Center" Margin="12,10">
                        <Border Width="38" Height="38" CornerRadius="10" Margin="0,0,10,0"
                                Background="{DynamicResource SuccessBg}">
                            <md:PackIcon Kind="ShieldCheck" Width="20" Height="20"
                                         Foreground="{DynamicResource SuccessGreen}"
                                         HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="{loc:Loc Key=Overview_ScanTitle}"
                                       FontSize="{DynamicResource FontSize.Body}" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextDark}"/>
                            <TextBlock Text="{loc:Loc Key=Overview_ScanSub}"
                                       FontSize="{DynamicResource FontSize.Caption}"
                                       Foreground="{DynamicResource TextMuted}"/>
                        </StackPanel>
                    </StackPanel>
                </Button>

                <Button Margin="2,0" Style="{StaticResource HubActionCardButton}"
                        Tag="{x:Static strings:OpticombatStrings+PanelIds.History}"
                        Click="ActionCard_Click">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center"
                                VerticalAlignment="Center" Margin="12,10">
                        <Border Width="38" Height="38" CornerRadius="10" Margin="0,0,10,0"
                                Background="{DynamicResource AccentBg}">
                            <md:PackIcon Kind="History" Width="20" Height="20"
                                         Foreground="{DynamicResource AccentBlue}"
                                         HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="{loc:Loc Key=Overview_HistoryTitle}"
                                       FontSize="{DynamicResource FontSize.Body}" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextDark}"/>
                            <TextBlock Text="{loc:Loc Key=Overview_HistorySub}"
                                       FontSize="{DynamicResource FontSize.Caption}"
                                       Foreground="{DynamicResource TextMuted}"/>
                        </StackPanel>
                    </StackPanel>
                </Button>

                <Button Margin="4,0,0,0" Style="{StaticResource HubActionCardButton}"
                        Tag="{x:Static strings:OpticombatStrings+ActionIds.Update}"
                        Click="ActionCard_Click">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center"
                                VerticalAlignment="Center" Margin="12,10">
                        <Border Width="38" Height="38" CornerRadius="10" Margin="0,0,10,0"
                                Background="{DynamicResource AccentBg}">
                            <md:PackIcon Kind="Refresh" Width="20" Height="20"
                                         Foreground="{DynamicResource TextAccent}"
                                         HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="{loc:Loc Key=Overview_UpdateTitle}"
                                       FontSize="{DynamicResource FontSize.Body}" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextDark}"/>
                            <TextBlock Text="{loc:Loc Key=Overview_UpdateSub}"
                                       FontSize="{DynamicResource FontSize.Caption}"
                                       Foreground="{DynamicResource TextMuted}"/>
                        </StackPanel>
                    </StackPanel>
                </Button>

            </UniformGrid>
        </Border>

        <!-- ══════════════════════════════════════════════════════
             BANDEAU UAC — visible uniquement hors droits admin
        ══════════════════════════════════════════════════════ -->
        <Border x:Name="bannerPartialScan"
                Grid.Row="2"
                Margin="24,6,24,0"
                CornerRadius="10"
                Padding="14,10"
                Background="{DynamicResource AlertBg}"
                BorderBrush="{DynamicResource AlertGold}"
                BorderThickness="1"
                Visibility="Collapsed">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <md:PackIcon Grid.Column="0" Kind="ShieldAlert" Width="18" Height="18"
                             Foreground="{DynamicResource AlertGold}"
                             VerticalAlignment="Center" Margin="0,0,10,0"/>
                <TextBlock Grid.Column="1"
                           Text="{loc:Loc Key=Overview_PartialScanBanner}"
                           FontSize="{DynamicResource FontSize.Body}"
                           Foreground="{DynamicResource AlertGold}"
                           VerticalAlignment="Center" TextWrapping="Wrap"/>
                <Button Grid.Column="2"
                        x:Name="btnRunAsAdmin"
                        Style="{StaticResource WarningButton}"
                        Padding="12,6" Margin="12,0,0,0"
                        Click="BtnRunAsAdmin_Click">
                    <StackPanel Orientation="Horizontal">
                        <md:PackIcon Kind="ShieldLock" Width="14" Height="14"
                                     Margin="0,0,6,0" VerticalAlignment="Center"/>
                        <TextBlock Text="{loc:Loc Key=Overview_RunAsAdmin}" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </Grid>
        </Border>

        <!-- ══════════════════════════════════════════════════════
             CARTES BAS — Statistiques / Recommandations / État de protection
        ══════════════════════════════════════════════════════ -->
        <Grid Grid.Row="3" Margin="24,10,24,12" VerticalAlignment="Stretch">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="4*"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="4*"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="3*"/>
            </Grid.ColumnDefinitions>

            <!-- Statistiques -->
            <Border Grid.Column="0" VerticalAlignment="Stretch"
                    Style="{StaticResource ContentPanelCard}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <StackPanel Grid.Row="0">
                        <TextBlock Text="{loc:Loc Key=Overview_StatsTitle}"
                                   FontSize="{DynamicResource FontSize.Title}" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextDark}"/>
                        <TextBlock Text="{loc:Loc Key=Overview_StatsSub}"
                                   FontSize="{DynamicResource FontSize.Small}" Foreground="{DynamicResource TextMuted}"
                                   Margin="0,2,0,2"/>
                        <TextBlock x:Name="txtProtectionStatsUpdated"
                                   FontSize="{DynamicResource FontSize.Caption}" Foreground="{DynamicResource TextMuted}"
                                   Margin="0,0,0,8"/>
                    </StackPanel>
                    <Border Grid.Row="1"
                            CornerRadius="8"
                            Background="{DynamicResource SurfaceBg}"
                            Padding="12,10"
                            MinHeight="72">
                        <TextBlock x:Name="txtProtectionStatsBody"
                                   TextWrapping="Wrap"
                                   FontSize="{DynamicResource FontSize.Body}"
                                   Foreground="{DynamicResource TextDark}"
                                   VerticalAlignment="Top"
                                   LineHeight="20"
                                   Text="{loc:Loc Key=Overview_StatsLoading}"/>
                    </Border>
                </Grid>
            </Border>

            <!-- Recommandations -->
            <Border Grid.Column="2" VerticalAlignment="Stretch"
                    Style="{StaticResource ContentPanelCard}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0"
                               Text="{loc:Loc Key=Overview_Recommendations}"
                               FontSize="{DynamicResource FontSize.Title}" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextDark}" Margin="0,0,0,10"/>

                    <!-- Le contenu peut dépasser la hauteur de la carte (plusieurs
                         recommandations, plusieurs composants plateforme) : on le rend
                         défilable au lieu de le laisser être rogné par les coins arrondis
                         de la Border parente. -->
                    <ScrollViewer Grid.Row="1"
                                  VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled"
                                  Padding="0,0,4,0">
                        <StackPanel>
                            <Border Background="{DynamicResource SurfaceBg}"
                                    CornerRadius="8" Padding="10,8" Margin="0,0,0,8">
                                <StackPanel>
                                    <TextBlock Text="{loc:Loc Key=Posture_Title}"
                                               FontSize="{DynamicResource FontSize.Caption}" FontWeight="Bold"
                                               Foreground="{DynamicResource TextMuted}"/>
                                    <StackPanel Orientation="Horizontal" Margin="0,4,0,2">
                                        <TextBlock x:Name="txtSecurityScore"
                                                   Text="—"
                                                   FontSize="28" FontWeight="Bold"
                                                   Foreground="{DynamicResource TextAccent}"
                                                   VerticalAlignment="Center"/>
                                        <TextBlock Text="/100"
                                                   FontSize="{DynamicResource FontSize.Small}"
                                                   Foreground="{DynamicResource TextMuted}"
                                                   VerticalAlignment="Bottom" Margin="4,0,0,5"/>
                                    </StackPanel>
                                    <TextBlock x:Name="txtPostureSummary"
                                               TextWrapping="Wrap"
                                               FontSize="{DynamicResource FontSize.Micro}"
                                               Foreground="{DynamicResource TextDark}"
                                               LineHeight="14"
                                               Visibility="Collapsed"/>
                                    <StackPanel x:Name="postureIssuesPanel"/>
                                </StackPanel>
                            </Border>

                            <Border Background="{DynamicResource SurfaceBg}"
                                    CornerRadius="8" Padding="10,8" Margin="0,0,0,8">
                                <StackPanel>
                                    <TextBlock Text="{loc:Loc Key=Platform_StatusTitle}"
                                               FontSize="{DynamicResource FontSize.Caption}" FontWeight="Bold"
                                               Foreground="{DynamicResource TextMuted}"/>
                                    <StackPanel x:Name="platformStatusPanel" Margin="0,6,0,0"/>
                                </StackPanel>
                            </Border>

                            <Border x:Name="brRecHygiene" Background="{DynamicResource AlertBg}"
                                    CornerRadius="8" Padding="10,8">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <md:PackIcon x:Name="icRecHygiene" Grid.Column="0" Kind="Broom" Width="14" Height="14"
                                                 Foreground="{DynamicResource AlertGoldLight}"
                                                 VerticalAlignment="Top" Margin="0,1,0,0"/>
                                    <TextBlock x:Name="txtRecHygiene" Grid.Column="1" Text="{loc:Loc Key=Overview_RecHygiene}"
                                               FontSize="{DynamicResource FontSize.Small}" Foreground="{DynamicResource AlertGold}"
                                               LineHeight="16" TextWrapping="Wrap" Margin="6,0,0,0"/>
                                </Grid>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </Border>

            <!-- État de protection + signatures -->
            <Border Grid.Column="4" VerticalAlignment="Stretch"
                    Style="{StaticResource ContentPanelCard}">
                <StackPanel>
                    <TextBlock Text="{loc:Loc Key=Overview_ProtectionState}"
                               FontSize="{DynamicResource FontSize.Title}" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextDark}"
                               Margin="0,0,0,10"/>

                    <Grid Margin="0,0,0,6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <md:PackIcon Kind="ShieldCheck" Width="14" Height="14"
                                     Foreground="{DynamicResource SuccessGreen}"
                                     VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <TextBlock Grid.Column="1" Text="ClamAV"
                                   FontSize="{DynamicResource FontSize.Small}" Foreground="{DynamicResource TextMuted}"
                                   VerticalAlignment="Center"/>
                        <TextBlock x:Name="txtOverviewClamAvStatus" Grid.Column="2"
                                   Text="{loc:Loc Key=Overview_ClamActive}" FontSize="{DynamicResource FontSize.Small}" FontWeight="SemiBold"
                                   Foreground="{DynamicResource SuccessGreen}"
                                   VerticalAlignment="Center"/>
                    </Grid>

                    <Grid Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <md:PackIcon Kind="Dna" Width="14" Height="14"
                                     Foreground="{DynamicResource AccentBlue}"
                                     VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <TextBlock Grid.Column="1" Text="{loc:Loc Key=Overview_YaraRulesLabel}"
                                   FontSize="{DynamicResource FontSize.Small}" Foreground="{DynamicResource TextMuted}"
                                   VerticalAlignment="Center"/>
                        <TextBlock x:Name="txtOverviewYaraCount" Grid.Column="2"
                                   Text="—" FontSize="{DynamicResource FontSize.Small}" FontWeight="SemiBold"
                                   Foreground="{DynamicResource AccentBlue}"
                                   VerticalAlignment="Center"/>
                    </Grid>

                    <Rectangle Height="1" Fill="{DynamicResource CardBorderAccent}" Margin="0,0,0,10"/>

                    <TextBlock Text="{loc:Loc Key=Overview_SignaturesSection}"
                               FontSize="{DynamicResource FontSize.Small}" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextDark}"
                               Margin="0,0,0,8"/>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Margin="0,0,8,0">
                            <TextBlock Text="YARA" FontSize="{DynamicResource FontSize.Caption}" FontWeight="Bold"
                                       Foreground="{DynamicResource TextMuted}"/>
                            <TextBlock x:Name="txtOverviewYaraPackVer" Text="—"
                                       FontSize="{DynamicResource FontSize.Large}" FontWeight="Bold"
                                       Foreground="{DynamicResource AccentBlue}" Margin="0,2,0,0"/>
                            <TextBlock Text="{loc:Loc Key=Overview_LastUpdateShort}" FontSize="{DynamicResource FontSize.Micro}"
                                       Foreground="{DynamicResource TextMuted}" Margin="0,6,0,0"/>
                            <TextBlock x:Name="txtOverviewYaraPackMaj" Text="—"
                                       FontSize="{DynamicResource FontSize.Small}" Foreground="{DynamicResource TextDark}"/>
                        </StackPanel>

                        <Rectangle Grid.Column="1" Width="1" Margin="4,0"
                                   Fill="{DynamicResource BorderColor}" VerticalAlignment="Stretch"/>

                        <StackPanel Grid.Column="2" Margin="8,0,0,0">
                            <TextBlock Text="ClamAV" FontSize="{DynamicResource FontSize.Caption}" FontWeight="Bold"
                                       Foreground="{DynamicResource TextMuted}"/>
                            <TextBlock x:Name="txtOverviewClamDbVer" Text="—"
                                       FontSize="{DynamicResource FontSize.Large}" FontWeight="Bold"
                                       Foreground="{DynamicResource AlertGold}" Margin="0,2,0,0"/>
                            <TextBlock Text="{loc:Loc Key=Overview_LastUpdateShort}" FontSize="{DynamicResource FontSize.Micro}"
                                       Foreground="{DynamicResource TextMuted}" Margin="0,6,0,0"/>
                            <TextBlock x:Name="txtOverviewClamDbMaj" Text="—"
                                       FontSize="{DynamicResource FontSize.Small}" Foreground="{DynamicResource TextDark}"/>
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Border>
        </Grid>
        </Grid>
</UserControl>
