<Window x:Class="optiCombat.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:md="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:views="clr-namespace:optiCombat.Views"
        xmlns:strings="clr-namespace:optiCombat.Strings"
        xmlns:loc="clr-namespace:optiCombat.Localization"
        mc:Ignorable="d"
        Title="{loc:Loc Key=App_Title}"
        Height="720" Width="1280"
        MinHeight="600" MinWidth="1024"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource AppBg}"
        FontFamily="{DynamicResource AppFontFamily}"
        Icon="optiCombat.ico">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="90"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ═══════════════════════════════════════════════
             SIDEBAR SLIM (90 px)
        ═══════════════════════════════════════════════ -->
        <Border Grid.Column="0"
                Background="{DynamicResource SidebarBg}"
                BorderBrush="{DynamicResource BorderColor}"
                BorderThickness="0,0,1,0">
            <DockPanel>

                <!-- Logo compact (favicon OPTICOMBAT) -->
                <StackPanel DockPanel.Dock="Top" Margin="0,18,0,10"
                            HorizontalAlignment="Center">
                    <Image Source="/optiCombat;component/optiCombat_hero.png"
                           Width="52" Height="52"
                           HorizontalAlignment="Center" VerticalAlignment="Center"
                           RenderOptions.BitmapScalingMode="HighQuality"/>
                </StackPanel>

                <Separator DockPanel.Dock="Top" Background="{DynamicResource BorderSubtle}" Margin="10,0,10,4"/>

                <!-- Boutons bas -->
                <StackPanel DockPanel.Dock="Bottom" Margin="0,0,0,10"
                            HorizontalAlignment="Center">

                    <!-- Version -->
                    <TextBlock x:Name="txtSidebarVersion"
                               Text="…"
                               FontSize="{DynamicResource FontSize.Micro}" Foreground="{DynamicResource TextMuted}"
                               HorizontalAlignment="Center" Margin="0,6,0,0"
                               TextWrapping="Wrap" TextAlignment="Center" Width="80"/>
                </StackPanel>

                <StackPanel DockPanel.Dock="Bottom" Margin="0,0,0,4"
                            HorizontalAlignment="Center">

                    <!-- Site web (icône seule) -->
                    <Button x:Name="btnWebsite"
                            Click="BtnWebsite_Click"
                            Width="48" Height="36" Margin="0,3"
                            Background="{DynamicResource SurfaceBg}"
                            BorderBrush="{DynamicResource BorderColor}"
                            BorderThickness="1"
                            Cursor="Hand"
                            ToolTip="{loc:Loc Key=Nav_TooltipWebsite}"
                            AutomationProperties.Name="{loc:Loc Key=Nav_TooltipWebsite}">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="bg" CornerRadius="8"
                                        Background="{TemplateBinding Background}"
                                        BorderBrush="{TemplateBinding BorderBrush}"
                                        BorderThickness="{TemplateBinding BorderThickness}">
                                    <md:PackIcon Kind="Web" Width="16" Height="16"
                                                 Foreground="{DynamicResource TextMedium}"
                                                 HorizontalAlignment="Center"
                                                 VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="bg" Property="Background" Value="{DynamicResource SidebarHover}"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                    <!-- Mode sombre (icône seule) -->
                    <Button x:Name="btnModesSombre"
                            Click="BtnModesSombre_Click"
                            Width="48" Height="36" Margin="0,3"
                            Background="{DynamicResource ThemeToggleBg}"
                            BorderThickness="0"
                            Cursor="Hand"
                            AutomationProperties.Name="{loc:Loc Key=Nav_TooltipThemeDark}">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="bg" CornerRadius="8"
                                        Background="{TemplateBinding Background}">
                                    <md:PackIcon Kind="WeatherSunny" Width="16" Height="16"
                                                 Foreground="{DynamicResource ThemeToggleFg}"
                                                 HorizontalAlignment="Center"
                                                 VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsPressed" Value="True">
                                        <Setter TargetName="bg" Property="Opacity" Value="0.78"/>
                                    </Trigger>
                                    <EventTrigger RoutedEvent="MouseEnter">
                                        <BeginStoryboard>
                                            <Storyboard>
                                                <DoubleAnimation Storyboard.TargetName="bg"
                                                                 Storyboard.TargetProperty="Opacity"
                                                                 To="0.88" Duration="0:0:0.12"/>
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </EventTrigger>
                                    <EventTrigger RoutedEvent="MouseLeave">
                                        <BeginStoryboard>
                                            <Storyboard>
                                                <DoubleAnimation Storyboard.TargetName="bg"
                                                                 Storyboard.TargetProperty="Opacity"
                                                                 To="1" Duration="0:0:0.12"/>
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </EventTrigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </StackPanel>

                <!-- Séparateur avant boutons bas -->
                <Separator DockPanel.Dock="Bottom"
                           Background="{DynamicResource BorderSubtle}"
                           Margin="10,4,10,4"/>

                <!-- Navigation RadioButtons — icône + label empilés, centrés -->
                <StackPanel DockPanel.Dock="Top"
                            KeyboardNavigation.TabNavigation="Local">

                    <!-- Vue d'ensemble -->
                    <RadioButton x:Name="navOverview"
                                 Style="{StaticResource NavItem}"
                                 Tag="{x:Static strings:OpticombatStrings+PanelIds.Overview}"
                                 Checked="NavItem_Checked"
                                 IsTabStop="True"
                                 ToolTip="{loc:Loc Key=Nav_TooltipHome}"
                                 AutomationProperties.Name="{loc:Loc Key=Nav_TooltipHome}">
                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                            <md:PackIcon Kind="Monitor" Width="22" Height="22"
                                         HorizontalAlignment="Center"
                                         VerticalAlignment="Center"/>
                            <TextBlock Text="{loc:Loc Key=Nav_Home}" FontSize="{DynamicResource FontSize.Micro}" TextAlignment="Center"
                                       Margin="0,4,0,0"/>
                        </StackPanel>
                    </RadioButton>

                    <!-- Nettoyer -->
                    <RadioButton x:Name="navClean"
                                 Style="{StaticResource NavItem}"
                                 Tag="{x:Static strings:OpticombatStrings+PanelIds.Clean}"
                                 Checked="NavItem_Checked"
                                 IsTabStop="True"
                                 ToolTip="{loc:Loc Key=Nav_TooltipClean}"
                                 AutomationProperties.Name="{loc:Loc Key=Nav_TooltipClean}">
                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                            <md:PackIcon Kind="Broom" Width="22" Height="22"
                                         HorizontalAlignment="Center"
                                         VerticalAlignment="Center"/>
                            <TextBlock Text="{loc:Loc Key=Nav_Clean}" FontSize="{DynamicResource FontSize.Micro}" TextAlignment="Center"
                                       Margin="0,4,0,0"/>
                        </StackPanel>
                    </RadioButton>

                    <!-- Antivirus -->
                    <RadioButton x:Name="navAntivirus"
                                 Style="{StaticResource NavItem}"
                                 Tag="{x:Static strings:OpticombatStrings+PanelIds.Antivirus}"
                                 Checked="NavItem_Checked"
                                 IsTabStop="True"
                                 ToolTip="{loc:Loc Key=Nav_TooltipAntivirus}"
                                 AutomationProperties.Name="{loc:Loc Key=Nav_TooltipAntivirus}">
                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                            <Grid HorizontalAlignment="Center">
                                <md:PackIcon Kind="ShieldCheck" Width="22" Height="22"
                                             HorizontalAlignment="Center"
                                             VerticalAlignment="Center"/>
                                <!-- Badge ClamAV (petit point vert) -->
                                <md:PackIcon x:Name="icoSidebarClamAv"
                                             Kind="ShieldCheck" Width="10" Height="10"
                                             HorizontalAlignment="Right" VerticalAlignment="Bottom"
                                             Foreground="{DynamicResource SuccessGreen}"/>
                            </Grid>
                            <TextBlock Text="{loc:Loc Key=Nav_Antivirus}" FontSize="{DynamicResource FontSize.Micro}" TextAlignment="Center"
                                       Margin="0,4,0,0"/>
                            <TextBlock x:Name="txtSidebarClamAvBadge"
                                       Text="{loc:Loc Key=Main_SidebarActive}"
                                       FontSize="{DynamicResource FontSize.Micro}" TextAlignment="Center"
                                       Foreground="{DynamicResource SuccessGreen}"
                                       Margin="0,1,0,0"/>
                        </StackPanel>
                    </RadioButton>

                    <!-- Historique -->
                    <RadioButton x:Name="navHistory"
                                 Style="{StaticResource NavItem}"
                                 Tag="{x:Static strings:OpticombatStrings+PanelIds.History}"
                                 Checked="NavItem_Checked"
                                 IsTabStop="True"
                                 ToolTip="{loc:Loc Key=Nav_TooltipHistory}"
                                 AutomationProperties.Name="{loc:Loc Key=Nav_TooltipHistory}">
                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                            <md:PackIcon Kind="History" Width="22" Height="22"
                                         HorizontalAlignment="Center"
                                         VerticalAlignment="Center"/>
                            <TextBlock Text="{loc:Loc Key=Nav_History}" FontSize="{DynamicResource FontSize.Micro}" TextAlignment="Center"
                                       Margin="0,4,0,0"/>
                        </StackPanel>
                    </RadioButton>

                    <!-- Options -->
                    <RadioButton x:Name="navOptions"
                                 Style="{StaticResource NavItem}"
                                 Tag="{x:Static strings:OpticombatStrings+PanelIds.Options}"
                                 Checked="NavItem_Checked"
                                 IsTabStop="True"
                                 ToolTip="{loc:Loc Key=Nav_TooltipOptions}"
                                 AutomationProperties.Name="{loc:Loc Key=Nav_TooltipOptions}">
                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                            <md:PackIcon Kind="Cog" Width="22" Height="22"
                                         HorizontalAlignment="Center"
                                         VerticalAlignment="Center"/>
                            <TextBlock Text="{loc:Loc Key=Nav_Options}" FontSize="{DynamicResource FontSize.Micro}" TextAlignment="Center"
                                       Margin="0,4,0,0"/>
                        </StackPanel>
                    </RadioButton>

                </StackPanel>

            </DockPanel>
        </Border>

        <!-- ═══════════════════════════════════════════════
             CONTENU PRINCIPAL
        ═══════════════════════════════════════════════ -->
        <Grid Grid.Column="1" Background="{DynamicResource ContentBgDeep}">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- ── Fond mesh animé (deux taches lumineuses qui se déplacent) ── -->
            <Canvas Grid.Row="0" Grid.RowSpan="2" IsHitTestVisible="False" ClipToBounds="True">
                <!-- Tache violette (haut-gauche → bas-droite) -->
                <Ellipse x:Name="meshBlob1"
                         Width="520" Height="420"
                         Canvas.Left="-80" Canvas.Top="-60"
                         Opacity="0.13">
                    <Ellipse.Fill>
                        <RadialGradientBrush>
                            <GradientStop Color="{DynamicResource MeshBlob1Color}" Offset="0"/>
                            <GradientStop Color="#00000000" Offset="1"/>
                        </RadialGradientBrush>
                    </Ellipse.Fill>
                    <Ellipse.RenderTransform>
                        <TranslateTransform x:Name="blob1Transform" X="0" Y="0"/>
                    </Ellipse.RenderTransform>
                    <Ellipse.Triggers>
                        <EventTrigger RoutedEvent="Loaded">
                            <BeginStoryboard>
                                <Storyboard RepeatBehavior="Forever" AutoReverse="True">
                                    <DoubleAnimation Storyboard.TargetName="blob1Transform"
                                                     Storyboard.TargetProperty="X"
                                                     From="0" To="180" Duration="0:0:14"
                                                     EasingFunction="{x:Null}"/>
                                    <DoubleAnimation Storyboard.TargetName="blob1Transform"
                                                     Storyboard.TargetProperty="Y"
                                                     From="0" To="120" Duration="0:0:18"
                                                     EasingFunction="{x:Null}"/>
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                    </Ellipse.Triggers>
                </Ellipse>
                <!-- Tache bleue (bas-droite) -->
                <Ellipse x:Name="meshBlob2"
                         Width="460" Height="380"
                         Canvas.Right="-60" Canvas.Bottom="-40"
                         Opacity="0.10">
                    <Ellipse.Fill>
                        <RadialGradientBrush>
                            <GradientStop Color="{DynamicResource MeshBlob2Color}" Offset="0"/>
                            <GradientStop Color="#00000000" Offset="1"/>
                        </RadialGradientBrush>
                    </Ellipse.Fill>
                    <Ellipse.RenderTransform>
                        <TranslateTransform x:Name="blob2Transform" X="0" Y="0"/>
                    </Ellipse.RenderTransform>
                    <Ellipse.Triggers>
                        <EventTrigger RoutedEvent="Loaded">
                            <BeginStoryboard>
                                <Storyboard RepeatBehavior="Forever" AutoReverse="True">
                                    <DoubleAnimation Storyboard.TargetName="blob2Transform"
                                                     Storyboard.TargetProperty="X"
                                                     From="0" To="-140" Duration="0:0:20"
                                                     EasingFunction="{x:Null}"/>
                                    <DoubleAnimation Storyboard.TargetName="blob2Transform"
                                                     Storyboard.TargetProperty="Y"
                                                     From="0" To="-90" Duration="0:0:15"
                                                     EasingFunction="{x:Null}"/>
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                    </Ellipse.Triggers>
                </Ellipse>
            </Canvas>

            <!-- Voile givré — atténue le mesh, rapproche l'effet acrylic WPF -->
            <Border Grid.Row="0" Grid.RowSpan="2"
                    Background="{DynamicResource GlassFrostVeil}"
                    IsHitTestVisible="False"/>

            <!-- Panneaux (empilés, un seul visible à la fois) -->
            <Grid Grid.Row="0">
                <views:OverviewControl  x:Name="panelOverview"  Visibility="Visible"/>
                <views:AntivirusView    x:Name="panelAntivirus" Visibility="Collapsed"/>
                <views:CleanControl     x:Name="panelClean"     Visibility="Collapsed"/>
                <views:HistoryControl   x:Name="panelHistory"   Visibility="Collapsed"/>
                <views:OptionsControl   x:Name="panelOptions"   Visibility="Collapsed"/>
            </Grid>

            <!-- ── Barre de statut (footer compact : statut | Vanier) ── -->
            <Border Grid.Row="1"
                    Background="{DynamicResource HeaderBg}"
                    BorderBrush="{DynamicResource BorderColor}"
                    BorderThickness="0,1,0,0"
                    Padding="16,7">
                <Grid ClipToBounds="True">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Gauche : statut (tronqué si long — ne doit pas recouvrir Vanier) -->
                    <DockPanel Grid.Column="0" LastChildFill="True" Margin="0,0,20,0"
                               VerticalAlignment="Center">
                        <ProgressBar x:Name="statusFooterSpinner"
                                     DockPanel.Dock="Left"
                                     Width="36" Height="3"
                                     IsIndeterminate="True"
                                     Visibility="Collapsed"
                                     Foreground="{DynamicResource AccentBlue}"
                                     Background="{DynamicResource BorderSubtle}"
                                     VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <md:PackIcon x:Name="statusFooterIcon"
                                     DockPanel.Dock="Left"
                                     Kind="CheckboxMarked" Width="14" Height="14"
                                     Foreground="{DynamicResource SuccessGreen}"
                                     VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <TextBlock x:Name="lblStatus"
                                   Text="{loc:Loc Key=Main_StatusReady}"
                                   Foreground="{DynamicResource TextMedium}"
                                   FontSize="{DynamicResource FontSize.Body}"
                                   VerticalAlignment="Center"
                                   TextTrimming="CharacterEllipsis"
                                   TextWrapping="NoWrap"
                                   ToolTip="{Binding Text, RelativeSource={RelativeSource Self}}"/>
                    </DockPanel>

                    <!-- Droite : Vanier (version uniquement dans la sidebar) -->
                    <TextBlock Grid.Column="1"
                               Text="{loc:Loc Key=Main_FooterFree}"
                               Foreground="{DynamicResource TextMuted}"
                               FontSize="{DynamicResource FontSize.Small}"
                               VerticalAlignment="Center"
                               HorizontalAlignment="Right"
                               TextWrapping="NoWrap"
                               FontStyle="Italic"/>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
