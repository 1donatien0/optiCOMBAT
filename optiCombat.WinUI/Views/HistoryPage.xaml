<UserControl
    x:Class="optiCombat.WinUI.Views.HistoryPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Padding="24,20" RowSpacing="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="220" MinHeight="160" />
        </Grid.RowDefinitions>

        <Border Padding="20,16" Background="White" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="8">
            <Grid ColumnSpacing="16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Spacing="4">
                    <TextBlock FontSize="24" FontWeight="SemiBold" Text="Historique" />
                    <TextBlock Foreground="{StaticResource TextMutedBrush}" Text="Journal d'activité — analyses, nettoyages et quarantaine" />
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                    <Button Click="ExportHtml_Click" Content="Export HTML" />
                    <Button Click="ExportPdf_Click" Content="Export PDF" x:Name="ExportPdfButton" />
                    <Button Click="OpenAntivirus_Click" Content="Antivirus" />
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1" ColumnSpacing="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="220" />
            </Grid.ColumnDefinitions>
            <StackPanel Orientation="Horizontal" Spacing="6">
                <RadioButton x:Name="ChipAll" GroupName="HistFilter" IsChecked="True" Checked="Filter_Checked" Tag="All" />
                <RadioButton x:Name="ChipThreats" GroupName="HistFilter" Checked="Filter_Checked" Tag="Threats" />
                <RadioButton x:Name="ChipCleanScans" GroupName="HistFilter" Checked="Filter_Checked" Tag="CleanScans" />
                <RadioButton x:Name="ChipCleans" GroupName="HistFilter" Checked="Filter_Checked" Tag="Cleans" />
                <RadioButton x:Name="ChipQuarantine" GroupName="HistFilter" Checked="Filter_Checked" Tag="Quarantine" />
            </StackPanel>
            <TextBox Grid.Column="1" PlaceholderText="Rechercher…" TextChanged="Search_TextChanged" />
        </Grid>

        <Border Grid.Row="2" Background="White" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="8">
            <Grid>
                <ListView x:Name="TimelineList" SelectionChanged="TimelineList_SelectionChanged">
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <Grid ColumnSpacing="10" Padding="4,6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="130" />
                                    <ColumnDefinition Width="110" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="90" />
                                    <ColumnDefinition Width="160" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="{Binding DateDisplay}" FontSize="12" />
                                <TextBlock Grid.Column="1" Text="{Binding TypeDisplay}" FontSize="12" />
                                <TextBlock Grid.Column="2" Text="{Binding TargetDisplay}" TextTrimming="CharacterEllipsis" FontSize="12" />
                                <TextBlock Grid.Column="3" Text="{Binding DetailDisplay}" FontSize="12" Foreground="{StaticResource TextMutedBrush}" />
                                <TextBlock Grid.Column="4" Text="{Binding ResultSummary}" FontWeight="SemiBold" FontSize="12" />
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
                <StackPanel x:Name="EmptyState" HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="8" Visibility="Collapsed">
                    <FontIcon Glyph="&#xE81C;" FontSize="36" Foreground="{StaticResource TextMutedBrush}" />
                    <TextBlock x:Name="EmptyTitleText" FontSize="16" FontWeight="SemiBold" HorizontalAlignment="Center" />
                    <TextBlock x:Name="EmptySubtitleText" Foreground="{StaticResource TextMutedBrush}" HorizontalAlignment="Center" TextWrapping="WrapWholeWords" MaxWidth="420" />
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="3" ColumnSpacing="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBlock x:Name="SessionInfoText" VerticalAlignment="Center" Foreground="{StaticResource TextMutedBrush}" FontSize="12" TextWrapping="WrapWholeWords" />
            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" x:Name="ScanActionsPanel" Visibility="Collapsed">
                <Button Click="TreatInAntivirus_Click" Content="Traiter dans Antivirus" />
                <Button Click="QuarantineAll_Click" Content="Tout mettre en quarantaine" />
            </StackPanel>
        </Grid>

        <Border Grid.Row="4" Padding="16" Background="#F8FAFC" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="8">
            <Grid>
                <StackPanel x:Name="ScanDetailPanel" Spacing="8" Visibility="Collapsed">
                    <TextBlock x:Name="DetailText" TextWrapping="WrapWholeWords" />
                    <ListView x:Name="ThreatsList" MinHeight="100">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Grid ColumnSpacing="8" Padding="0,4">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="140" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="{Binding FilePath}" TextTrimming="CharacterEllipsis" FontSize="12" VerticalAlignment="Center" />
                                    <TextBlock Grid.Column="1" Text="{Binding VirusName}" FontWeight="SemiBold" FontSize="12" VerticalAlignment="Center" />
                                    <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="4">
                                        <Button Click="QuarantineThreat_Click" Tag="{Binding FilePath}" Content="Quarantaine" />
                                        <Button Click="DismissThreat_Click" Tag="{Binding FilePath}" Content="Ignorer" />
                                        <Button Click="IgnoreThreat_Click" Tag="{Binding FilePath}" Content="Exclure" />
                                        <Button Click="DeleteThreat_Click" Tag="{Binding FilePath}" Content="Supprimer" />
                                    </StackPanel>
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </StackPanel>

                <ScrollViewer x:Name="CleanDetailPanel" Visibility="Collapsed">
                    <TextBlock x:Name="CleanLogText" FontFamily="Consolas" FontSize="12" TextWrapping="WrapWholeWords" />
                </ScrollViewer>

                <StackPanel x:Name="QuarantineDetailPanel" Spacing="10" Visibility="Collapsed">
                    <TextBlock x:Name="QuarTitleText" FontWeight="SemiBold" FontSize="16" />
                    <TextBlock x:Name="QuarPathText" TextWrapping="WrapWholeWords" FontSize="12" />
                    <TextBlock x:Name="QuarMetaText" Foreground="{StaticResource TextMutedBrush}" FontSize="12" />
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Button Click="ViewSourceScan_Click" Content="Voir scan source" x:Name="ViewSourceScanButton" Visibility="Collapsed" />
                        <Button Click="ManageInAv_Click" Content="Gérer dans Antivirus" />
                    </StackPanel>
                </StackPanel>

                <TextBlock x:Name="NoSelectionText" VerticalAlignment="Center" Foreground="{StaticResource TextMutedBrush}" Text="Sélectionnez une entrée dans la timeline." />
            </Grid>
        </Border>
    </Grid>
</UserControl>
