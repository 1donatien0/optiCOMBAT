<UserControl
    x:Class="optiCombat.WinUI.Views.CleanPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Padding="24,20" RowSpacing="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Padding="20,16" Background="{ThemeResource CardBackgroundBrush}" BorderBrush="{ThemeResource CardBorderBrush}" BorderThickness="1" CornerRadius="8">
            <StackPanel Spacing="4">
                <TextBlock FontSize="24" FontWeight="SemiBold" Text="Nettoyer" />
                <TextBlock Foreground="{ThemeResource TextMutedBrush}" Text="Libérez de l'espace — fichiers temporaires et caches navigateurs" />
            </StackPanel>
        </Border>

        <Grid Grid.Row="1" ColumnSpacing="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Border Padding="16" Background="{ThemeResource CardBackgroundBrush}" BorderBrush="{ThemeResource CardBorderBrush}" BorderThickness="1" CornerRadius="8">
                <StackPanel Spacing="4">
                    <TextBlock FontWeight="SemiBold" Text="Temporaires système" />
                    <TextBlock x:Name="TempSizeText" FontSize="22" FontWeight="Bold" Text="0 Mo" />
                </StackPanel>
            </Border>
            <Border Grid.Column="1" Padding="16" Background="{ThemeResource CardBackgroundBrush}" BorderBrush="{ThemeResource CardBorderBrush}" BorderThickness="1" CornerRadius="8">
                <StackPanel Spacing="4">
                    <TextBlock FontWeight="SemiBold" Text="Caches navigateurs" />
                    <TextBlock x:Name="BrowserSizeText" FontSize="22" FontWeight="Bold" Text="0 Mo" />
                </StackPanel>
            </Border>
            <Border Grid.Column="2" Padding="16" Background="{StaticResource AccentBrush}" CornerRadius="8">
                <StackPanel Spacing="4">
                    <TextBlock FontWeight="SemiBold" Foreground="White" Text="Total récupérable" />
                    <TextBlock x:Name="TotalSizeText" FontSize="22" FontWeight="Bold" Foreground="White" Text="0 Mo" />
                </StackPanel>
            </Border>
        </Grid>

        <StackPanel Grid.Row="2" Orientation="Horizontal" Spacing="10">
            <Button Click="Analyze_Click" Content="Analyser" x:Name="AnalyzeButton" />
            <Button Click="Clean_Click" Content="Nettoyer maintenant" Background="{StaticResource AccentBrush}" Foreground="White" x:Name="CleanButton" IsEnabled="False" />
            <ProgressRing x:Name="BusyRing" Width="24" Height="24" Visibility="Collapsed" />
        </StackPanel>

        <Grid Grid.Row="3" ColumnSpacing="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Padding="16" Background="{ThemeResource CardBackgroundBrush}" BorderBrush="{ThemeResource CardBorderBrush}" BorderThickness="1" CornerRadius="8">
                <StackPanel Spacing="10">
                    <TextBlock FontWeight="SemiBold" Text="Système" />
                    <Grid ColumnSpacing="12" RowSpacing="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <CheckBox x:Name="ChkTempWin" Content="Temp Windows" IsChecked="True" Checked="Option_Changed" Unchecked="Option_Changed" />
                        <CheckBox x:Name="ChkTempUser" Grid.Column="1" Content="Temp utilisateur" IsChecked="True" Checked="Option_Changed" Unchecked="Option_Changed" />
                        <CheckBox x:Name="ChkRecycle" Grid.Row="1" Content="Corbeille" IsChecked="True" Checked="Option_Changed" Unchecked="Option_Changed" />
                        <CheckBox x:Name="ChkLogs" Grid.Row="1" Grid.Column="1" Content="Journaux Windows" Checked="Option_Changed" Unchecked="Option_Changed" />
                    </Grid>
                    <TextBlock FontWeight="SemiBold" Margin="0,6,0,0" Text="Navigateurs" />
                    <Grid ColumnSpacing="12" RowSpacing="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <CheckBox x:Name="ChkEdge" Content="Microsoft Edge" IsChecked="True" Checked="Option_Changed" Unchecked="Option_Changed" />
                        <CheckBox x:Name="ChkChrome" Grid.Column="1" Content="Google Chrome" IsChecked="True" Checked="Option_Changed" Unchecked="Option_Changed" />
                        <CheckBox x:Name="ChkFirefox" Grid.Row="1" Content="Mozilla Firefox" IsChecked="True" Checked="Option_Changed" Unchecked="Option_Changed" />
                        <CheckBox x:Name="ChkBrave" Grid.Row="1" Grid.Column="1" Content="Brave" Checked="Option_Changed" Unchecked="Option_Changed" />
                        <CheckBox x:Name="ChkOpera" Grid.Row="2" Content="Opera" Checked="Option_Changed" Unchecked="Option_Changed" />
                        <CheckBox x:Name="ChkVivaldi" Grid.Row="2" Grid.Column="1" Content="Vivaldi" Checked="Option_Changed" Unchecked="Option_Changed" />
                        <CheckBox x:Name="ChkArc" Grid.Row="3" Content="Arc" Checked="Option_Changed" Unchecked="Option_Changed" />
                    </Grid>
                </StackPanel>
            </Border>

            <Border Grid.Column="1" Padding="16" Background="{ThemeResource CardAltBackgroundBrush}" BorderBrush="{ThemeResource CardBorderBrush}" BorderThickness="1" CornerRadius="8">
                <Grid RowSpacing="8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <TextBlock FontWeight="SemiBold" Text="Journal" />
                    <ScrollViewer Grid.Row="1">
                        <TextBlock x:Name="LogText" FontFamily="Consolas" FontSize="12" TextWrapping="WrapWholeWords" />
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
