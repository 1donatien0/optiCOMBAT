<UserControl
    x:Class="optiCombat.WinUI.Views.OverviewPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <ScrollViewer>
        <Grid MaxWidth="1180" Padding="36,32,36,28">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="14" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="10" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="18" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Border
                Padding="28,22"
                Background="White"
                BorderBrush="#D9E2EC"
                BorderThickness="1"
                CornerRadius="8">
                <Grid ColumnSpacing="24">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Spacing="10" VerticalAlignment="Center">
                        <TextBlock
                            x:Name="ProtectionHeadline"
                            FontSize="30"
                            FontWeight="SemiBold"
                            Text="Votre ordinateur est sécurisé" />
                        <TextBlock
                            x:Name="ProtectionSubtitle"
                            MaxWidth="520"
                            Foreground="{StaticResource TextMutedBrush}"
                            FontSize="15"
                            Text="Les définitions sont à jour, l'ordinateur est protégé."
                            TextWrapping="WrapWholeWords" />
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <FontIcon
                                FontSize="13"
                                Foreground="{StaticResource AccentBrush}"
                                Glyph="&#xE823;" />
                            <TextBlock Foreground="{StaticResource AccentBrush}" Text="Dernière analyse" />
                            <TextBlock
                                x:Name="LastScanText"
                                Foreground="{StaticResource AccentBrush}"
                                FontWeight="SemiBold"
                                Text="Jamais" />
                        </StackPanel>
                        <Button
                            MinWidth="168"
                            HorizontalAlignment="Left"
                            Click="Scan_Click">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <FontIcon FontSize="15" Glyph="&#xE83D;" />
                                <TextBlock Text="Antivirus" />
                            </StackPanel>
                        </Button>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="16" VerticalAlignment="Center">
                        <Image
                            Width="128"
                            Height="128"
                            Source="ms-appx:///Assets/optiCombat_hero.png" />
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock FontSize="42" FontWeight="Bold">
                                <Run Text="opti" />
                                <Run Foreground="{StaticResource AccentBrush}" Text="COMBAT" />
                            </TextBlock>
                            <TextBlock
                                Foreground="{StaticResource TextMutedBrush}"
                                FontSize="13"
                                FontWeight="SemiBold"
                                Text="PROTECT  -  DETECT  -  DEFEND" />
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </Border>

            <Grid Grid.Row="2" ColumnSpacing="10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Button Tag="clean" Click="Action_Click">
                    <StackPanel MinHeight="64" Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                        <FontIcon Foreground="{StaticResource WarningBrush}" Glyph="&#xE90F;" />
                        <StackPanel>
                            <TextBlock FontWeight="SemiBold" Text="Nettoyer" />
                            <TextBlock Foreground="{StaticResource TextMutedBrush}" Text="Fichiers temporaires" />
                        </StackPanel>
                    </StackPanel>
                </Button>

                <Button Grid.Column="1" Tag="antivirus" Click="Action_Click">
                    <StackPanel MinHeight="64" Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                        <FontIcon Foreground="{StaticResource AccentBrush}" Glyph="&#xE83D;" />
                        <StackPanel>
                            <TextBlock FontWeight="SemiBold" Text="Antivirus" />
                            <TextBlock Foreground="{StaticResource TextMutedBrush}" Text="Lancer une analyse" />
                        </StackPanel>
                    </StackPanel>
                </Button>

                <Button Grid.Column="2" Tag="history" Click="Action_Click">
                    <StackPanel MinHeight="64" Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                        <FontIcon Foreground="#2563EB" Glyph="&#xE81C;" />
                        <StackPanel>
                            <TextBlock FontWeight="SemiBold" Text="Historique" />
                            <TextBlock Foreground="{StaticResource TextMutedBrush}" Text="Voir les analyses" />
                        </StackPanel>
                    </StackPanel>
                </Button>

                <Button Grid.Column="3" Tag="update" Click="Action_Click">
                    <StackPanel MinHeight="64" Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                        <FontIcon Foreground="#7C3AED" Glyph="&#xE895;" />
                        <StackPanel>
                            <TextBlock FontWeight="SemiBold" Text="Mise à jour" />
                            <TextBlock Foreground="{StaticResource TextMutedBrush}" Text="Signatures antivirus" />
                        </StackPanel>
                    </StackPanel>
                </Button>
            </Grid>

            <Border
                x:Name="ElevationBanner"
                Grid.Row="4"
                Padding="14,10"
                Background="#FFF7ED"
                BorderBrush="#FDBA74"
                BorderThickness="1"
                CornerRadius="8"
                Visibility="Collapsed">
                <Grid ColumnSpacing="12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <FontIcon Foreground="{StaticResource WarningBrush}" Glyph="&#xE7BA;" />
                    <TextBlock
                        Grid.Column="1"
                        Foreground="{StaticResource WarningBrush}"
                        Text="Analyse partielle : certains dossiers système sont inaccessibles sans droits administrateur."
                        TextWrapping="WrapWholeWords" />
                    <Button
                        Grid.Column="2"
                        Click="RunAsAdmin_Click"
                        Content="Analyser en administrateur" />
                </Grid>
            </Border>

            <Grid Grid.Row="6" ColumnSpacing="12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="4*" />
                    <ColumnDefinition Width="4*" />
                    <ColumnDefinition Width="3*" />
                </Grid.ColumnDefinitions>

                <Border Style="{StaticResource OverviewCardStyle}">
                    <StackPanel Spacing="10">
                        <TextBlock FontSize="18" FontWeight="SemiBold" Text="Statistiques" />
                        <TextBlock
                            x:Name="ProtectionStatsUpdated"
                            Foreground="{StaticResource TextMutedBrush}"
                            FontSize="12"
                            Text="Actualisé : maintenant" />
                        <Border Padding="12" Background="#F8FAFC" CornerRadius="8">
                            <TextBlock
                                x:Name="ProtectionStatsBody"
                                LineHeight="20"
                                Text="Aucune analyse enregistrée - lancez une analyse depuis Antivirus.&#x0a;&#x0a;Total depuis l'installation : 0 analyse.&#x0a;Détail par session : onglet Historique."
                                TextWrapping="WrapWholeWords" />
                        </Border>
                    </StackPanel>
                </Border>

                <Border Grid.Column="1" Style="{StaticResource OverviewCardStyle}">
                    <StackPanel Spacing="10">
                        <TextBlock FontSize="18" FontWeight="SemiBold" Text="Recommandations" />
                        <Border Padding="12" Background="#F8FAFC" CornerRadius="8">
                            <StackPanel Spacing="8">
                                <TextBlock FontWeight="SemiBold" Text="Score de sécurité" />
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock
                                        x:Name="SecurityScore"
                                        Foreground="{StaticResource AccentBrush}"
                                        FontSize="30"
                                        FontWeight="Bold"
                                        Text="--" />
                                    <TextBlock
                                        Margin="4,0,0,5"
                                        VerticalAlignment="Bottom"
                                        Foreground="{StaticResource TextMutedBrush}"
                                        Text="/100" />
                                </StackPanel>
                                <ItemsControl x:Name="PostureIssues" />
                            </StackPanel>
                        </Border>
                        <Border Padding="12" Background="#ECFDF5" CornerRadius="8">
                            <TextBlock
                                x:Name="HygieneRecommendation"
                                Foreground="{StaticResource AccentBrush}"
                                Text="Système sain."
                                TextWrapping="WrapWholeWords" />
                        </Border>
                    </StackPanel>
                </Border>

                <Border Grid.Column="2" Style="{StaticResource OverviewCardStyle}">
                    <StackPanel Spacing="12">
                        <TextBlock FontSize="18" FontWeight="SemiBold" Text="État de protection" />
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <FontIcon Foreground="{StaticResource AccentBrush}" Glyph="&#xE83D;" />
                            <TextBlock Grid.Column="1" Margin="8,0" Foreground="{StaticResource TextMutedBrush}" Text="ClamAV" />
                            <TextBlock x:Name="ClamAvStatus" Grid.Column="2" FontWeight="SemiBold" Foreground="{StaticResource AccentBrush}" Text="Actif" />
                        </Grid>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <FontIcon Foreground="#2563EB" Glyph="&#xE950;" />
                            <TextBlock Grid.Column="1" Margin="8,0" Foreground="{StaticResource TextMutedBrush}" Text="Règles YARA" />
                            <TextBlock x:Name="YaraStatus" Grid.Column="2" FontWeight="SemiBold" Foreground="#2563EB" Text="--" />
                        </Grid>
                        <Rectangle Height="1" Fill="#E2E8F0" />
                        <StackPanel x:Name="PlatformStatusList" Spacing="6" />
                        <Rectangle Height="1" Fill="#E2E8F0" />
                        <Grid ColumnSpacing="14">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Foreground="{StaticResource TextMutedBrush}" FontWeight="SemiBold" Text="YARA" />
                                <TextBlock x:Name="YaraPackVersion" FontSize="20" FontWeight="Bold" Text="--" />
                                <TextBlock Foreground="{StaticResource TextMutedBrush}" FontSize="12" Text="Dernière MAJ" />
                                <TextBlock x:Name="YaraLastUpdate" Text="--" />
                            </StackPanel>
                            <StackPanel Grid.Column="1">
                                <TextBlock Foreground="{StaticResource TextMutedBrush}" FontWeight="SemiBold" Text="ClamAV" />
                                <TextBlock x:Name="ClamDbVersion" FontSize="20" FontWeight="Bold" Text="--" />
                                <TextBlock Foreground="{StaticResource TextMutedBrush}" FontSize="12" Text="Dernière MAJ" />
                                <TextBlock x:Name="ClamLastUpdate" Text="--" />
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>
    </ScrollViewer>
</UserControl>
