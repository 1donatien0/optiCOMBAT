<UserControl
    x:Class="optiCombat.WinUI.Views.OverviewPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    HorizontalAlignment="Stretch"
    VerticalAlignment="Stretch">

    <Grid Padding="24,14,24,10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="10" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="8" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="10" />
            <RowDefinition Height="*" MinHeight="160" />
        </Grid.RowDefinitions>

        <Border
            Padding="20,14"
            Background="{ThemeResource CardBackgroundBrush}"
            BorderBrush="{ThemeResource CardBorderBrush}"
            BorderThickness="1"
            CornerRadius="8">
            <Grid ColumnSpacing="20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Spacing="8" VerticalAlignment="Center">
                    <TextBlock
                        x:Name="ProtectionHeadline"
                        FontSize="26"
                        FontWeight="SemiBold"
                        Text="Votre ordinateur est sécurisé" />
                    <TextBlock
                        x:Name="ProtectionSubtitle"
                        MaxWidth="480"
                        Foreground="{ThemeResource TextMutedBrush}"
                        FontSize="14"
                        Text="Les définitions sont à jour, l'ordinateur est protégé."
                        TextWrapping="WrapWholeWords" />
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <FontIcon
                            FontSize="13"
                            Foreground="{StaticResource AccentBrush}"
                            Glyph="&#xE823;" />
                        <TextBlock Foreground="{StaticResource AccentBrush}" Text="Dernière analyse" />
                        <TextBlock
                            x:Name="LastScanText"
                            Foreground="{StaticResource AccentBrush}"
                            FontWeight="SemiBold"
                            Text="Jamais" />
                    </StackPanel>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                    <Image
                        Width="108"
                        Height="108"
                        Source="ms-appx:///Assets/optiCombat_hero.png" />
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock FontSize="36" FontWeight="Bold">
                            <Run Text="opti" />
                            <Run Foreground="{StaticResource AccentBrush}" Text="COMBAT" />
                        </TextBlock>
                        <TextBlock
                            Foreground="{ThemeResource TextMutedBrush}"
                            FontSize="12"
                            FontWeight="SemiBold"
                            Text="PROTECT  -  DETECT  -  DEFEND" />
                    </StackPanel>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="2" ColumnSpacing="8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Button Tag="clean" Click="Action_Click">
                <StackPanel MinHeight="52" Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                    <FontIcon Foreground="{StaticResource WarningBrush}" Glyph="&#xE90F;" />
                    <StackPanel>
                        <TextBlock FontWeight="SemiBold" Text="Nettoyer" />
                        <TextBlock Foreground="{ThemeResource TextMutedBrush}" FontSize="12" Text="Fichiers temporaires" />
                    </StackPanel>
                </StackPanel>
            </Button>

            <Button Grid.Column="1" Tag="antivirus" Click="Action_Click">
                <StackPanel MinHeight="52" Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                    <FontIcon Foreground="{StaticResource AccentBrush}" Glyph="&#xE83D;" />
                    <StackPanel>
                        <TextBlock FontWeight="SemiBold" Text="Antivirus" />
                        <TextBlock Foreground="{ThemeResource TextMutedBrush}" FontSize="12" Text="Lancer une analyse" />
                    </StackPanel>
                </StackPanel>
            </Button>

            <Button Grid.Column="2" Tag="history" Click="Action_Click">
                <StackPanel MinHeight="52" Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                    <FontIcon Foreground="#2563EB" Glyph="&#xE81C;" />
                    <StackPanel>
                        <TextBlock FontWeight="SemiBold" Text="Historique" />
                        <TextBlock Foreground="{ThemeResource TextMutedBrush}" FontSize="12" Text="Voir les analyses" />
                    </StackPanel>
                </StackPanel>
            </Button>

            <Button Grid.Column="3" Tag="update" Click="Action_Click">
                <StackPanel MinHeight="52" Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                    <FontIcon Foreground="#7C3AED" Glyph="&#xE895;" />
                    <StackPanel>
                        <TextBlock FontWeight="SemiBold" Text="Mise à jour" />
                        <TextBlock Foreground="{ThemeResource TextMutedBrush}" FontSize="12" Text="Signatures antivirus" />
                    </StackPanel>
                </StackPanel>
            </Button>
        </Grid>

        <Border
            x:Name="ElevationBanner"
            Grid.Row="4"
            Padding="12,8"
            Background="{ThemeResource WarningTintBrush}"
            BorderBrush="#FDBA74"
            BorderThickness="1"
            CornerRadius="8"
            Visibility="Collapsed">
            <Grid ColumnSpacing="12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <FontIcon Foreground="{StaticResource WarningBrush}" Glyph="&#xE7BA;" />
                <TextBlock
                    Grid.Column="1"
                    Foreground="{StaticResource WarningBrush}"
                    Text="Analyse partielle : certains dossiers système sont inaccessibles sans droits administrateur."
                    TextWrapping="WrapWholeWords" />
                <Button
                    Grid.Column="2"
                    Click="RunAsAdmin_Click"
                    Content="Analyser en administrateur" />
            </Grid>
        </Border>

        <Grid Grid.Row="6" ColumnSpacing="10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="4*" />
                <ColumnDefinition Width="4*" />
                <ColumnDefinition Width="3*" />
            </Grid.ColumnDefinitions>

            <Border Style="{StaticResource OverviewCardStyle}">
                <StackPanel Spacing="8">
                    <TextBlock FontSize="16" FontWeight="SemiBold" Text="Statistiques" />
                    <TextBlock
                        x:Name="ProtectionStatsUpdated"
                        Foreground="{ThemeResource TextMutedBrush}"
                        FontSize="12"
                        Text="Actualisé : maintenant" />
                    <Border Padding="10" Background="{ThemeResource CardAltBackgroundBrush}" CornerRadius="8" VerticalAlignment="Stretch">
                        <TextBlock
                            x:Name="ProtectionStatsBody"
                            LineHeight="18"
                            FontSize="12"
                            Text="Aucune analyse enregistrée - lancez une analyse depuis Antivirus.&#x0a;&#x0a;Total depuis l'installation : 0 analyse.&#x0a;Détail par session : onglet Historique."
                            TextWrapping="WrapWholeWords" />
                    </Border>
                </StackPanel>
            </Border>

            <Border Grid.Column="1" Style="{StaticResource OverviewCardStyle}">
                <StackPanel Spacing="8">
                    <TextBlock FontSize="16" FontWeight="SemiBold" Text="Recommandations" />
                    <Border Padding="10" Background="{ThemeResource CardAltBackgroundBrush}" CornerRadius="8">
                        <StackPanel Spacing="6">
                            <TextBlock FontWeight="SemiBold" Text="Score de sécurité" />
                            <StackPanel Orientation="Horizontal">
                                <TextBlock
                                    x:Name="SecurityScore"
                                    Foreground="{StaticResource AccentBrush}"
                                    FontSize="26"
                                    FontWeight="Bold"
                                    Text="--" />
                                <TextBlock
                                    Margin="4,0,0,4"
                                    VerticalAlignment="Bottom"
                                    Foreground="{ThemeResource TextMutedBrush}"
                                    Text="/100" />
                            </StackPanel>
                            <ItemsControl x:Name="PostureIssues" />
                        </StackPanel>
                    </Border>
                    <Border Padding="10" Background="{ThemeResource AccentTintBrush}" CornerRadius="8">
                        <TextBlock
                            x:Name="HygieneRecommendation"
                            Foreground="{StaticResource AccentBrush}"
                            FontSize="12"
                            Text="Système sain."
                            TextWrapping="WrapWholeWords" />
                    </Border>
                </StackPanel>
            </Border>

            <Border Grid.Column="2" Style="{StaticResource OverviewCardStyle}">
                <StackPanel Spacing="8">
                    <TextBlock FontSize="16" FontWeight="SemiBold" Text="État de protection" />
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <FontIcon Foreground="{StaticResource AccentBrush}" Glyph="&#xE83D;" />
                        <TextBlock Grid.Column="1" Margin="8,0" Foreground="{ThemeResource TextMutedBrush}" FontSize="12" Text="ClamAV" />
                        <TextBlock x:Name="ClamAvStatus" Grid.Column="2" FontWeight="SemiBold" FontSize="12" Foreground="{StaticResource AccentBrush}" Text="Actif" />
                    </Grid>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <FontIcon Foreground="#2563EB" Glyph="&#xE950;" />
                        <TextBlock Grid.Column="1" Margin="8,0" Foreground="{ThemeResource TextMutedBrush}" FontSize="12" Text="Règles YARA" />
                        <TextBlock x:Name="YaraStatus" Grid.Column="2" FontWeight="SemiBold" FontSize="12" Foreground="#2563EB" Text="--" />
                    </Grid>
                    <Rectangle Height="1" Fill="{ThemeResource CardBorderBrush}" />
                    <StackPanel x:Name="PlatformStatusList" Spacing="4" />
                    <Rectangle Height="1" Fill="{ThemeResource CardBorderBrush}" />
                    <Grid ColumnSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Foreground="{ThemeResource TextMutedBrush}" FontSize="11" FontWeight="SemiBold" Text="YARA" />
                            <TextBlock x:Name="YaraPackVersion" FontSize="18" FontWeight="Bold" Text="--" />
                            <TextBlock Foreground="{ThemeResource TextMutedBrush}" FontSize="11" Text="Dernière MAJ" />
                            <TextBlock x:Name="YaraLastUpdate" FontSize="12" Text="--" />
                        </StackPanel>
                        <StackPanel Grid.Column="1">
                            <TextBlock Foreground="{ThemeResource TextMutedBrush}" FontSize="11" FontWeight="SemiBold" Text="ClamAV" />
                            <TextBlock x:Name="ClamDbVersion" FontSize="18" FontWeight="Bold" Text="--" />
                            <TextBlock Foreground="{ThemeResource TextMutedBrush}" FontSize="11" Text="Dernière MAJ" />
                            <TextBlock x:Name="ClamLastUpdate" FontSize="12" Text="--" />
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>
