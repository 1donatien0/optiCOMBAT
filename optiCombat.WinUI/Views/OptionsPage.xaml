<UserControl
    x:Class="optiCombat.WinUI.Views.OptionsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    HorizontalAlignment="Stretch"
    VerticalAlignment="Stretch">

    <UserControl.Resources>
        <!-- Carte d'option : libellé à gauche, contrôle à droite. -->
        <Style x:Key="OptionRowStyle" TargetType="Grid">
            <Setter Property="Background" Value="{ThemeResource CardBackgroundBrush}" />
            <Setter Property="Padding" Value="16,12" />
            <Setter Property="CornerRadius" Value="6" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="BorderBrush" Value="{ThemeResource CardBorderBrush}" />
        </Style>
        <Style x:Key="OptionCaptionStyle" TargetType="TextBlock" BasedOn="{StaticResource CaptionTextBlockStyle}">
            <Setter Property="Foreground" Value="{ThemeResource TextMutedBrush}" />
            <Setter Property="TextWrapping" Value="WrapWholeWords" />
        </Style>
        <Style x:Key="SectionHeaderStyle" TargetType="TextBlock" BasedOn="{StaticResource BodyStrongTextBlockStyle}">
            <Setter Property="Margin" Value="4,14,0,4" />
        </Style>
        <!-- Interrupteur compact, sans texte On/Off : la carte porte le libellé. -->
        <Style x:Key="OptionToggleStyle" TargetType="ToggleSwitch">
            <Setter Property="OnContent" Value="" />
            <Setter Property="OffContent" Value="" />
            <Setter Property="MinWidth" Value="0" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
    </UserControl.Resources>

    <Grid Padding="24,14,24,10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Padding="16,12" Background="{ThemeResource CardBackgroundBrush}" BorderBrush="{ThemeResource CardBorderBrush}" BorderThickness="1" CornerRadius="8">
            <StackPanel Spacing="4">
                <TextBlock FontSize="24" FontWeight="SemiBold" Text="Options" />
                <TextBlock Foreground="{ThemeResource TextMutedBrush}" Text="Préférences et comportement de l'application" />
            </StackPanel>
        </Border>

        <ScrollViewer Grid.Row="1" Margin="0,6,0,0">
            <StackPanel MaxWidth="920" Spacing="8">

                <TextBlock Style="{StaticResource SectionHeaderStyle}" Text="Général" />

                <Grid Style="{StaticResource OptionRowStyle}" ColumnSpacing="16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel VerticalAlignment="Center" Spacing="2">
                        <TextBlock Text="Langue de l'interface" />
                        <TextBlock Style="{StaticResource OptionCaptionStyle}" Text="S'applique immédiatement à toute l'application" />
                    </StackPanel>
                    <ComboBox x:Name="LanguageCombo" Grid.Column="1" Width="180" VerticalAlignment="Center" SelectionChanged="Language_SelectionChanged">
                        <ComboBoxItem Content="Français (fr-FR)" Tag="fr-FR" />
                        <ComboBoxItem Content="English (en-US)" Tag="en-US" />
                    </ComboBox>
                </Grid>

                <Grid Style="{StaticResource OptionRowStyle}" ColumnSpacing="16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel VerticalAlignment="Center" Spacing="2">
                        <TextBlock Text="Analyse favorite" />
                        <TextBlock Style="{StaticResource OptionCaptionStyle}" Text="Type d'analyse proposé en premier" />
                    </StackPanel>
                    <ComboBox x:Name="FavoriteScanCombo" Grid.Column="1" Width="180" VerticalAlignment="Center" SelectionChanged="FavoriteScan_SelectionChanged">
                        <ComboBoxItem Content="Analyse rapide" />
                        <ComboBoxItem Content="Analyse complète" />
                        <ComboBoxItem Content="Dossier" />
                        <ComboBoxItem Content="Fichier" />
                    </ComboBox>
                </Grid>

                <Grid Style="{StaticResource OptionRowStyle}" ColumnSpacing="16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel VerticalAlignment="Center" Spacing="2">
                        <TextBlock Text="Notifications d'action" />
                        <TextBlock Style="{StaticResource OptionCaptionStyle}" Text="Toasts lors des quarantaines, mises à jour et analyses" />
                    </StackPanel>
                    <ToggleSwitch x:Name="TglNotifications" Grid.Column="1" Style="{StaticResource OptionToggleStyle}" Toggled="Notifications_Toggled" />
                </Grid>

                <Grid Style="{StaticResource OptionRowStyle}" ColumnSpacing="16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock VerticalAlignment="Center" Text="Démarrer avec Windows" />
                    <ToggleSwitch x:Name="TglAutoStart" Grid.Column="1" Style="{StaticResource OptionToggleStyle}" Toggled="AutoStart_Toggled" />
                </Grid>

                <Grid Style="{StaticResource OptionRowStyle}" ColumnSpacing="16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel VerticalAlignment="Center" Spacing="2">
                        <TextBlock Text="Thème sombre" />
                        <TextBlock Style="{StaticResource OptionCaptionStyle}" Text="Aussi accessible via la lune / le soleil de la barre latérale" />
                    </StackPanel>
                    <ToggleSwitch x:Name="TglDarkTheme" Grid.Column="1" Style="{StaticResource OptionToggleStyle}" Toggled="DarkTheme_Toggled" />
                </Grid>

                <Grid Style="{StaticResource OptionRowStyle}" ColumnSpacing="16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel VerticalAlignment="Center" Spacing="2">
                        <TextBlock Text="Mode jeu (sans distraction)" />
                        <TextBlock Style="{StaticResource OptionCaptionStyle}" Text="Suspend les notifications pendant les applications plein écran" />
                    </StackPanel>
                    <ToggleSwitch x:Name="TglGameMode" Grid.Column="1" Style="{StaticResource OptionToggleStyle}" Toggled="GameMode_Toggled" />
                </Grid>

                <TextBlock Style="{StaticResource SectionHeaderStyle}" Text="Protection" />

                <Grid Style="{StaticResource OptionRowStyle}" ColumnSpacing="16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel VerticalAlignment="Center" Spacing="2">
                        <TextBlock Text="Protection en temps réel" />
                        <TextBlock Style="{StaticResource OptionCaptionStyle}" Text="Surveille en continu les fichiers créés ou modifiés" />
                    </StackPanel>
                    <ToggleSwitch x:Name="TglRtp" Grid.Column="1" Style="{StaticResource OptionToggleStyle}" Toggled="Rtp_Toggled" />
                </Grid>

                <Grid Style="{StaticResource OptionRowStyle}" ColumnSpacing="16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel VerticalAlignment="Center" Spacing="2">
                        <TextBlock Text="Quarantaine automatique" />
                        <TextBlock Style="{StaticResource OptionCaptionStyle}" Text="Isole les menaces détectées sans confirmation" />
                    </StackPanel>
                    <ToggleSwitch x:Name="TglAutoQuarantine" Grid.Column="1" Style="{StaticResource OptionToggleStyle}" Toggled="AutoQuarantine_Toggled" />
                </Grid>

                <Grid Style="{StaticResource OptionRowStyle}" ColumnSpacing="16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock VerticalAlignment="Center" Text="Sauvegarde avant quarantaine" />
                    <ToggleSwitch x:Name="TglBackupQuarantine" Grid.Column="1" Style="{StaticResource OptionToggleStyle}" Toggled="BackupQuarantine_Toggled" />
                </Grid>

                <Grid Style="{StaticResource OptionRowStyle}" ColumnSpacing="16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock VerticalAlignment="Center" Text="Mise à jour auto des signatures" />
                    <ToggleSwitch x:Name="TglAutoUpdate" Grid.Column="1" Style="{StaticResource OptionToggleStyle}" Toggled="AutoUpdate_Toggled" />
                </Grid>

                <Grid Style="{StaticResource OptionRowStyle}" ColumnSpacing="16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel VerticalAlignment="Center" Spacing="2">
                        <TextBlock Text="Mises à jour signatures agressives" />
                        <TextBlock Style="{StaticResource OptionCaptionStyle}" Text="Vérifie plus fréquemment, consomme plus de réseau" />
                    </StackPanel>
                    <ToggleSwitch x:Name="TglAggressiveSig" Grid.Column="1" Style="{StaticResource OptionToggleStyle}" Toggled="AggressiveSig_Toggled" />
                </Grid>

                <Grid Style="{StaticResource OptionRowStyle}" ColumnSpacing="16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock VerticalAlignment="Center" Text="Surveillance des processus" />
                    <ToggleSwitch x:Name="TglProcessMonitor" Grid.Column="1" Style="{StaticResource OptionToggleStyle}" Toggled="ProcessMonitor_Toggled" />
                </Grid>

                <Grid Style="{StaticResource OptionRowStyle}" ColumnSpacing="16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock VerticalAlignment="Center" Text="Protection anti-sabotage" />
                    <ToggleSwitch x:Name="TglTamper" Grid.Column="1" Style="{StaticResource OptionToggleStyle}" Toggled="Tamper_Toggled" />
                </Grid>

                <Grid Style="{StaticResource OptionRowStyle}" ColumnSpacing="16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock VerticalAlignment="Center" Text="Analyse des lecteurs amovibles" />
                    <ToggleSwitch x:Name="TglRemovableDrive" Grid.Column="1" Style="{StaticResource OptionToggleStyle}" Toggled="RemovableDrive_Toggled" />
                </Grid>

                <Grid Style="{StaticResource OptionRowStyle}" ColumnSpacing="16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock VerticalAlignment="Center" Text="Analyse détaillée des lecteurs USB" />
                    <ToggleSwitch x:Name="TglRemovableDetailed" Grid.Column="1" Style="{StaticResource OptionToggleStyle}" Toggled="RemovableDetailed_Toggled" />
                </Grid>

                <Grid Style="{StaticResource OptionRowStyle}" ColumnSpacing="16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock VerticalAlignment="Center" Text="Inclure les USB dans l'analyse complète" />
                    <ToggleSwitch x:Name="TglRemovableFullScan" Grid.Column="1" Style="{StaticResource OptionToggleStyle}" Toggled="RemovableFullScan_Toggled" />
                </Grid>

                <Grid Style="{StaticResource OptionRowStyle}" ColumnSpacing="16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel VerticalAlignment="Center" Spacing="2">
                        <TextBlock Text="Utiliser le moteur ClamD" />
                        <TextBlock Style="{StaticResource OptionCaptionStyle}" Text="Démon résident : analyses plus rapides, plus de mémoire" />
                    </StackPanel>
                    <ToggleSwitch x:Name="TglClamd" Grid.Column="1" Style="{StaticResource OptionToggleStyle}" Toggled="Clamd_Toggled" />
                </Grid>

                <!-- Carte composite : planification -->
                <Grid Style="{StaticResource OptionRowStyle}">
                    <StackPanel Spacing="10">
                        <Grid ColumnSpacing="16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock VerticalAlignment="Center" Text="Analyse planifiée quotidienne" />
                            <ToggleSwitch x:Name="TglScheduledScan" Grid.Column="1" Style="{StaticResource OptionToggleStyle}" Toggled="ScheduledScan_Toggled" />
                        </Grid>
                        <Grid ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="120" />
                                <ColumnDefinition Width="120" />
                            </Grid.ColumnDefinitions>
                            <TextBlock VerticalAlignment="Center" Style="{StaticResource OptionCaptionStyle}" Text="Heure d'exécution (heure / minutes)" />
                            <NumberBox x:Name="ScheduleHourBox" Grid.Column="1" Minimum="0" Maximum="23" SpinButtonPlacementMode="Compact" />
                            <NumberBox x:Name="ScheduleMinuteBox" Grid.Column="2" Minimum="0" Maximum="59" SpinButtonPlacementMode="Compact" />
                        </Grid>
                        <TextBlock x:Name="ScheduledStatusText" Style="{StaticResource OptionCaptionStyle}" />
                    </StackPanel>
                </Grid>

                <TextBlock Style="{StaticResource SectionHeaderStyle}" Text="Exclusions et seuils" />

                <!-- Carte composite : exclusions -->
                <Grid Style="{StaticResource OptionRowStyle}">
                    <StackPanel Spacing="10">
                        <TextBlock Text="Dossiers exclus de l'analyse" />
                        <Grid ColumnSpacing="8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="ExclusionInput" PlaceholderText="Chemin du dossier à exclure" />
                            <Button Grid.Column="1" Click="BrowseExclusion_Click" Content="Parcourir" />
                            <Button Grid.Column="2" Click="AddExclusion_Click" Content="Ajouter" />
                        </Grid>
                        <ListView x:Name="ExclusionsList" MaxHeight="180">
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <Grid ColumnSpacing="12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="{Binding}" TextTrimming="CharacterEllipsis" VerticalAlignment="Center" />
                                        <Button Grid.Column="1" Click="RemoveExclusion_Click" Tag="{Binding}" Content="Retirer" />
                                    </Grid>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </StackPanel>
                </Grid>

                <Grid Style="{StaticResource OptionRowStyle}" ColumnSpacing="16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="140" />
                    </Grid.ColumnDefinitions>
                    <StackPanel VerticalAlignment="Center" Spacing="2">
                        <TextBlock Text="Seuil suggestion nettoyage" />
                        <TextBlock Style="{StaticResource OptionCaptionStyle}" Text="En jours, avant de proposer un nettoyage" />
                    </StackPanel>
                    <NumberBox x:Name="CleanThresholdBox" Grid.Column="1" Minimum="1" Maximum="90" SpinButtonPlacementMode="Compact" VerticalAlignment="Center" ValueChanged="Thresholds_Changed" />
                </Grid>

                <Grid Style="{StaticResource OptionRowStyle}" ColumnSpacing="16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="140" />
                    </Grid.ColumnDefinitions>
                    <StackPanel VerticalAlignment="Center" Spacing="2">
                        <TextBlock Text="Seuil signatures obsolètes" />
                        <TextBlock Style="{StaticResource OptionCaptionStyle}" Text="En jours, avant l'alerte de mise à jour" />
                    </StackPanel>
                    <NumberBox x:Name="SignatureStaleBox" Grid.Column="1" Minimum="1" Maximum="90" SpinButtonPlacementMode="Compact" VerticalAlignment="Center" ValueChanged="Thresholds_Changed" />
                </Grid>

                <Grid Style="{StaticResource OptionRowStyle}" ColumnSpacing="16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="260" />
                    </Grid.ColumnDefinitions>
                    <StackPanel VerticalAlignment="Center" Spacing="2">
                        <TextBlock Text="Clé API VirusTotal" />
                        <TextBlock Style="{StaticResource OptionCaptionStyle}" Text="Optionnel — enrichit la réputation des menaces" />
                    </StackPanel>
                    <PasswordBox x:Name="VirusTotalBox" Grid.Column="1" VerticalAlignment="Center" PasswordChanged="VirusTotal_Changed" />
                </Grid>

                <TextBlock Style="{StaticResource SectionHeaderStyle}" Text="Mise à jour de l'application" />

                <Grid Style="{StaticResource OptionRowStyle}" ColumnSpacing="16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel VerticalAlignment="Center" Spacing="2">
                        <TextBlock x:Name="AppVersionText" />
                        <TextBlock x:Name="UpdateStatusText" Style="{StaticResource OptionCaptionStyle}" />
                    </StackPanel>
                    <Button Grid.Column="1" VerticalAlignment="Center" Click="CheckUpdates_Click" Content="Vérifier les mises à jour" />
                </Grid>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
