<UserControl
    x:Class="optiCombat.WinUI.Views.OptionsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <ScrollViewer>
        <StackPanel Padding="24,20" MaxWidth="920" Spacing="14">
            <Border Padding="20,16" Background="White" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="8">
                <StackPanel Spacing="4">
                    <TextBlock FontSize="24" FontWeight="SemiBold" Text="Options" />
                    <TextBlock Foreground="{StaticResource TextMutedBrush}" Text="Préférences et comportement de l'application" />
                </StackPanel>
            </Border>

            <Border Padding="20,16" Background="White" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="8">
                <StackPanel Spacing="14">
                    <TextBlock FontWeight="SemiBold" Text="Général" />
                    <ComboBox x:Name="LanguageCombo" Header="Langue de l'interface" SelectionChanged="Language_SelectionChanged">
                        <ComboBoxItem Content="Français (fr-FR)" Tag="fr-FR" />
                        <ComboBoxItem Content="English (en-US)" Tag="en-US" />
                    </ComboBox>
                    <ComboBox x:Name="FavoriteScanCombo" Header="Analyse favorite" SelectionChanged="FavoriteScan_SelectionChanged">
                        <ComboBoxItem Content="Analyse rapide" />
                        <ComboBoxItem Content="Analyse complète" />
                        <ComboBoxItem Content="Dossier" />
                        <ComboBoxItem Content="Fichier" />
                    </ComboBox>
                    <ToggleSwitch x:Name="TglNotifications" Header="Notifications d'action" Toggled="Notifications_Toggled" />
                    <ToggleSwitch x:Name="TglAutoStart" Header="Démarrer avec Windows" Toggled="AutoStart_Toggled" />
                    <ToggleSwitch x:Name="TglDarkTheme" Header="Thème sombre" Toggled="DarkTheme_Toggled" />
                    <ToggleSwitch x:Name="TglGameMode" Header="Mode jeu (sans distraction)" Toggled="GameMode_Toggled" />
                </StackPanel>
            </Border>

            <Border Padding="20,16" Background="White" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="8">
                <StackPanel Spacing="14">
                    <TextBlock FontWeight="SemiBold" Text="Protection" />
                    <ToggleSwitch x:Name="TglRtp" Header="Protection en temps réel" Toggled="Rtp_Toggled" />
                    <ToggleSwitch x:Name="TglAutoQuarantine" Header="Quarantaine automatique" Toggled="AutoQuarantine_Toggled" />
                    <ToggleSwitch x:Name="TglBackupQuarantine" Header="Sauvegarde avant quarantaine" Toggled="BackupQuarantine_Toggled" />
                    <ToggleSwitch x:Name="TglAutoUpdate" Header="Mise à jour auto des signatures" Toggled="AutoUpdate_Toggled" />
                    <ToggleSwitch x:Name="TglAggressiveSig" Header="Mises à jour signatures agressives" Toggled="AggressiveSig_Toggled" />
                    <ToggleSwitch x:Name="TglProcessMonitor" Header="Surveillance des processus" Toggled="ProcessMonitor_Toggled" />
                    <ToggleSwitch x:Name="TglTamper" Header="Protection anti-sabotage" Toggled="Tamper_Toggled" />
                    <ToggleSwitch x:Name="TglRemovableDrive" Header="Analyse des lecteurs amovibles" Toggled="RemovableDrive_Toggled" />
                    <ToggleSwitch x:Name="TglRemovableDetailed" Header="Analyse détaillée des lecteurs USB" Toggled="RemovableDetailed_Toggled" />
                    <ToggleSwitch x:Name="TglRemovableFullScan" Header="Inclure les USB dans l'analyse complète" Toggled="RemovableFullScan_Toggled" />
                    <ToggleSwitch x:Name="TglClamd" Header="Utiliser le moteur ClamD" Toggled="Clamd_Toggled" />
                    <ToggleSwitch x:Name="TglScheduledScan" Header="Analyse planifiée quotidienne" Toggled="ScheduledScan_Toggled" />
                    <Grid ColumnSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <NumberBox x:Name="ScheduleHourBox" Header="Heure planifiée" Minimum="0" Maximum="23" SpinButtonPlacementMode="Inline" />
                        <NumberBox x:Name="ScheduleMinuteBox" Grid.Column="1" Header="Minutes" Minimum="0" Maximum="59" SpinButtonPlacementMode="Inline" />
                    </Grid>
                    <TextBlock x:Name="ScheduledStatusText" Foreground="{StaticResource TextMutedBrush}" FontSize="12" TextWrapping="WrapWholeWords" />
                </StackPanel>
            </Border>

            <Border Padding="20,16" Background="White" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="8">
                <StackPanel Spacing="14">
                    <TextBlock FontWeight="SemiBold" Text="Exclusions et seuils" />
                    <Grid ColumnSpacing="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="ExclusionInput" PlaceholderText="Chemin du dossier à exclure" />
                        <Button Grid.Column="1" Click="BrowseExclusion_Click" Content="Parcourir" />
                        <Button Grid.Column="2" Click="AddExclusion_Click" Content="Ajouter" />
                    </Grid>
                    <ListView x:Name="ExclusionsList" MinHeight="100">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Grid ColumnSpacing="12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="{Binding}" TextTrimming="CharacterEllipsis" VerticalAlignment="Center" />
                                    <Button Grid.Column="1" Click="RemoveExclusion_Click" Tag="{Binding}" Content="Retirer" />
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                    <PasswordBox x:Name="VirusTotalBox" Header="Clé API VirusTotal (optionnel)" PasswordChanged="VirusTotal_Changed" />
                    <Grid ColumnSpacing="16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <NumberBox x:Name="CleanThresholdBox" Header="Seuil suggestion nettoyage (jours)" Minimum="1" Maximum="90" SpinButtonPlacementMode="Inline" ValueChanged="Thresholds_Changed" />
                        <NumberBox x:Name="SignatureStaleBox" Grid.Column="1" Header="Seuil signatures obsolètes (jours)" Minimum="1" Maximum="90" SpinButtonPlacementMode="Inline" ValueChanged="Thresholds_Changed" />
                    </Grid>
                </StackPanel>
            </Border>

            <Border Padding="20,16" Background="White" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="8">
                <StackPanel Spacing="10">
                    <TextBlock FontWeight="SemiBold" Text="Mise à jour de l'application" />
                    <TextBlock x:Name="AppVersionText" Foreground="{StaticResource TextMutedBrush}" />
                    <Button Click="CheckUpdates_Click" Content="Vérifier les mises à jour" HorizontalAlignment="Left" />
                    <TextBlock x:Name="UpdateStatusText" TextWrapping="WrapWholeWords" Foreground="{StaticResource TextMutedBrush}" FontSize="12" />
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
