<Window
    x:Class="optiCombat.WinUI.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="optiCombat">

    <Grid x:Name="RootGrid" Background="{ThemeResource AppBackgroundBrush}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="96" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Grid Grid.Column="0" Background="{ThemeResource SidebarBackgroundBrush}" RequestedTheme="Dark">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Image
                Width="48"
                Height="48"
                Margin="0,16,0,12"
                HorizontalAlignment="Center"
                Source="ms-appx:///Assets/optiCombat_hero.png" />

            <NavigationView
                x:Name="Navigation"
                Grid.Row="1"
                IsBackButtonVisible="Collapsed"
                IsSettingsVisible="False"
                PaneDisplayMode="LeftCompact"
                CompactPaneLength="96"
                OpenPaneLength="96"
                Background="Transparent"
                SelectionChanged="Navigation_SelectionChanged">
                <NavigationView.MenuItems>
                    <NavigationViewItem Content="Accueil" Icon="Home" Tag="overview" IsSelected="True" />
                    <NavigationViewItem Content="Nettoyer" Icon="Repair" Tag="clean" />
                    <NavigationViewItem Content="Antivirus" Tag="antivirus">
                        <NavigationViewItem.Icon>
                            <FontIcon Glyph="&#xE83D;" />
                        </NavigationViewItem.Icon>
                    </NavigationViewItem>
                    <NavigationViewItem Content="Historique" Tag="history">
                        <NavigationViewItem.Icon>
                            <FontIcon Glyph="&#xE81C;" />
                        </NavigationViewItem.Icon>
                    </NavigationViewItem>
                    <NavigationViewItem Content="Options" Icon="Setting" Tag="options" />
                </NavigationView.MenuItems>
            </NavigationView>

            <StackPanel Grid.Row="2" Spacing="6">
                <Button
                    x:Name="ThemeToggleButton"
                    HorizontalAlignment="Center"
                    Padding="10,8"
                    Background="Transparent"
                    BorderThickness="0"
                    Click="ThemeToggle_Click"
                    ToolTipService.ToolTip="Basculer entre thème clair et sombre">
                    <FontIcon x:Name="ThemeToggleIcon" FontSize="16" Glyph="&#xE708;" />
                </Button>
                <TextBlock
                    x:Name="VersionText"
                    Margin="8,0,8,12"
                    HorizontalAlignment="Center"
                    Foreground="#94A3B8"
                    FontSize="11"
                    TextAlignment="Center" />
            </StackPanel>
        </Grid>

        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <ContentControl
                x:Name="PageHost"
                Grid.Row="0"
                HorizontalContentAlignment="Stretch"
                VerticalContentAlignment="Stretch" />

            <Border
                Grid.Row="1"
                Padding="18,9"
                Background="{ThemeResource CardBackgroundBrush}"
                BorderBrush="{ThemeResource CardBorderBrush}"
                BorderThickness="0,1,0,0">
                <TextBlock
                    x:Name="StatusText"
                    Foreground="{ThemeResource TextMutedBrush}"
                    Text="WinUI 3 prêt - migration progressive" />
            </Border>
        </Grid>
    </Grid>
</Window>
