<Window
    x:Class="optiCombat.WinUI.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="optiCombat">

    <Grid x:Name="RootGrid" Background="{StaticResource AppBackgroundBrush}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="96" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Grid Grid.Column="0" Background="{StaticResource SidebarBackgroundBrush}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Image
                Width="56"
                Height="56"
                Margin="0,22,0,18"
                HorizontalAlignment="Center"
                Source="ms-appx:///Assets/optiCombat_hero.png" />

            <NavigationView
                x:Name="Navigation"
                Grid.Row="1"
                IsBackButtonVisible="Collapsed"
                IsSettingsVisible="False"
                PaneDisplayMode="LeftCompact"
                CompactPaneLength="96"
                OpenPaneLength="96"
                Background="Transparent"
                SelectionChanged="Navigation_SelectionChanged">
                <NavigationView.MenuItems>
                    <NavigationViewItem Content="Accueil" Icon="Home" Tag="overview" IsSelected="True" />
                    <NavigationViewItem Content="Nettoyer" Icon="Repair" Tag="clean" />
                    <NavigationViewItem Content="Antivirus" Icon="Shield" Tag="antivirus" />
                    <NavigationViewItem Content="Historique" Icon="Clock" Tag="history" />
                    <NavigationViewItem Content="Options" Icon="Setting" Tag="options" />
                </NavigationView.MenuItems>
            </NavigationView>

            <TextBlock
                x:Name="VersionText"
                Grid.Row="2"
                Margin="8,0,8,18"
                HorizontalAlignment="Center"
                Foreground="#94A3B8"
                FontSize="11"
                TextAlignment="Center" />
        </Grid>

        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <ContentControl x:Name="PageHost" Grid.Row="0" />

            <Border
                Grid.Row="1"
                Padding="18,9"
                Background="White"
                BorderBrush="#E2E8F0"
                BorderThickness="0,1,0,0">
                <TextBlock
                    x:Name="StatusText"
                    Foreground="{StaticResource TextMutedBrush}"
                    Text="WinUI 3 prêt - migration progressive" />
            </Border>
        </Grid>
    </Grid>
</Window>
